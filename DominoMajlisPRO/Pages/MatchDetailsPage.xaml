<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:galleryComponents="clr-namespace:DominoMajlisPRO.GalleryEngine.Components"
    x:Class="DominoMajlisPRO.Pages.MatchDetailsPage"
    BackgroundColor="#080808"
    NavigationPage.HasNavigationBar="False">
    <Grid>

        <!-- الصفحة الرئيسية -->

        <Grid
           
            RowDefinitions="90,*">

            <!-- Header -->

            <Grid
                FlowDirection="RightToLeft"
                Grid.Row="0"
                Padding="15,35,15,10"
                ColumnDefinitions="50,*,50">

                <!-- Settings -->

                <Image
                    Grid.Column="0"
                    Source="settings_gold.png"
                    WidthRequest="34"
                    HeightRequest="34"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">

                    <Image.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnMenuClicked"/>
                    </Image.GestureRecognizers>

                </Image>

                <!-- Title -->

                <Image
                    Grid.Column="1"
                    Source="head_gold.png"
                    HeightRequest="42"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Aspect="AspectFit"/>

                <!-- Back -->

                <Image
                    Grid.Column="2"
                    Source="back_gold.png"
                    WidthRequest="34"
                    HeightRequest="34"
                    HorizontalOptions="End"
                    VerticalOptions="Center">

                    <Image.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnBackClicked"/>
                    </Image.GestureRecognizers>

                </Image>

            </Grid>

            <!-- Body -->

            <ScrollView Grid.Row="1">

                <VerticalStackLayout
                     FlowDirection="RightToLeft"
                    x:Name="MainContainer"
                    Padding="15"
                    Spacing="15">

                    <!-- TEAMS DASHBOARD -->

                    <Grid
    FlowDirection="MatchParent"
    ColumnDefinitions="*,Auto,*"
    ColumnSpacing="10">

                        <!-- TEAM 1 -->

                        <Border
        x:Name="Team1Border"
        Grid.Column="0"
        StrokeThickness="2"
        BackgroundColor="#161616"
        StrokeShape="RoundRectangle 18"
        Padding="8">

                            <Grid
            ColumnDefinitions="Auto,*"
            ColumnSpacing="8">

                                <!-- Emblem -->

                                <Image
                Grid.Column="0"
                x:Name="Team1Emblem"
                WidthRequest="42"
                HeightRequest="42"
                Aspect="AspectFit"
                VerticalOptions="Center"/>

                                <!-- Info -->

                                <VerticalStackLayout
                Grid.Column="1"
                Spacing="2"
                VerticalOptions="Center">

                                    <Label
                    x:Name="Team1NameLabel"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="White"
                    MaxLines="1"
                    LineBreakMode="TailTruncation"/>

                                    <galleryComponents:IdentityPlateView
                    x:Name="Team1NamePlate"
                    HeightRequest="30"
                    MaximumWidthRequest="180"
                    HorizontalOptions="Fill"
                    IsVisible="False"/>

                                    <Label
                    x:Name="Team1IdLabel"
                    FontSize="11"
                    TextColor="Gold"
                    MaxLines="1"/>

                                    <Label
                    x:Name="Team1Player1Label"
                    FontSize="11"
                    TextColor="White"
                    MaxLines="1"
                    LineBreakMode="TailTruncation"/>

                                    <Label
                    x:Name="Team1Player2Label"
                    FontSize="11"
                    TextColor="#CCCCCC"
                    MaxLines="1"
                    LineBreakMode="TailTruncation"/>

                                </VerticalStackLayout>

                            </Grid>

                        </Border>

                        <!-- VS -->

                        <Grid
        Grid.Column="1"
        VerticalOptions="Center">

                            <Image
            Source="vs_gold_icon.png"
            WidthRequest="40"
            HeightRequest="40"
            Aspect="AspectFit"/>

                        </Grid>

                        <!-- TEAM 2 -->

                        <Border
        x:Name="Team2Border"
        Grid.Column="2"
        StrokeThickness="2"
        BackgroundColor="#161616"
        StrokeShape="RoundRectangle 18"
        Padding="8">

                            <Grid
            ColumnDefinitions="Auto,*"
            ColumnSpacing="8">

                                <!-- Emblem -->

                                <Image
                Grid.Column="0"
                x:Name="Team2Emblem"
                WidthRequest="42"
                HeightRequest="42"
                Aspect="AspectFit"
                VerticalOptions="Center"/>

                                <!-- Info -->

                                <VerticalStackLayout
                Grid.Column="1"
                Spacing="2"
                VerticalOptions="Center">

                                    <Label
                    x:Name="Team2NameLabel"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="White"
                    MaxLines="1"
                    LineBreakMode="TailTruncation"/>

                                    <galleryComponents:IdentityPlateView
                    x:Name="Team2NamePlate"
                    HeightRequest="30"
                    MaximumWidthRequest="180"
                    HorizontalOptions="Fill"
                    IsVisible="False"/>

                                    <Label
                    x:Name="Team2IdLabel"
                    FontSize="11"
                    TextColor="Gold"
                    MaxLines="1"/>

                                    <Label
                    x:Name="Team2Player1Label"
                    FontSize="11"
                    TextColor="White"
                    MaxLines="1"
                    LineBreakMode="TailTruncation"/>

                                    <Label
                    x:Name="Team2Player2Label"
                    FontSize="11"
                    TextColor="#CCCCCC"
                    MaxLines="1"
                    LineBreakMode="TailTruncation"/>

                                </VerticalStackLayout>

                            </Grid>

                        </Border>

                    </Grid>
                    <!-- STATS SECTION -->

                    <!-- MATCH SUMMARY CARD -->

                    <Border
    Stroke="Gold"
    StrokeThickness="2"
    BackgroundColor="#111111"
    StrokeShape="RoundRectangle 22"
    Padding="5">

                        <Grid
        ColumnDefinitions="*,*,*,*"
        ColumnSpacing="10">

                            <!-- WINNER -->

                            <VerticalStackLayout
            Grid.Column="0"
            HorizontalOptions="Center"
            Spacing="4">

                                <Label
                Text="الفائز"
                TextColor="Gold"
                FontSize="14"
                HorizontalTextAlignment="Center"/>

                                <Label
                x:Name="WinnerLabel"
                Text="---"
                TextColor="#4CAF50"
                FontSize="12"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                MaxLines="1"/>

                            </VerticalStackLayout>

                            <!-- RESULT -->

                            <VerticalStackLayout
            Grid.Column="1"
            HorizontalOptions="Center"
            Spacing="4">

                                <Label
                Text="النتيجة"
                TextColor="Gold"
                FontSize="14"
                HorizontalTextAlignment="Center"/>

                                <Label
                x:Name="ResultLabel"
                Text="0 - 0"
                TextColor="White"
                FontSize="12"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"/>

                            </VerticalStackLayout>

                            <!-- ROUNDS -->

                            <VerticalStackLayout
            Grid.Column="2"
            HorizontalOptions="Center"
            Spacing="4">

                                <Label
                Text="الجولات"
                TextColor="Gold"
                FontSize="14"
                HorizontalTextAlignment="Center"/>

                                <Label
                x:Name="RoundsCountLabel"
                Text="0"
                TextColor="White"
                FontSize="12"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"/>

                            </VerticalStackLayout>

                            <!-- MELES -->

                            <VerticalStackLayout
            Grid.Column="3"
            HorizontalOptions="Center"
            Spacing="4">

                                <Label
                Text="الملص"
                TextColor="Gold"
                FontSize="14"
                HorizontalTextAlignment="Center"/>

                                <Label
                x:Name="MelesLabel"
                Text="NO"
                TextColor="#FF9800"
                FontSize="12"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"/>

                            </VerticalStackLayout>

                        </Grid>

                    </Border>
                    <!-- MATCH INFO STRIP -->

                    <Border
    Stroke="Gold"
    StrokeThickness="1.5"
    BackgroundColor="#111111"
    StrokeShape="RoundRectangle 20"
    Padding="10">

                        <Grid
        FlowDirection="MatchParent"
        ColumnSpacing="0">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />

                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />

                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />

                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>

                            <!-- END TIME -->
                            <VerticalStackLayout
Grid.Column="0"
HorizontalOptions="Center"
VerticalOptions="Center"
Spacing="2">

                                <Label
    Text="وقت البداية"
    FontSize="11"
    TextColor="#D0D0D0"
    HorizontalTextAlignment="Center"
    LineBreakMode="TailTruncation"/>

                                <Label
    x:Name="MatchStartTimeLabel"
    FontSize="11"
    FontAttributes="Bold"
    TextColor="White"
    HorizontalTextAlignment="Center"
    LineBreakMode="TailTruncation"/>

                            </VerticalStackLayout>

                            <VerticalStackLayout
            Grid.Column="2"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="2">

                                <Label
                Text="وقت النهاية"
                FontSize="11"
                TextColor="#D0D0D0"
                HorizontalTextAlignment="Center"
                LineBreakMode="TailTruncation"/>

                                <Label
                x:Name="MatchEndTimeLabel"
                FontSize="11"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalTextAlignment="Center"
                LineBreakMode="TailTruncation"/>

                            </VerticalStackLayout>

                            <BoxView
            Grid.Column="1"
            WidthRequest="1"
            Color="#303030"
            VerticalOptions="Fill"/>

                            <!-- START TIME -->

                         
                            <BoxView
            Grid.Column="3"
            WidthRequest="1"
            Color="#303030"
            VerticalOptions="Fill"/>

                            <!-- DATE -->

                            <VerticalStackLayout
            Grid.Column="4"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="2">

                                <Label
                Text="التاريخ"
                FontSize="12"
                TextColor="#D0D0D0"
                HorizontalTextAlignment="Center"/>

                                <Label
                x:Name="MatchDateLabel"
                FontSize="11"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalTextAlignment="Center"
                LineBreakMode="TailTruncation"/>

                            </VerticalStackLayout>

                            <BoxView
            Grid.Column="5"
            WidthRequest="1"
            Color="#303030"
            VerticalOptions="Fill"/>

                            <!-- RULES -->

                            <VerticalStackLayout
            Grid.Column="6"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="2">

                                <Label
                Text="القوانين"
                FontSize="11"
                TextColor="#D0D0D0"
                HorizontalTextAlignment="Center"/>

                                <Label
                x:Name="RulesTypeLabel"
                FontSize="12"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalTextAlignment="Center"
                LineBreakMode="TailTruncation"/>

                            </VerticalStackLayout>

                        </Grid>

                    </Border>
                    <!-- ROUND HISTORY -->
                    <Border
    Stroke="Gold"
    StrokeThickness="2"
    BackgroundColor="#111111"
    StrokeShape="RoundRectangle 22"
    Padding="12">

                        <VerticalStackLayout
        Spacing="10">

                            <Label
            Text="سجل الجولات"
            TextColor="Gold"
            FontSize="20"
            FontAttributes="Bold"
            HorizontalTextAlignment="Center"/>

                            <BoxView
            HeightRequest="1"
            Color="#404040"/>

                            <VerticalStackLayout
            x:Name="RoundsContainer"
            Spacing="10"/>

                        </VerticalStackLayout>

                    </Border>
                    <!-- MATCH ANALYTICS -->

                
                </VerticalStackLayout>

            </ScrollView>

        </Grid>

        <!-- Overlay -->

        <Grid
             FlowDirection="RightToLeft"
            x:Name="OverlayGrid"
            IsVisible="False"
            BackgroundColor="#88000000">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    Tapped="OnOverlayTapped"/>
            </Grid.GestureRecognizers>

        </Grid>

        <!-- SIDE PANEL SYSTEM -->


            <!-- BOTTOM SHEET -->

            <Grid
    x:Name="BottomSheetRoot"
    IsVisible="False"
    ZIndex="999">

                <!-- Overlay -->

                <BoxView
        Color="#99000000">

                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer
                Tapped="OnOverlayTapped"/>
                    </BoxView.GestureRecognizers>

                </BoxView>

                <!-- Sheet -->

                <Border
        x:Name="BottomSheet"
        VerticalOptions="End"
        TranslationY="600"
        BackgroundColor="#080808"
        Stroke="Gold"
        StrokeThickness="2"
        StrokeShape="RoundRectangle 30,30,0,0"
        MaximumHeightRequest="500">

                    <ScrollView>

                        <VerticalStackLayout
                Padding="20"
                Spacing="12">

                            <!-- Handle -->

                            <Border
                    WidthRequest="60"
                    HeightRequest="5"
                    BackgroundColor="#555555"
                    HorizontalOptions="Center"
                    StrokeThickness="0"/>

                            <!-- Title -->

                            <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="10">

                                <Image
                        Source="settings_gold.png"
                        WidthRequest="24"
                        HeightRequest="24"/>

                                <Label
                        Text="إدارة المباراة"
                        TextColor="Gold"
                        FontSize="22"
                        FontAttributes="Bold"/>

                            </HorizontalStackLayout>

                            <BoxView
                    HeightRequest="1"
                    Color="#404040"/>


                            <!-- Share Image -->

                            <Border
                    Stroke="Gold"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="#121212"
                    Padding="14">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                            Tapped="OnShareImageClicked"/>
                                </Border.GestureRecognizers>

                                <HorizontalStackLayout
                        FlowDirection="RightToLeft"
                        Spacing="12">

                                    <Image
                            Source="share_image_gold.png"
                            WidthRequest="24"
                            HeightRequest="24"/>

                                    <Label
                            Text="مشاركة كصورة"
                            TextColor="White"
                            FontSize="16"/>

                                </HorizontalStackLayout>

                            </Border>

                            <!-- PDF -->

                            <Border
                    Stroke="Gold"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="#121212"
                    Padding="14">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                            Tapped="OnSharePdfClicked"/>
                                </Border.GestureRecognizers>

                                <HorizontalStackLayout
                        FlowDirection="RightToLeft"
                        Spacing="12">

                                    <Image
                            Source="pdf_gold.png"
                            WidthRequest="24"
                            HeightRequest="24"/>

                                    <Label
                            Text="مشاركة PDF"
                            TextColor="White"
                            FontSize="16"/>

                                </HorizontalStackLayout>

                            </Border>

                            <!-- Copy -->

                            <Border
                    Stroke="Gold"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="#121212"
                    Padding="14">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                            Tapped="OnCopyResultClicked"/>
                                </Border.GestureRecognizers>

                                <HorizontalStackLayout
                        FlowDirection="RightToLeft"
                        Spacing="12">

                                    <Image
                            Source="copy_gold.png"
                            WidthRequest="24"
                            HeightRequest="24"/>

                                    <Label
                            Text="نسخ النتيجة"
                            TextColor="White"
                            FontSize="16"/>

                                </HorizontalStackLayout>

                            </Border>
                        <!-- Certificate -->
                        <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="14">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
        Tapped="OnCertificateClicked"/>
                            </Border.GestureRecognizers>

                            <HorizontalStackLayout
    FlowDirection="RightToLeft"
    Spacing="12">

                                <Image
        Source="certificate_gold.png"
        WidthRequest="24"
        HeightRequest="24"/>

                                <Label
        Text="اصدار شهادة "
        TextColor="White"
        FontSize="16"/>

                            </HorizontalStackLayout>

                        </Border>
                        <!-- تحليل الزخم -->

                        <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="14">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
        Tapped="OnMomentumClicked"/>
                            </Border.GestureRecognizers>

                            <HorizontalStackLayout
    FlowDirection="RightToLeft"
    Spacing="12">

                                <Image
        Source="analytics_gold.png"
        WidthRequest="24"
        HeightRequest="24"/>

                                <Label
        Text="تحليل المباريات"
        TextColor="White"
        FontSize="16"
        HorizontalOptions="StartAndExpand"/>

                            </HorizontalStackLayout>

                        </Border>


                    </VerticalStackLayout>

                    </ScrollView>

                </Border>

            </Grid>
        <!-- Momentum Sheet -->

        <Grid
    x:Name="MomentumSheetRoot"
    IsVisible="False"
    BackgroundColor="#80000000"
    ZIndex="999">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer
            Tapped="OnMomentumOverlayTapped" />
            </Grid.GestureRecognizers>

            <Border
        x:Name="MomentumSheet"
        BackgroundColor="#111111"
        Stroke="Gold"
        StrokeThickness="2"
        StrokeShape="RoundRectangle 30,30,0,0"
        VerticalOptions="End"
        TranslationY="700"
        Padding="20">

                <VerticalStackLayout Spacing="16">

                    <BoxView
                HeightRequest="5"
                WidthRequest="60"
                CornerRadius="3"
                Color="#777"
                HorizontalOptions="Center" />

                    <Label
                Text="تحليل الزخم"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="Gold"
                HorizontalOptions="Center" />

                    <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="10">
                        <HorizontalStackLayout
                        
    FlowDirection="RightToLeft"
    Spacing="10">

                        <Image
        Source="fast_round_gold.png"
        WidthRequest="45"
        HeightRequest="45"/>

                        <Label
        Text="أسرع جولة"
        TextColor="White"
        HorizontalOptions="StartAndExpand"/>

                        <Label
        x:Name="FastestRoundLabel"
        Text="--"
        TextColor="Gold"
        FontAttributes="Bold"/>

                    </HorizontalStackLayout>
                        </Border>
                    <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="10">
                        <HorizontalStackLayout
                        
    FlowDirection="RightToLeft"
    Spacing="10">

                        <Image
        Source="slow_round_gold.png"
        WidthRequest="45"
        HeightRequest="45"/>

                        <Label
        Text="أبطأ جولة"
        TextColor="White"
        HorizontalOptions="StartAndExpand"/>

                        <Label
        x:Name="SlowestRoundLabel"
        Text="--"
        TextColor="Gold"
        FontAttributes="Bold"/>

                    </HorizontalStackLayout>
                        </Border>
                    <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="10">
                        <HorizontalStackLayout
    FlowDirection="RightToLeft"
    Spacing="10">

                        <Image
        Source="average_time_gold.png"
        WidthRequest="45"
        HeightRequest="45"/>

                        <Label
        Text="متوسط الزمن"
        TextColor="White"
        HorizontalOptions="StartAndExpand"/>

                        <Label
        x:Name="AverageRoundLabel"
        Text="--"
        TextColor="Gold"
        FontAttributes="Bold"/>

                    </HorizontalStackLayout>
                        </Border>
                

                    <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="10">
                        <HorizontalStackLayout
                            
    FlowDirection="RightToLeft"
    Spacing="10">

                        <Image
        Source="dominant_team_gold.png"
        WidthRequest="45"
        HeightRequest="45"/>

                        <Label
        Text="الفريق المسيطر"
                          
        TextColor="White"
        HorizontalOptions="StartAndExpand"/>

                        <Label
        x:Name="DominantTeamLabel"
        Text="--"
                             
        TextColor="Gold"
        FontAttributes="Bold"/>

                    </HorizontalStackLayout>
</Border>
                    <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="10">
                        <HorizontalStackLayout
    FlowDirection="RightToLeft"
    Spacing="10">

                            <Image
        Source="streak_gold.png"
        WidthRequest="45"
        HeightRequest="45"/>

                            <Label
        Text="أطول سلسلة انتصار"
        TextColor="White"
        HorizontalOptions="StartAndExpand"/>

                            <Label
        x:Name="StreakLabel"
        Text="--"
        TextColor="Gold"
        FontAttributes="Bold"/>

                        </HorizontalStackLayout>
                    </Border>
                    <Border
Stroke="Gold"
StrokeThickness="1"
StrokeShape="RoundRectangle 16"
BackgroundColor="#121212"
Padding="10">
                        <HorizontalStackLayout
    FlowDirection="RightToLeft"
    Spacing="10">

                        <Image
        Source="highest_score_gold.png"
        WidthRequest="45"
        HeightRequest="45"/>

                        <Label
        Text="أعلى نقاط"
        TextColor="White"
        HorizontalOptions="StartAndExpand"/>

                        <Label
        x:Name="HighestRoundLabel"
        Text="--"
        TextColor="Gold"
        FontAttributes="Bold"/>

                    </HorizontalStackLayout>
</Border>
                </VerticalStackLayout>

            </Border>

        </Grid>

    </Grid>
   

</ContentPage>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:galleryComponents="clr-namespace:DominoMajlisPRO.GalleryEngine.Components"
    x:Class="DominoMajlisPRO.Pages.CertificatePage"
    BackgroundColor="#080808"
    NavigationPage.HasNavigationBar="False">

    <Grid x:Name="CertificateContainer"
              BackgroundColor="#080808"
>

        <!-- Watermark -->

        <Image
            Source="domino_gold_icon.png"
            Opacity="0.17"
            WidthRequest="500"
            HeightRequest="500"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            InputTransparent="True"/>

        <!-- Frame Overlay -->

        <Image
            Source="certificate_fram_gold.png"
            Aspect="Fill"
            InputTransparent="True"
            ZIndex="999"/>

        <!-- Fixed Back Button: always visible above content & frame,
             respects the status bar safe area, never scrolls away. -->

        <Border
            ZIndex="1000"
            BackgroundColor="#CC000000"
            Stroke="#D4AF37"
            StrokeThickness="1.5"
            StrokeShape="RoundRectangle 22"
            WidthRequest="44"
            HeightRequest="44"
            Padding="8"
            Margin="0,48,18,0"
            HorizontalOptions="End"
            VerticalOptions="Start">

            <Image
                Source="back_gold.png"
                Aspect="AspectFit"/>

            <Border.GestureRecognizers>
                <TapGestureRecognizer
                    Tapped="OnBackClicked"/>
            </Border.GestureRecognizers>

        </Border>

        <ScrollView>

            <VerticalStackLayout
                 
                x:Name="CertificateRoot"
                Padding="45,120,42,120"
                Spacing="10">

                <!-- DOMINO -->

                <Label
                                          Margin="0,-10,0,0"

                    Text="DOMINO"
                    FontFamily="CinzelDecorative-Bold"
                    FontSize="25"
                    FontAttributes="Bold"
                    TextColor="Gold"
                    HorizontalTextAlignment="Center"/>

                <!-- Header -->

                <Image
                    Source="certificate_head_gold.png"
                    Aspect="AspectFit"
                    HorizontalOptions="Fill"/>

                <!-- Match Information -->

                <Border
                    Stroke="Gold"
                    StrokeThickness="1.5"
                    BackgroundColor="#18000000"
                    StrokeShape="RoundRectangle 18"
                    
                    Padding="12">

                    <Grid
                        ColumnDefinitions="*,*,*"
                        RowDefinitions="Auto,Auto"
                        ColumnSpacing="10"
                        RowSpacing="8">

                        <Label
                            x:Name="CertificateMatchIdLabel"
                            Grid.Row="0"
                            Grid.Column="0"
                            TextColor="White"
                            FontSize="12"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            x:Name="CertificateDateLabel"
                            Grid.Row="0"
                            Grid.Column="1"
                            TextColor="White"
                            FontSize="12"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            x:Name="CertificateDurationLabel"
                            Grid.Row="0"
                            Grid.Column="2"
                            TextColor="Gold"
                            FontSize="12"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            x:Name="CertificateStartTimeLabel"
                            Grid.Row="1"
                            Grid.Column="0"
                            TextColor="White"
                            FontSize="12"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            x:Name="CertificateEndTimeLabel"
                            Grid.Row="1"
                            Grid.Column="2"
                            TextColor="White"
                            FontSize="12"
                            HorizontalTextAlignment="Center"/>

                    </Grid>

                </Border>
                <!-- Teams -->

                <Border
                    Stroke="Gold"
                    StrokeThickness="1.5"
                    BackgroundColor="#18000000"
                    StrokeShape="RoundRectangle 18"
                    Padding="8">

                    <Grid
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="5">

                        <!-- Team 1 -->

                        <VerticalStackLayout
                            Grid.Column="0"
                            HorizontalOptions="Center"
                            Spacing="4">

                            <Image
                                x:Name="CertificateTeam1Emblem"
                                WidthRequest="80"
                                HeightRequest="80"/>

                            <Grid HeightRequest="34" WidthRequest="120">
                                <Label x:Name="CertificateTeam1Name" TextColor="White" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center"/>
                                <galleryComponents:RuntimeNamePlateView x:Name="CertificateTeam1NamePlate" RenderingContext="Certificate" OwnerKind="Team" IsVisible="False"/>
                            </Grid>

                            <Label
                                x:Name="CertificateTeam1Id"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                x:Name="CertificateTeam1Players"
                                TextColor="#DDDDDD"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                        <!-- VS -->

                        <Image
                            Grid.Column="1"
                            Source="vs_gold_icon.png"
                            WidthRequest="70"
                            HeightRequest="70"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                        <!-- Team 2 -->

                        <VerticalStackLayout
                            Grid.Column="2"
                            HorizontalOptions="Center"
                            Spacing="4">

                            <Image
                                x:Name="CertificateTeam2Emblem"
                                WidthRequest="80"
                                HeightRequest="80"/>

                            <Grid HeightRequest="34" WidthRequest="120">
                                <Label x:Name="CertificateTeam2Name" TextColor="White" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center"/>
                                <galleryComponents:RuntimeNamePlateView x:Name="CertificateTeam2NamePlate" RenderingContext="Certificate" OwnerKind="Team" IsVisible="False"/>
                            </Grid>

                            <Label
                                x:Name="CertificateTeam2Id"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                x:Name="CertificateTeam2Players"
                                TextColor="#DDDDDD"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>

                <!-- Result -->

                <Border
                    Stroke="Gold"
                    StrokeThickness="1.5"
                    BackgroundColor="#18000000"
                    StrokeShape="RoundRectangle 18"
                    Padding="12">

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="6">

                        <Label
                            Text="FINAL    RESULT"
                            FontFamily="CinzelDecorative-Bold"
                            TextColor="Gold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            x:Name="CertificateScoreLabel"
                            TextColor="White"
                            FontSize="40"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            x:Name="CertificateWinnerLabel"
                                FontFamily="CinzelDecorative-Bold"

                            TextColor="#4CAF50"
                            FontSize="22"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"/>

                    </VerticalStackLayout>

                </Border>

                <!-- Statistics -->

                <Border
                    Stroke="Gold"
                    StrokeThickness="1.5"
                    BackgroundColor="#18000000"
                    StrokeShape="RoundRectangle 18"
                    Padding="12">

                    <Grid
                        ColumnDefinitions="*,*,*,*"
                        ColumnSpacing="6">

                        <VerticalStackLayout
                            Grid.Column="0">

                            <Label
                                Text="ROUNDS"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                x:Name="CertificateRoundsLabel"
                                TextColor="White"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                        <VerticalStackLayout
                            Grid.Column="1">

                            <Label
                                Text="RULES"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                x:Name="CertificateRulesLabel"
                                TextColor="White"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                        <VerticalStackLayout
                            Grid.Column="2">

                            <Label
                                Text="HIGHEST"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                x:Name="CertificateHighestRoundLabel"
                                TextColor="White"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                        <VerticalStackLayout
                            Grid.Column="3">

                            <Label
                                Text="MELES"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                x:Name="CertificateMelesLabel"
                                TextColor="White"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>
                <!-- Verification -->

                <Border
                    Stroke="Gold"
                    StrokeThickness="1.5"
                    BackgroundColor="#18000000"
                    StrokeShape="RoundRectangle 18"
                    Padding="15">

                    <Grid
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="10"
                        VerticalOptions="Center">

                        <!-- Official Seal + verify text -->

                        <VerticalStackLayout
                            Grid.Column="0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Spacing="4">

                            <Image
                                Source="lin.png"
                                Opacity="0.55"
                                WidthRequest="54"
                                HeightRequest="54"
                                HorizontalOptions="Center"/>

                            <Label
                                Text="Official Authentication"
                                FontFamily="CinzelDecorative-Bold"
                                Opacity="0.85"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                        <!-- QR (bottom-right, inside certificate boundary) -->

                        <VerticalStackLayout
                            Grid.Column="1"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            Spacing="4">

                            <Border
                                BackgroundColor="White"
                                Stroke="#D4AF37"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="6"
                                HorizontalOptions="End">

                                <Image
                                    x:Name="CertificateQrImage"
                                    Source="qr_gold.png"
                                    WidthRequest="82"
                                    HeightRequest="82"
                                    Aspect="AspectFit"/>

                            </Border>

                            <Label
                                Text="تحقق من الشهادة"
                                FontFamily="CinzelDecorative-Bold"
                                TextColor="Gold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>

                <!-- HASH -->

                <Border
                    Stroke="Gold"
                    StrokeThickness="1"
                    BackgroundColor="#12000000"
                    StrokeShape="RoundRectangle 14"
                    Padding="10">

                    <Label
                        x:Name="CertificateHashLabel"
                        FontFamily="Consolas"
                        FontSize="11"
                        TextColor="#D6D6D6"
                        HorizontalTextAlignment="Center"/>

                </Border>
                <!-- PDF Button -->

                <Frame
                    x:Name="PdfFrame"
    BackgroundColor="#111111"
    BorderColor="#D4AF37"
    CornerRadius="18"
    Padding="12"
    Margin="0,10">

                    <Grid
        ColumnDefinitions="40,*">

                        <Image
                           
            Source="pdf_gold.png"
            WidthRequest="28"
            HeightRequest="28"
            VerticalOptions="Center"/>

                        <Label
                             x:Name="PdfButton"
            Grid.Column="1"
            Text="Export PDF"
            TextColor="#D4AF37"
            FontAttributes="Bold"
            FontSize="13"
            VerticalOptions="Center">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                    Tapped="OnExportPdfClicked"/>
                            </Label.GestureRecognizers>

                        </Label>

                    </Grid>

                </Frame>
                <!-- Signature -->

                <VerticalStackLayout
                    Margin="0,-10,0,0"
                    HorizontalOptions="Center"
                    Spacing="0">

                    <Image
                        Source="certificate_sigen_gold.png"
                        HeightRequest="170"
                        Aspect="AspectFit"
                        HorizontalOptions="Center"/>

                </VerticalStackLayout>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>

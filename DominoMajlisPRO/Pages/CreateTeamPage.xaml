<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:DominoMajlisPRO.Pages"
    xmlns:galleryComponents="clr-namespace:DominoMajlisPRO.GalleryEngine.Components"
    x:Class="DominoMajlisPRO.Pages.CreateTeamPage"
    Title="إنشاء فريق"
    BackgroundColor="#050607"
    FlowDirection="RightToLeft"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#76521B"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="BackgroundColor" Value="#E60B0D0F"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 16"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="Label">
            <Setter Property="TextColor" Value="#F2C46D"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HorizontalTextAlignment" Value="End"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="TextColor" Value="#F5E4C6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,-4"/>
        </Style>
        <Style x:Key="DarkEntry" TargetType="Entry">
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="PlaceholderColor" Value="#8B8B8B"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HeightRequest" Value="36"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <ScrollView x:Name="MainScroll" Grid.Row="0">
            <VerticalStackLayout Padding="{OnIdiom Phone='14,14,14,104', Tablet='28,20,28,104'}" Spacing="10">

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,4">
                    <Button
                        Text="‹"
                        WidthRequest="44"
                        HeightRequest="44"
                        Clicked="OnBackClicked"
                        BackgroundColor="#141414"
                        BorderColor="#76521B"
                        BorderWidth="1"
                        CornerRadius="14"
                        TextColor="#F2C46D"
                        FontSize="24"
                        Padding="0"/>

                    <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="10">
                        <Label
                            Text="إنشاء فريق جديد"
                            FontSize="{OnIdiom Phone=23, Tablet=32}"
                            FontAttributes="Bold"
                            TextColor="#F2C46D"
                            VerticalOptions="Center"/>
                        <Image Source="eagle_3d.png" WidthRequest="42" HeightRequest="42"/>
                    </HorizontalStackLayout>

                    <Button
                        Grid.Column="2"
                        Text="?"
                        Clicked="OnHelpClicked"
                        WidthRequest="46"
                        HeightRequest="46"
                        BackgroundColor="#141414"
                        BorderColor="#76521B"
                        BorderWidth="1"
                        CornerRadius="14"
                        TextColor="#F2C46D"
                        FontSize="24"
                        FontAttributes="Bold"/>
                </Grid>

                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="8" Margin="0,0,0,8">
                    <Border Style="{StaticResource CardBorder}" Grid.Column="0" Margin="0,0,0,0">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="معلومات الفريق  👥" Style="{StaticResource SectionTitle}"/>

                            <Label Text="اسم الفريق" Style="{StaticResource FieldLabel}"/>
                            <Border Stroke="#7A5A20" BackgroundColor="#101214" StrokeShape="RoundRectangle 12" Padding="10,0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry x:Name="TeamNameEntry" Style="{StaticResource DarkEntry}" Placeholder="أدخل اسم الفريق"/>
                                    <Image Grid.Column="1" Source="edit_card.png" WidthRequest="26" HeightRequest="26" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Label Text="نوع الفريق" Style="{StaticResource FieldLabel}"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border x:Name="TeamCard" Stroke="#FFD15F" BackgroundColor="#5A3A0D" StrokeShape="RoundRectangle 12" Padding="10">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTeamClicked"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                        <Image Source="players_card.png" WidthRequest="24" HeightRequest="24"/>
                                        <Label Text="فريق" TextColor="#FFE4A3" FontSize="16" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>

                                <Border x:Name="SingleCard" Grid.Column="1" Stroke="#3A3A3A" BackgroundColor="#151719" StrokeShape="RoundRectangle 12" Padding="10">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSingleClicked"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                        <Image Source="player_card.png" WidthRequest="24" HeightRequest="24"/>
                                        <Label Text="فردي" TextColor="#E8E0D2" FontSize="16" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>

                            <Label Text="اسم اللاعب الأول" Style="{StaticResource FieldLabel}"/>
                            <Border Stroke="#3D3528" BackgroundColor="#101214" StrokeShape="RoundRectangle 12" Padding="10,0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry x:Name="Player1Entry" Style="{StaticResource DarkEntry}" Placeholder="أدخل اسم اللاعب الأول"/>
                                    <Image Grid.Column="1" Source="player_card.png" WidthRequest="25" HeightRequest="25" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <VerticalStackLayout x:Name="Player2Layout" Spacing="6">
                                <Label Text="اسم اللاعب الثاني (اختياري)" Style="{StaticResource FieldLabel}"/>
                                <Border Stroke="#3D3528" BackgroundColor="#101214" StrokeShape="RoundRectangle 12" Padding="10,0">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Entry x:Name="Player2Entry" Style="{StaticResource DarkEntry}" Placeholder="أدخل اسم اللاعب الثاني"/>
                                        <Image Grid.Column="1" Source="player_card.png" WidthRequest="25" HeightRequest="25" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="PreviewCard"
                        Style="{StaticResource CardBorder}"
                        Grid.Column="1"
                        Margin="0">
                        <Grid>
                            <Border x:Name="PreviewEmblemBackground" BackgroundColor="#070707" StrokeThickness="0" StrokeShape="RoundRectangle 16"/>
                            <Image x:Name="PreviewBackgroundImage" IsVisible="False" Aspect="AspectFill" Opacity="0.72"/>
                            <BoxView Color="#B0000000"/>
                            <VerticalStackLayout Padding="6" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="معاينة سريعة" Style="{StaticResource SectionTitle}" HorizontalOptions="Center"/>
                                <Grid WidthRequest="{OnIdiom Phone=134, Tablet=190}" HeightRequest="{OnIdiom Phone=124, Tablet=168}">
                                    <Image x:Name="PreviewTeamEffectOverlay" IsVisible="False" Aspect="AspectFit"/>
                                    <Image x:Name="PreviewEmblem" Source="shield_3d.png" Aspect="AspectFit"/>
                                </Grid>
                                <Grid HeightRequest="40" HorizontalOptions="Fill">
                                    <Label x:Name="PreviewTeamName" Text="اسم الفريق" TextColor="#F2C46D" FontSize="28" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation"/>
                                    <galleryComponents:IdentityPlateView x:Name="PreviewTeamNamePlate" RenderingContext="CreateTeam" IsVisible="False" HeightRequest="40"/>
                                </Grid>
                                <Grid x:Name="PreviewPlayersHost" ColumnDefinitions="*,*" ColumnSpacing="6" HorizontalOptions="Fill" WidthRequest="{OnIdiom Phone=188, Tablet=220}">
                                    <VerticalStackLayout Spacing="2" WidthRequest="{OnIdiom Phone=90, Tablet=106}" HorizontalOptions="Center">
                                        <Border Stroke="#B8893B" BackgroundColor="#141414" StrokeShape="RoundRectangle 23" HeightRequest="{OnIdiom Phone=46, Tablet=56}" WidthRequest="{OnIdiom Phone=46, Tablet=56}" HorizontalOptions="Center">
                                            <Grid>
                                                <Image x:Name="PreviewPlayer1Avatar" Source="player_card.png" Aspect="AspectFill"/>
                                                <Image x:Name="PreviewPlayer1Frame" IsVisible="False" Aspect="AspectFit" Scale="1.12" InputTransparent="True"/>
                                            </Grid>
                                        </Border>
                                        <Grid HeightRequest="26">
                                            <Label x:Name="PreviewPlayer1" Text="اللاعب الأول" TextColor="White" FontSize="13" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation"/>
                                            <galleryComponents:IdentityPlateView x:Name="PreviewPlayer1NamePlate" RenderingContext="CreateTeam" IsVisible="False" HeightRequest="26"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout x:Name="PreviewPlayer2Host" Grid.Column="1" Spacing="2" WidthRequest="{OnIdiom Phone=90, Tablet=106}" HorizontalOptions="Center">
                                        <Border Stroke="#B8893B" BackgroundColor="#141414" StrokeShape="RoundRectangle 23" HeightRequest="{OnIdiom Phone=46, Tablet=56}" WidthRequest="{OnIdiom Phone=46, Tablet=56}" HorizontalOptions="Center">
                                            <Grid>
                                                <Image x:Name="PreviewPlayer2Avatar" Source="player_card.png" Aspect="AspectFill"/>
                                                <Image x:Name="PreviewPlayer2Frame" IsVisible="False" Aspect="AspectFit" Scale="1.12" InputTransparent="True"/>
                                            </Grid>
                                        </Border>
                                        <Grid HeightRequest="26">
                                            <Label x:Name="PreviewPlayer2" Text="اللاعب الثاني" TextColor="White" FontSize="13" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation"/>
                                            <galleryComponents:IdentityPlateView x:Name="PreviewPlayer2NamePlate" RenderingContext="CreateTeam" IsVisible="False" HeightRequest="26"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                    <Frame x:Name="PreviewColorDot" WidthRequest="18" HeightRequest="18" CornerRadius="9" Padding="0" BackgroundColor="#FFD700" BorderColor="#F2C46D" HasShadow="False"/>
                                    <Label x:Name="PreviewMode" Text="فريق" TextColor="#D8D0C2" FontSize="15"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,-2,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearFieldsClicked"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" FlowDirection="RightToLeft">
                        <Image Source="delete_icon.png" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" HorizontalOptions="Center" />
                        <Label Grid.Column="1" Text="تنظيف الحقول وإعادة الخيارات الافتراضية" TextColor="#F2C46D" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" VerticalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="اختيار اللاعبين  👥" Style="{StaticResource SectionTitle}"/>
                            <Entry x:Name="PlayerSearchEntry" Grid.Column="1" WidthRequest="{OnIdiom Phone=150, Tablet=240}" Placeholder="بحث" Style="{StaticResource DarkEntry}" TextChanged="OnPlayerSearchTextChanged"/>
                        </Grid>
                        <CollectionView x:Name="PlayersCollection" HeightRequest="92" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="pages:PlayerSelectionItem">
                                    <Grid WidthRequest="78">
                                        <Border Stroke="{Binding AccentColor}" StrokeThickness="1.4" BackgroundColor="#111315" StrokeShape="RoundRectangle 39" WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                                            <Image Source="{Binding AvatarSource}" Aspect="AspectFill"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPlayerCardTapped"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Label Text="{Binding DisplayName}" TextColor="#EDE4D0" FontSize="11" HorizontalTextAlignment="Center" VerticalOptions="End" MaxLines="1" LineBreakMode="TailTruncation"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="اختيار الفريق  🛡" Style="{StaticResource SectionTitle}"/>
                            <Entry x:Name="TeamInlineSearchEntry" Grid.Column="1" WidthRequest="{OnIdiom Phone=150, Tablet=240}" Placeholder="بحث" Style="{StaticResource DarkEntry}" TextChanged="OnInlineTeamSearchTextChanged"/>
                        </Grid>
                        <CollectionView x:Name="TeamsCarousel" HeightRequest="136" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="pages:TeamSelectionItem">
                                    <Border WidthRequest="136" Stroke="{Binding AccentColor}" BackgroundColor="{Binding BackgroundColor}" StrokeShape="RoundRectangle 14" Padding="9">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTeamCardTapped"/>
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                            <Image Source="{Binding EmblemSource}" WidthRequest="58" HeightRequest="58" Aspect="AspectFit" HorizontalOptions="Center"/>
                                            <Label Text="{Binding TeamName}" TextColor="#F2C46D" FontAttributes="Bold" FontSize="14" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding PlayersText}" TextColor="#EDE4D0" FontSize="11" HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="اختيار الشعار  🛡" Style="{StaticResource SectionTitle}"/>
                        <CollectionView x:Name="EmblemCarousel" HeightRequest="82" SelectionMode="Single" SelectionChanged="OnEmblemSelectionChanged" ItemsUpdatingScrollMode="KeepScrollOffset">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" SnapPointsAlignment="Center" SnapPointsType="MandatorySingle"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="pages:EmblemCarouselItem">
                                    <Grid WidthRequest="76" HeightRequest="76">
                                        <Border IsVisible="{Binding IsSelected}" Stroke="Gold" StrokeThickness="2" BackgroundColor="#332B2100" StrokeShape="RoundRectangle 14"/>
                                        <Image Source="{Binding ImageSource}" WidthRequest="64" HeightRequest="64" HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit"/>
                                        <Border IsVisible="{Binding IsSelected}" WidthRequest="20" HeightRequest="20" BackgroundColor="#F2C46D" Stroke="Black" StrokeShape="RoundRectangle 10" HorizontalOptions="Start" VerticalOptions="Start">
                                            <Label Text="✓" FontSize="12" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="اختيار اللون  🎨" Style="{StaticResource SectionTitle}"/>
                        <CollectionView x:Name="ColorCarousel" HeightRequest="58" SelectionMode="Single" SelectionChanged="OnColorSelectionChanged" ItemsUpdatingScrollMode="KeepScrollOffset">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="14" SnapPointsAlignment="Center" SnapPointsType="MandatorySingle"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="pages:TeamColorCarouselItem">
                                    <Grid WidthRequest="52" HeightRequest="52">
                                        <Border IsVisible="{Binding IsSelected}" Stroke="Gold" StrokeThickness="2" BackgroundColor="#332B2100" StrokeShape="RoundRectangle 26"/>
                                        <Image Source="{Binding ImageSource}" WidthRequest="42" HeightRequest="42" HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit"/>
                                        <Border IsVisible="False" WidthRequest="18" HeightRequest="18" BackgroundColor="#F2C46D" Stroke="Black" StrokeShape="RoundRectangle 9" HorizontalOptions="Start" VerticalOptions="Start">
                                            <Label Text="✓" FontSize="10" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="5" HeightRequest="44">
                            <Button x:Name="FramesTab" Text="الإطارات" Clicked="OnFramesTabClicked" TextColor="#F2C46D" BackgroundColor="#1B140A" BorderColor="#8A6326" BorderWidth="1" CornerRadius="9" FontSize="11" Padding="2" LineBreakMode="WordWrap"/>
                            <Button x:Name="TypographyTab" Grid.Column="1" Text="تأثيرات الخطوط" Clicked="OnTypographyTabClicked" TextColor="#B89551" BackgroundColor="#101214" BorderColor="#49391F" BorderWidth="1" CornerRadius="9" FontSize="11" Padding="2" LineBreakMode="WordWrap"/>
                            <Button x:Name="BackgroundsTab" Grid.Column="2" Text="الخلفيات" Clicked="OnBackgroundsTabClicked" TextColor="#B89551" BackgroundColor="#101214" BorderColor="#49391F" BorderWidth="1" CornerRadius="9" FontSize="11" Padding="2" LineBreakMode="WordWrap"/>
                            <Button x:Name="EffectsTab" Grid.Column="3" Text="التأثيرات البصرية" Clicked="OnEffectsTabClicked" TextColor="#B89551" BackgroundColor="#101214" BorderColor="#49391F" BorderWidth="1" CornerRadius="9" FontSize="11" Padding="2" LineBreakMode="WordWrap"/>
                        </Grid>

                        <VerticalStackLayout x:Name="OwnedFramesSection" Spacing="8">
                            <Label x:Name="FramesEmptyLabel" Text="لا توجد إطارات مملوكة للاعبي هذا الفريق" TextColor="#8E887E" FontSize="11" HorizontalTextAlignment="Center"/>
                            <CollectionView x:Name="OwnedFramesCarousel" HeightRequest="76" SelectionMode="Single" SelectionChanged="OnOwnedFrameSelectionChanged">
                                <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" SnapPointsAlignment="Center" SnapPointsType="MandatorySingle"/></CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="pages:OwnedCosmeticChoiceItem">
                                        <Border WidthRequest="116" HeightRequest="70" Padding="5" Stroke="{Binding AccentColor}" StrokeThickness="1.4" BackgroundColor="#101214" StrokeShape="RoundRectangle 10">
                                            <Grid>
                                                <Image Source="{Binding PreviewImageSource}" IsVisible="{Binding IsImageFrame}" Aspect="AspectFit"/>
                                                <galleryComponents:IdentityPlateView RenderingContext="CreateTeam" DisplayText="{Binding DisplayName}" Preset="{Binding TypographyPreset}" IsVisible="{Binding IsTypographyFrame}" HorizontalOptions="Fill"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="OwnedTypographySection" IsVisible="False" Spacing="8">
                            <Label x:Name="TypographyEmptyLabel" Text="لا توجد تأثيرات خطوط مملوكة للاعبي هذا الفريق" TextColor="#8E887E" FontSize="11" HorizontalTextAlignment="Center"/>
                            <CollectionView x:Name="OwnedTypographyCarousel" HeightRequest="76" SelectionMode="Single" SelectionChanged="OnOwnedTypographySelectionChanged">
                                <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" SnapPointsAlignment="Center" SnapPointsType="MandatorySingle"/></CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="pages:OwnedCosmeticChoiceItem">
                                        <Border WidthRequest="116" HeightRequest="70" Padding="6" Stroke="{Binding AccentColor}" StrokeThickness="1.4" BackgroundColor="#101214" StrokeShape="RoundRectangle 10">
                                            <galleryComponents:IdentityPlateView RenderingContext="CreateTeam" DisplayText="{Binding DisplayName}" Preset="{Binding TypographyPreset}" IsVisible="{Binding IsTypographyEffect}" HorizontalOptions="Fill"/>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="EmblemBackgroundSection" IsVisible="False" Spacing="8">
                        <Picker x:Name="EmblemBackgroundPicker" Title="خلفية الشعار" ItemDisplayBinding="{Binding DisplayName}" SelectedIndexChanged="OnEmblemBackgroundSelectionChanged" TextColor="#F2C46D" TitleColor="#F2C46D"/>

                        <CollectionView x:Name="EmblemBackgroundCarousel" HeightRequest="68" SelectionMode="Single" SelectionChanged="OnEmblemBackgroundCarouselSelectionChanged" ItemsUpdatingScrollMode="KeepScrollOffset">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" SnapPointsAlignment="Center" SnapPointsType="MandatorySingle"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="pages:EmblemBackgroundCarouselItem">
                                    <Grid WidthRequest="68" HeightRequest="62">
                                        <Border IsVisible="{Binding IsSelected}" Stroke="#FFD15F" StrokeThickness="2" BackgroundColor="#261B0B" StrokeShape="RoundRectangle 12"/>
                                        <Border Margin="5" Stroke="#7B5A23" StrokeThickness="1" BackgroundColor="{Binding SwatchColor}" StrokeShape="RoundRectangle 10">
                                            <Grid>
                                                <Image IsVisible="{Binding IsImage}" Source="{Binding ImageSource}" Aspect="AspectFill"/>
                                            </Grid>
                                        </Border>
                                        <Border IsVisible="{Binding IsSelected}" WidthRequest="18" HeightRequest="18" BackgroundColor="#F2C46D" Stroke="Black" StrokeShape="RoundRectangle 9" HorizontalOptions="Start" VerticalOptions="Start">
                                            <Label Text="✓" FontSize="10" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="TeamEffectSection" IsVisible="False" Spacing="8">
                            <Label Text="تأثير الفريق" TextColor="#F2C46D" FontAttributes="Bold" HorizontalTextAlignment="End"/>
                            <CollectionView x:Name="TeamEffectCarousel" HeightRequest="66" SelectionMode="Single" SelectionChanged="OnTeamEffectSelectionChanged" ItemsUpdatingScrollMode="KeepScrollOffset">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" SnapPointsAlignment="Center" SnapPointsType="MandatorySingle"/>
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="pages:TeamEffectCarouselItem">
                                        <Grid WidthRequest="64" HeightRequest="64" Loaded="OnTeamEffectItemLoaded">
                                            <Border IsVisible="{Binding IsSelected}" Stroke="Gold" StrokeThickness="1.5" BackgroundColor="#221A0C" StrokeShape="RoundRectangle 12"/>
                                            <Image IsVisible="{Binding HasPreviewImage}" Source="{Binding PreviewImageSource}" WidthRequest="54" HeightRequest="54" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            <Label IsVisible="{Binding IsNone}" Text="بدون" FontSize="10" TextColor="White" HorizontalOptions="Center" VerticalOptions="End"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="12" IsVisible="False">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="التحقق قبل الحفظ" Style="{StaticResource SectionTitle}"/>
                        <FlexLayout x:Name="ValidationPanel" Direction="Row" Wrap="Wrap" JustifyContent="End"/>
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="ReadinessStatusLabel" Text="" TextColor="#D7B66F" FontSize="12" HorizontalTextAlignment="End" Margin="4,0,4,-4"/>

                <Grid x:Name="ActionButtonsGrid" ColumnDefinitions="*,*,*" ColumnSpacing="6" Margin="0,4,0,2">
                    <Border Stroke="#A05E21" BackgroundColor="#8C5A1B" StrokeShape="RoundRectangle 12" Padding="6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSaveClicked"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Image x:Name="SaveButtonIcon" Source="save_card.png" WidthRequest="18" HeightRequest="18"/>
                            <Label x:Name="SaveButtonText" Text="إنشاء الفريق" TextColor="#FFE7B0" FontAttributes="Bold" FontSize="17"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Stroke="#7B201B" BackgroundColor="#42110F" StrokeShape="RoundRectangle 12" Padding="6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDeleteCurrentTeamClicked"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Image Source="delete_icon.png" WidthRequest="16" HeightRequest="16"/>
                            <Label Text="حذف الفريق" TextColor="#FF6B5F" FontAttributes="Bold" FontSize="17"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Stroke="#7B201B" BackgroundColor="#42110F" StrokeShape="RoundRectangle 12" Padding="6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDeleteAllTeamsClicked"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Image Source="delete_icon.png" WidthRequest="16" HeightRequest="16"/>
                            <Label Text="حذف جميع الفرق" TextColor="#FF6B5F" FontAttributes="Bold" FontSize="17"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1" Margin="12,0,12,10" Stroke="#3D2C15" BackgroundColor="#F007090B" StrokeShape="RoundRectangle 18" Padding="0">
            <Grid ColumnDefinitions="*,*,*,*" HeightRequest="76">
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterHomeTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="الصفحة الرئيسية" TextColor="#D7B66F" FontSize="12"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterCreateTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="players_card.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="إنشاء فريق" TextColor="#FFD15F" FontSize="12" FontAttributes="Bold"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterPlayTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="joystick_gold.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="اللعب" TextColor="#D7B66F" FontSize="12"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterStoreTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="shop_gold.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="المتجر" TextColor="#D7B66F" FontSize="12"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid x:Name="DialogOverlay" Grid.RowSpan="2" IsVisible="False" Opacity="0" BackgroundColor="#B0000000" Padding="22" ZIndex="90">
            <Border x:Name="DialogSheet" Stroke="#C99539" StrokeThickness="1.4" BackgroundColor="#F00A0B0D" StrokeShape="RoundRectangle 20" Padding="18" HorizontalOptions="Fill" VerticalOptions="Center" Margin="10" MinimumWidthRequest="280" MaximumWidthRequest="440" Scale="0.92">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="DialogTitleLabel" TextColor="#F2C46D" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="End" LineBreakMode="WordWrap" MaxLines="3"/>
                    <Label x:Name="DialogMessageLabel" TextColor="#F8EAD0" FontSize="13" LineBreakMode="WordWrap" HorizontalTextAlignment="End" MaxLines="8"/>
                    <Grid x:Name="DialogButtonsGrid" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
                        <Border x:Name="DialogCancelButton" Stroke="#6B4A1E" BackgroundColor="#15110B" StrokeShape="RoundRectangle 12" Padding="10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDialogCancelTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="DialogCancelLabel" Text="إلغاء" TextColor="#D7B66F" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation"/>
                        </Border>
                        <Border x:Name="DialogOkButton" Grid.Column="1" Stroke="#D6A642" BackgroundColor="#7E5518" StrokeShape="RoundRectangle 12" Padding="12,10" MinimumWidthRequest="112">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDialogOkTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="DialogOkLabel" Text="حسناً" TextColor="#FFF4CF" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>

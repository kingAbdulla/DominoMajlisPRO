<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:DominoMajlisPRO.Pages"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    x:Class="DominoMajlisPRO.Pages.CreateTeamPage"
    BackgroundColor="#050505"
    FlowDirection="RightToLeft"
  Title="إنشاء فريق">

    <Grid>

        <ScrollView x:Name="MainScroll">

            <VerticalStackLayout

                Padding="25"
            Spacing="20">

            <Grid
    ColumnDefinitions="Auto,*">

                <Button
        Text="←"
        WidthRequest="50"
        HeightRequest="50"
        Clicked="OnBackClicked"
        BackgroundColor="#1A1A1A"
        TextColor="Gold"/>

                <Label
        Grid.Column="1"
        Text="إنشاء فريق"
        FontSize="28"
        FontAttributes="Bold"
        TextColor="Gold"
        HorizontalOptions="Center"/>
            </Grid>
            <!-- TEAM TYPE -->

            <Label
    Text="نوع الفريق"
    FontSize="22"
    FontAttributes="Bold"
    TextColor="Gold"/>

            <Grid
    ColumnDefinitions="*,*"
    ColumnSpacing="12">

                <!-- فردي -->

                <Border
        x:Name="SingleCard"
        Stroke="#404040"
        StrokeThickness="2"
        BackgroundColor="#151515"
        StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                Tapped="OnSingleClicked"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout
            Padding="15"
            Spacing="8"
            HorizontalOptions="Center">

                        <Image
                Source="player_card.png"
                WidthRequest="42"
                HeightRequest="42"
                Aspect="AspectFit"/>

                        <Label
                Text="فردي"
                FontSize="18"
                TextColor="White"
                HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                </Border>

                <!-- فريق -->

                <Border
        x:Name="TeamCard"
        Grid.Column="1"
        Stroke="#FFD700"
        StrokeThickness="2"
        BackgroundColor="#1A1A00"
        StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                Tapped="OnTeamClicked"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout
            Padding="15"
            Spacing="8"
            HorizontalOptions="Center">

                        <Image
                Source="players_card.png"
                WidthRequest="42"
                HeightRequest="42"
                Aspect="AspectFit"/>

                        <Label
                Text="فريق"
                FontSize="18"
                TextColor="Gold"
                HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                </Border>

            </Grid>
            <!-- TEAM NAME -->

            <Border
    Stroke="#7A5A00"
    StrokeThickness="1.5"
    BackgroundColor="#0B0B0B"
    StrokeShape="RoundRectangle 18"
    Padding="0">

                <Grid
        ColumnDefinitions="55,*,55">

                    <!-- Team Icon -->

                    <Border
            Grid.Column="0"
            BackgroundColor="#111111"
            Stroke="#2A2A2A"
            StrokeShape="RoundRectangle 18,0,0,18">

                        <Image
                Source="teamname_card.png"
                WidthRequest="34"
                HeightRequest="34"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Aspect="AspectFit"/>

                    </Border>

                    <!-- Team Name Entry -->

                    <Entry
            Grid.Column="1"
            x:Name="TeamNameEntry"
            Placeholder="اكتب اسم الفريق"
            PlaceholderColor="#777777"
            TextColor="White"
            BackgroundColor="Transparent"
            FontSize="18"
            Margin="10,0"/>

                    <!-- Select Team Button -->

                    <Border
            Grid.Column="2"
            BackgroundColor="#111111"
            Stroke="#2A2A2A"
            StrokeShape="RoundRectangle 0,18,18,0">

                        <Image
                Source="edit_card.png"
                WidthRequest="30"
                HeightRequest="30"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                            <Image.GestureRecognizers>

                                <TapGestureRecognizer
                        Tapped="OnSelectTeamClicked"/>

                            </Image.GestureRecognizers>

                        </Image>

                    </Border>

                </Grid>

            </Border>
            <!-- Player 1 -->

            <Border
    Stroke="#7A5A00"
    StrokeThickness="1.5"
    BackgroundColor="#0B0B0B"
    StrokeShape="RoundRectangle 18">

                <Grid
        ColumnDefinitions="55,*">

                    <Border
            BackgroundColor="#111111"
            Stroke="#2A2A2A"
            StrokeShape="RoundRectangle 18,0,0,18">

                        <Image
                Source="player_card.png"
                WidthRequest="34"
                HeightRequest="34"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Aspect="AspectFit"/>

                    </Border>

                    <Entry
            Grid.Column="1"
            x:Name="Player1Entry"
            Placeholder="اللاعب الأول (قائد الفريق)"
            PlaceholderColor="#777777"
            TextColor="White"
            BackgroundColor="Transparent"
            FontSize="18"
            Margin="10,0"/>

                </Grid>

            </Border>

            <!-- Player 2 -->

            <VerticalStackLayout
    x:Name="Player2Layout">

                <Border
        Stroke="#7A5A00"
        StrokeThickness="1.5"
        BackgroundColor="#0B0B0B"
        StrokeShape="RoundRectangle 18">

                    <Grid
            ColumnDefinitions="55,*">

                        <Border
                BackgroundColor="#111111"
                Stroke="#2A2A2A"
                StrokeShape="RoundRectangle 18,0,0,18">

                            <Image
                    Source="player_card.png"
                    WidthRequest="34"
                    HeightRequest="34"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Aspect="AspectFit"/>

                        </Border>

                        <Entry
                Grid.Column="1"
                x:Name="Player2Entry"
                Placeholder="اللاعب الثاني (اختياري)"
                PlaceholderColor="#777777"
                TextColor="White"
                BackgroundColor="Transparent"
                FontSize="18"
                Margin="10,0"/>

                    </Grid>

                </Border>

            </VerticalStackLayout>
            <!-- Emblem -->

            <!--معاينة النتائج المختارة -->
            <Label
    Text="اختر الشعار"
    FontSize="20"
    FontAttributes="Bold"
    HorizontalOptions="Center"
    TextColor="Gold"/>

            <CollectionView
                x:Name="EmblemCarousel"
                HeightRequest="54"
                HorizontalOptions="Fill"
                SelectionMode="Single"
                SelectionChanged="OnEmblemSelectionChanged"
                ItemsUpdatingScrollMode="KeepScrollOffset">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout
                        Orientation="Horizontal"
                        ItemSpacing="10"
                        SnapPointsAlignment="Center"
                        SnapPointsType="MandatorySingle"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="pages:EmblemCarouselItem">
                        <Grid
                            WidthRequest="54"
                            HeightRequest="54"
                            HorizontalOptions="Center">

                            <Border
                                IsVisible="{Binding IsSelected}"
                                Margin="2"
                                BackgroundColor="#332B2100"
                                Stroke="Gold"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 25">
                                <Border.Shadow>
                                    <Shadow
                                        Brush="Gold"
                                        Opacity="0.75"
                                        Radius="10"
                                        Offset="0,0"/>
                                </Border.Shadow>
                            </Border>

                            <Image
                                Source="ss.png"
                                WidthRequest="54"
                                HeightRequest="54"
                                Opacity="0.8"
                                Aspect="Fill"/>

                            <Image
                                Source="{Binding ImageSource}"
                                WidthRequest="38"
                                HeightRequest="38"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                                <Image.Triggers>
                                    <DataTrigger
                                        TargetType="Image"
                                        Binding="{Binding IsSelected}"
                                        Value="True">
                                        <Setter Property="Scale" Value="1.15"/>
                                    </DataTrigger>
                                </Image.Triggers>
                            </Image>

                            <Border
                                IsVisible="{Binding IsSelected}"
                                WidthRequest="18"
                                HeightRequest="18"
                                BackgroundColor="Gold"
                                Stroke="Black"
                                StrokeThickness="1"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"
                                TranslationX="4"
                                TranslationY="-4"
                                ZIndex="999"
                                StrokeShape="RoundRectangle 9">

                                <Label
                                    Text="✓"
                                    FontSize="10"
                                    TextColor="Black"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>

                            </Border>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>


            <VerticalStackLayout
                x:Name="TeamEffectSection"
                IsVisible="False"
                Spacing="8">

                <Label
                    Text="مؤثر الفريق"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="Gold"
                    HorizontalOptions="Center"/>

                <CollectionView
                    x:Name="TeamEffectCarousel"
                    HeightRequest="64"
                    HorizontalOptions="Fill"
                    SelectionMode="Single"
                    SelectionChanged="OnTeamEffectSelectionChanged"
                    ItemsUpdatingScrollMode="KeepScrollOffset">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout
                            Orientation="Horizontal"
                            ItemSpacing="10"
                            SnapPointsAlignment="Center"
                            SnapPointsType="MandatorySingle"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="pages:TeamEffectCarouselItem">
                            <Grid
                                WidthRequest="64"
                                HeightRequest="64"
                                Loaded="OnTeamEffectItemLoaded">
                                <Border
                                    IsVisible="{Binding IsSelected}"
                                    Stroke="Gold"
                                    StrokeThickness="1.5"
                                    BackgroundColor="#221A0C"
                                    StrokeShape="RoundRectangle 30"/>
                                <Image
                                    Source="shield_3d.png"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                                <Label
                                    IsVisible="{Binding IsNone}"
                                    Text="بدون"
                                    FontSize="10"
                                    TextColor="White"
                                    HorizontalOptions="Center"
                                    VerticalOptions="End"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Team Color -->

            <Label
    Text="لون الفريق"
    FontSize="20"
    FontAttributes="Bold"
    TextColor="Gold"
    HorizontalOptions="Center"/>

            <CollectionView
                x:Name="ColorCarousel"
                HeightRequest="40"
                HorizontalOptions="Fill"
                SelectionMode="Single"
                SelectionChanged="OnColorSelectionChanged"
                ItemsUpdatingScrollMode="KeepScrollOffset">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout
                        Orientation="Horizontal"
                        ItemSpacing="10"
                        SnapPointsAlignment="Center"
                        SnapPointsType="MandatorySingle"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="pages:TeamColorCarouselItem">
                        <Grid
                            WidthRequest="40"
                            HeightRequest="40"
                            HorizontalOptions="Center">

                            <Border
                                IsVisible="{Binding IsSelected}"
                                Margin="1"
                                BackgroundColor="#332B2100"
                                Stroke="Gold"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 19">
                                <Border.Shadow>
                                    <Shadow
                                        Brush="Gold"
                                        Opacity="0.75"
                                        Radius="8"
                                        Offset="0,0"/>
                                </Border.Shadow>
                            </Border>

                            <Image
                                Source="ss.png"
                                WidthRequest="40"
                                HeightRequest="40"
                                Opacity="0.8"
                                Aspect="Fill"/>

                            <Image
                                Source="{Binding ImageSource}"
                                WidthRequest="30"
                                HeightRequest="30"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Aspect="AspectFit">
                                <Image.Triggers>
                                    <DataTrigger
                                        TargetType="Image"
                                        Binding="{Binding IsSelected}"
                                        Value="True">
                                        <Setter Property="Scale" Value="1.12"/>
                                    </DataTrigger>
                                </Image.Triggers>
                            </Image>

                            <Border
                                IsVisible="{Binding IsSelected}"
                                WidthRequest="18"
                                HeightRequest="18"
                                BackgroundColor="Gold"
                                Stroke="Black"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 9"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"
                                ZIndex="999">

                                <Label
                                    Text="✓"
                                    FontSize="10"
                                    TextColor="Black"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>

                            </Border>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <Grid
    Margin="0,10,0,-15"
    HorizontalOptions="Center"
    ZIndex="10">

                <Border
    HorizontalOptions="Center"
    BackgroundColor="#111111"
    Stroke="#0B0B0B"
    StrokeThickness="1"
    StrokeShape="RoundRectangle 18"
    Padding="16,5"
    Margin="0,0,0,-18"
    ZIndex="100">

                    <Label
        Text="معاينة سريعة"
        FontSize="18"
        FontAttributes="Bold"
        TextColor="Gold"/>
                </Border>
            </Grid>



            <Grid
    Margin="0,-10,0,0"
    HeightRequest="260">

                <Picker
                    x:Name="EmblemBackgroundPicker"
                    Title="خلفية الشعار"
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedIndexChanged="OnEmblemBackgroundSelectionChanged"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    ZIndex="1000"/>

                <!-- الإطار الذهبي -->

                <Image
        Source="preview_fram.png"
        Aspect="Fill"
                    Opacity="0.8"
        HorizontalOptions="Fill"
        VerticalOptions="Fill"/>

                <!-- خلفية البطاقة -->

                <Border
        Margin="18"
        BackgroundColor="#0B0B0B"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 26">

                    <Grid
            Padding="18">

                        <Grid
                HeightRequest="200"
                ColumnDefinitions="1.4*,1,1.6*">

                            <!-- الشعار -->

                            <Border
                    x:Name="PreviewEmblemBackground"
                    Grid.Column="2"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 999"
                    WidthRequest="125"
                    HeightRequest="125"
                    MaximumWidthRequest="170"
                    MaximumHeightRequest="170"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>

                            <Image
                    x:Name="PreviewTeamEffectOverlay"
                    Grid.Column="2"
                    WidthRequest="155"
                    HeightRequest="155"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    InputTransparent="True"
                    IsVisible="False"/>

                            <Image
                    x:Name="PreviewEmblem"
                    Grid.Column="2"
                    Source="shield_3d.png"
                    WidthRequest="125"
                    HeightRequest="125"
                    MaximumWidthRequest="170"
                    MaximumHeightRequest="170"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Aspect="AspectFit"/>

                            <!-- الفاصل -->

                            <BoxView
                    Grid.Column="1"
                    WidthRequest="1"
                    Margin="15,25"
                    Color="#8A8A8A"/>

                            <!-- المعلومات -->

                            <VerticalStackLayout
                    Grid.Column="0"
                    VerticalOptions="Center"
                    Spacing="12">

                                <Label
                        x:Name="PreviewTeamName"
                        Text="اسم الفريق"
                        FontSize="22"
                        FontAttributes="Bold"
                        MaxLines="2"
                        LineBreakMode="NoWrap"
                        TextColor="Gold"/>

                                <Grid
                        ColumnDefinitions="*,Auto,*"
                        Margin="0,5,0,0">

                                    <Label
                            x:Name="PreviewPlayer1"
                            Text="اللاعب الأول"
                            FontSize="15"
                            TextColor="White"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="NoWrap"
                            MaxLines="2"/>

                                    <Label
                            Grid.Column="1"
                            Text="|"
                            FontSize="18"
                            TextColor="Gold"
                            Margin="10,0"/>

                                    <Label
                            x:Name="PreviewPlayer2"
                            Grid.Column="2"
                            Text="اللاعب الثاني"
                            FontSize="15"
                            TextColor="White"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="NoWrap"
                            MaxLines="2"/>

                                </Grid>

                                <Grid
                        ColumnDefinitions="Auto,*"
                        VerticalOptions="End">

                                    <Frame
                            x:Name="PreviewColorDot"
                            WidthRequest="20"
                            HeightRequest="20"
                            CornerRadius="10"
                            Padding="0"
                            BorderColor="Gold"
                            BackgroundColor="Gold"
                            HasShadow="False"
                            HorizontalOptions="Start"/>

                                    <Label
                            Grid.Column="1"
                            x:Name="PreviewMode"
                            Text="فريق"
                            FontSize="18"
                            TextColor="#CCCCCC"
                            VerticalOptions="Center"
                            Margin="10,0,0,0"/>

                                </Grid>

                            </VerticalStackLayout>

                        </Grid>

                    </Grid>

                </Border>

            </Grid>

            <!-- Save -->


            <!-- SAVE TEAM BUTTON -->

            <Border
    Stroke="#FFD700"
    StrokeThickness="3"
    BackgroundColor="#111111"
    StrokeShape="RoundRectangle 25"
    HeightRequest="75"
    Margin="0,10,0,0">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer
            Tapped="OnSaveClicked"/>
                </Border.GestureRecognizers>

                <Grid
        ColumnDefinitions="Auto,*"
        Padding="20,0">

                    <!-- أيقونة الحفظ -->

                    <Image
                        x:Name="SaveButtonIcon"
            Source="save_card.png"
            WidthRequest="42"
            HeightRequest="42"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>

                    <!-- النص -->
                        <Label
x:Name="SaveButtonText"
Grid.Column="1"
Text="إنشاء الفريق"
FontSize="24"
FontAttributes="Bold"
TextColor="Gold"
HorizontalOptions="Center"
VerticalOptions="Center"/>

                    </Grid>

            </Border>

        
    


            <!-- SAVED TEAMS BOTTOM SHEET -->

           

            </VerticalStackLayout>

        </ScrollView>
        <Grid
x:Name="TeamsOverlay"
IsVisible="False"
BackgroundColor="#AA000000"
ZIndex="999">

            <!-- لمس الخلفية للإغلاق -->

            <Grid.GestureRecognizers>
                <TapGestureRecognizer
        Tapped="OnCloseTeamsOverlay"/>
            </Grid.GestureRecognizers>

            <!-- النافذة -->

            <Border
    VerticalOptions="End"
    BackgroundColor="#0B0B0B"
    Stroke="#FFD700"
    StrokeThickness="2"
    StrokeShape="RoundRectangle 30,30,0,0"
    HeightRequest="500">

                <Grid
        RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <!-- المقبض -->

                    <BoxView
            HeightRequest="5"
            WidthRequest="70"
            CornerRadius="3"
            Color="#666666"
            HorizontalOptions="Center"
            Margin="0,10"/>

                    <!-- العنوان -->

                    <Label
            Grid.Row="1"
            Text="الفرق المحفوظة"
            FontSize="24"
            FontAttributes="Bold"
            TextColor="Gold"
            HorizontalOptions="Center"
            Margin="0,10"/>

                    <!-- البحث -->

                    <Border
            Grid.Row="2"
            Margin="20,10,20,0"
            HeightRequest="55"
            Stroke="#444444"
            BackgroundColor="#111111"
            StrokeShape="RoundRectangle 18"
            VerticalOptions="Start">

                        <Entry
    x:Name="TeamSearchEntry"
    Placeholder="ابحث عن فريق..."
    PlaceholderColor="#777777"
    TextColor="White"
    BackgroundColor="Transparent"
    TextChanged="OnTeamSearchTextChanged"/>

                    </Border>

                    <!-- الفرق -->

                    <CollectionView
    x:Name="TeamsCollection"
    Grid.Row="3"
    Margin="20,10"
    SelectionMode="None">

                        <CollectionView.ItemTemplate>

                            <DataTemplate>

                                <Border
                Margin="0,0,0,10"
                Padding="12"
                BackgroundColor="#111111"
                Stroke="#333333"
                StrokeShape="RoundRectangle 18">

                                    <Grid
                    ColumnDefinitions="55,*,40,40"
                    ColumnSpacing="6">
   
                                        <!-- الشعار -->

                                        <Image
                        Source="{Binding EmblemSource}"
                        WidthRequest="45"
                        HeightRequest="45"/>

                                        <!-- المعلومات -->

                                        <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="2">

                                            <Label
                            Text="{Binding TeamName}"
                            TextColor="Gold"
                            FontAttributes="Bold"
                            FontSize="18"/>

                                            <Label
                            Text="{Binding Player1}"
                            TextColor="White"
                            FontSize="14"/>
                                           
                                            <Label
                                                
 Text="{Binding Player2}"
 TextColor="White"
 FontSize="14"/>

                                        </VerticalStackLayout>

                                        <!-- تعديل -->

                                        <Image
                        Grid.Column="2"
                        Source="edit_card.png"
                        WidthRequest="26"
                        HeightRequest="26">

                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer
                                Tapped="OnEditTeamClicked"/>
                                            </Image.GestureRecognizers>

                                        </Image>

                                        <!-- حذف -->

                                        <Image
                        Grid.Column="3"
                        Source="delete_icon.png"
                        WidthRequest="26"
                        HeightRequest="26">

                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer
                                Tapped="OnDeleteTeamClicked"/>
                                            </Image.GestureRecognizers>

                                        </Image>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                    <Label
 x:Name="NoResultsLabel"
 Text="لا توجد نتائج مطابقة"
 TextColor="#888888"
 FontSize="18"
 HorizontalOptions="Center"
 Margin="0,20,0,0"
 IsVisible="False"/>

                    <!-- حذف الكل -->
               
                    <Border
            Grid.Row="4"
            Margin="20"
            Stroke="#AA0000"
            StrokeThickness="2"
            BackgroundColor="#111111"
            StrokeShape="RoundRectangle 18">

                        <Border.GestureRecognizers>

                            <TapGestureRecognizer
                    Tapped="OnDeleteAllTeamsClicked"/>

                        </Border.GestureRecognizers>

                        <HorizontalStackLayout
                Spacing="12"
                Padding="15"
                HorizontalOptions="Center">

                            <Image
                    Source="delete_icon.png"
                    WidthRequest="28"
                    HeightRequest="28"/>

                            <Label
                    Text="حذف جميع الفرق"
                    TextColor="#FF5555"
                    FontSize="18"
                    FontAttributes="Bold"/>
                            

                        </HorizontalStackLayout>

                    </Border>
                    

                </Grid>


            </Border>

        </Grid>
    </Grid>

</ContentPage>

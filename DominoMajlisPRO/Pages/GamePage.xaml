<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="DominoMajlisPRO.Pages.GamePage"
    BackgroundColor="#080808"
    FlowDirection="RightToLeft"
    Title="المباراة">
    <Grid>
    <ScrollView>

        <VerticalStackLayout
            Padding="8"
            Spacing="20">

            <!-- العودة -->
            <Grid ColumnDefinitions="Auto,*">
                

                <Button
                    
        x:Name="MenuButton"
        Text="☰"
        Clicked="OnMenuClicked"
        WidthRequest="50"
        HeightRequest="50"
        FontSize="22"
        BackgroundColor="#080808"
        BorderColor="Gold"
        BorderWidth="2"
        TextColor="Gold"
        CornerRadius="28" />

            </Grid>

            <!-- العنوان -->

            <VerticalStackLayout
                IsVisible="False"
                Margin="0,-20"
                HorizontalOptions="Center">

                <Label
                    
                  
                    Text="🎲 المباراة"
                  FontSize="18"
                    FontAttributes="Bold"
                    TextColor="Gold"
                    HorizontalOptions="Center"/>

                <Label
                    x:Name="RulesLabel"
                   FontSize="15"
                    TextColor="White"
                    HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <!-- WIN RATE -->

            <!-- بطاقة المباراة -->

                <Frame
    Margin="0,-10,0,0"
    BorderColor="#D4AF37"
    BackgroundColor="#080808"
    CornerRadius="24"
    Padding="12">

                    <Grid ColumnDefinitions="*,*,*">

                        <!-- الجولات -->

                        <VerticalStackLayout
            Spacing="2"
            HorizontalOptions="Center">

                            <Image
                Source="target_3d.png"
                HeightRequest="42"
                WidthRequest="42"/>

                            <Label
                Text="الجولات"
                FontSize="12"
                TextColor="#BBBBBB"
                HorizontalOptions="Center"/>

                            <Label
                x:Name="RoundsCountLabel"
                Text="0"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="#FFD700"
                HorizontalOptions="Center"/>

                        </VerticalStackLayout>

                        <!-- المتصدر -->

                        <VerticalStackLayout
            Grid.Column="1"
            Spacing="2"
            HorizontalOptions="Center">

                            <Image
                Source="trophy_3d.png"
                HeightRequest="42"
                WidthRequest="42"/>

                            <Label
                Text="المتصدر"
                FontSize="12"
                TextColor="#BBBBBB"
                HorizontalOptions="Center"/>

                            <Label
                x:Name="LeaderLabel"
                Text="-"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="#76FF03"
                HorizontalOptions="Center"
                LineBreakMode="TailTruncation"
                MaxLines="1"/>

                        </VerticalStackLayout>

                        <!-- الوقت -->

                        <VerticalStackLayout
            Grid.Column="2"
            Spacing="2"
            HorizontalOptions="Center">

                            <Image
                Source="clock_3d.png"
                HeightRequest="42"
                WidthRequest="42"/>

                            <Label
                Text="الوقت"
                FontSize="12"
                TextColor="#BBBBBB"
                HorizontalOptions="Center"/>

                            <Label
                x:Name="MatchTimeLabel"
                Text="00:00:00"
                FontSize="15"
                FontAttributes="Bold"
                TextColor="#00D9FF"
                HorizontalOptions="Center"/>

                        </VerticalStackLayout>

                    </Grid>

                </Frame>

                <!-- WIN RATE -->

            <Frame
                IsVisible="False"
    BorderColor="Gold"
    BackgroundColor="#080808"
    CornerRadius="20"
    Padding="15">

                <VerticalStackLayout
        Spacing="10">

                    <Label
            Text="📊 نسبة الفوز الحالية"
           FontSize="{OnIdiom Phone=14, Tablet=18}"
            FontAttributes="Bold"
            TextColor="Gold"
            HorizontalOptions="Center"/>

                    <Label
            x:Name="WinRateLabel"
            Text="50% - 50%"
           FontSize="{OnIdiom Phone=14, Tablet=18}"
            TextColor="White"
            HorizontalOptions="Center"/>

                    <ProgressBar
            x:Name="WinRateBar"
            Progress="0.5"
            HeightRequest="12"/>

                </VerticalStackLayout>

            </Frame>
            <!-- الفريق الأول -->
                <Frame
    Margin="0,-10"
    x:Name="ScoreBoardFrame"
    BorderColor="#D4AF37"
    BackgroundColor="#080808"
    CornerRadius="30"
    Padding="0"
    HasShadow="True">
                    <Grid
                    
        ColumnDefinitions="*,50,*"
        HeightRequest="320">

                    <!-- الفريق الأول -->

                        <VerticalStackLayout
                            
    x:Name="Team1Card"
                            Scale="1"
    Grid.Column="0"
    VerticalOptions="Center"
    HorizontalOptions="Center">


                            <Grid
    WidthRequest="90"
    HeightRequest="90">

                                <Image
        x:Name="Team1Emblem"
        WidthRequest="80"
        HeightRequest="80"
        HorizontalOptions="Center"
        VerticalOptions="Center"/>

                                <Image
                                                                        Margin="0,-5,-45,0"

        x:Name="Team1SpecialHonorIcon"
        Source="developer_gold.png"
        WidthRequest="45"
        HeightRequest="45"
        HorizontalOptions="End"
        VerticalOptions="Start"
        IsVisible="False"/>

                            </Grid>

                            <Label
                                
    x:Name="Team1Name"
    FontSize="22"
    FontAttributes="Bold"

    TextColor="Gold"
    HorizontalOptions="Center"
    HorizontalTextAlignment="Center"
    LineBreakMode="TailTruncation"
                                
    MaxLines="1"/>

                            <Label
                                
                                
    x:Name="Team1Players"
  FontSize="12"
    TextColor="#D0D0D0"
    HorizontalOptions="Center"
    HorizontalTextAlignment="Center"
    LineBreakMode="WordWrap"
    MaxLines="2"/>
                            <Label
                         
    x:Name="Team1FloatingScore"
    Text=""
    FontSize="25"
    FontAttributes="Bold"
    TextColor="#76FF03"
    Opacity="0"
    HorizontalOptions="Center"/>

                            <HorizontalStackLayout
    HorizontalOptions="Center"
    Spacing="5">

                          

                                <Label
        x:Name="Team1Score"
        Text="0"
        FontSize="75"
        FontAttributes="Bold"
        TextColor="Gold"
        HorizontalOptions="Center"/>

                            </HorizontalStackLayout>

                            <Label
                Text="الهدف 151"
              FontSize="12"
                           FontAttributes="Bold"   
                TextColor="#E8E8E8"
                HorizontalOptions="Center"/>
                      


                    </VerticalStackLayout>

                    <!-- VS -->

                        <Grid
    Grid.Column="1"
    VerticalOptions="FillAndExpand">

                            <!-- الخط العمودي -->
                            <BoxView
        WidthRequest="2.5"
        Color="Gold"
        Opacity="0.5"
        HorizontalOptions="Center"
        VerticalOptions="FillAndExpand"/>

                            <!-- دائرة VS -->
                            <Frame
        BorderColor="Gold"
        BackgroundColor="#080808"
        CornerRadius="50"
        WidthRequest="75"
        HeightRequest="75"
        Padding="0"
        HasShadow="True"
        HorizontalOptions="Center"
        VerticalOptions="Center">

                                <Image
    Grid.Column="1"
    Source="vs_gold_icon.png"
    WidthRequest="75"
    HeightRequest="75"
    VerticalOptions="Center"
    HorizontalOptions="Center"
    Aspect="AspectFit"/>


                            </Frame>

                        </Grid>
                        <!-- الفريق الثاني -->

                        <VerticalStackLayout
    x:Name="Team2Card"
                            Scale="1"
    Grid.Column="2"
    VerticalOptions="Center"
    HorizontalOptions="Center">


                            <Grid
    WidthRequest="90"
    HeightRequest="90">

                                <Image
        x:Name="Team2Emblem"
        WidthRequest="80"
        HeightRequest="80"
        HorizontalOptions="Center"
        VerticalOptions="Center"/>

                                <Image
                                                                        Margin="0,-5,-30,0"
        x:Name="Team2SpecialHonorIcon"
        Source="developer_gold.png"
        WidthRequest="28"
        HeightRequest="28"
        HorizontalOptions="End"
        VerticalOptions="Start"
        IsVisible="False"/>

                            </Grid>

                            <Label
                              
    x:Name="Team2Name"
    FontSize="22"
    FontAttributes="Bold"
    TextColor="Gold"
    HorizontalOptions="Center"
    HorizontalTextAlignment="Center"
    LineBreakMode="TailTruncation"
    MaxLines="1"/>

                            <Label
    x:Name="Team2Players"
   FontSize="12"
    TextColor="#D0D0D0"
    HorizontalOptions="Center"
    HorizontalTextAlignment="Center"
    LineBreakMode="WordWrap"
    MaxLines="2"/>
                            <Label
    x:Name="Team2FloatingScore"
    Text=""
    FontSize="25"
    FontAttributes="Bold"
    TextColor="#3D5AFE"
    Opacity="0"
    HorizontalOptions="Center"/>

                            <HorizontalStackLayout
    HorizontalOptions="Center"
    Spacing="5">

                            

                                <Label
        x:Name="Team2Score"
        Text="0"
        FontSize="75"
        FontAttributes="Bold"
        TextColor="Gold"
        HorizontalOptions="Center"/>

                            </HorizontalStackLayout>

                            <Label
                Text="الهدف 151"
            FontSize="12"
                            FontAttributes="Bold"    
                TextColor="#E8E8E8"
                HorizontalOptions="Center"/>
                   

                    </VerticalStackLayout>

                </Grid>

            </Frame>


            <!-- ACTIVE TEAM -->



            <!-- KEYPAD -->

            <Frame
    BorderColor="#D4AF37"
    BackgroundColor="#080808"
    CornerRadius="18"
    Padding="10">

                <VerticalStackLayout Spacing="6">

                    <Label
            x:Name="KeypadDisplay"
            Text="0"
            FontSize="36"
            TextColor="Gold"
            HorizontalOptions="Center"/>

                    <Grid
                        FlowDirection="LeftToRight"
    ColumnDefinitions="*,*,*"
    RowDefinitions="Auto,Auto,Auto,Auto"
    ColumnSpacing="5"
    RowSpacing="5">

                        <!-- الصف الأول -->

                        <Button
    Text="1"
    Grid.Row="0"
    Grid.Column="0"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>

                        <Button
    Text="2"
    Grid.Row="0"
    Grid.Column="1"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                        <Button
    Text="3"
    Grid.Row="0"
    Grid.Column="2"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                     
                        <!-- الصف الثاني -->
                        <Button
    Text="4"
    Grid.Row="1"
    Grid.Column="0"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                        <Button
    Text="5"
    Grid.Row="1"
    Grid.Column="1"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                        <Button
    Text="6"
    Grid.Row="1"
    Grid.Column="2"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                        

                        <!-- الصف الثالث -->
                        <Button
    Text="7"
    Grid.Row="2"
    Grid.Column="0"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                        <Button
    Text="8"
    Grid.Row="2"
    Grid.Column="1"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                        <Button
    Text="9"
    Grid.Row="2"
    Grid.Column="2"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
              

                        <!-- الصف الرابع -->
                        <Button
    Text="0"
    Grid.Row="3"
    Grid.Column="0"
    Clicked="OnKeypadClicked"
    BackgroundColor="#101010"
    TextColor="White"
    BorderColor="#2A2A2A"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="28"
    FontAttributes="Bold"/>
                        <Button
    Text="حذف"
    Grid.Row="3"
    Grid.Column="1"
    Clicked="OnDeleteDigitClicked"
    BackgroundColor="#080808"
    TextColor="#D4AF37"
    BorderColor="#D4AF37"
    BorderWidth="1"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="24"
    FontAttributes="Bold"/>
                        <Button
    Text="مسح"
    Grid.Row="3"
    Grid.Column="2"
    Clicked="OnClearKeypadClicked"
    BackgroundColor="#D4AF37"
    TextColor="Black"
    CornerRadius="15"
    HeightRequest="50"
    FontSize="24"
    FontAttributes="Bold"/>


                    </Grid>

                </VerticalStackLayout>

            </Frame>
           

            <!-- الأزرار -->

            <Frame
                IsVisible="False"
    BackgroundColor="#080808"
    BorderColor="Gold"
    CornerRadius="18"
    Padding="15">

                <Grid
        ColumnDefinitions="80,*,120"
        RowDefinitions="Auto,Auto">

                    <!-- العنوان -->

                    <Label
            Grid.Row="0"
            Grid.ColumnSpan="3"
            Text="آخر جولة"
           FontSize="{OnIdiom Phone=14, Tablet=18}"
            FontAttributes="Bold"
            TextColor="Gold"
            HorizontalOptions="Center"/>

                    <!-- النقاط -->

                 
                        
           <Label
    x:Name="LastRoundPointsLabel"
    Grid.Row="1"
    Grid.Column="0"
    FontSize="25"
    FontAttributes="Bold"
    TextColor="Lime"
    HorizontalTextAlignment="Center"
    LineBreakMode="NoWrap"
    MaxLines="1"/>


                        <Label
    x:Name="LastRoundTeamLabel"
    Grid.Row="1"
    Grid.Column="1"
   FontSize="{OnIdiom Phone=14, Tablet=18}"
    FontAttributes="Bold"
    TextColor="White"
    HorizontalTextAlignment="Center"
    LineBreakMode="NoWrap"
    MaxLines="1"/>
                        <!-- اسم الفريق -->

                    

                    <!-- الوقت -->

                    <Label
            x:Name="LastRoundTimeLabel"
            Grid.Row="1"
            Grid.Column="2"
           FontSize="{OnIdiom Phone=14, Tablet=18}"
            TextColor="Gray"
            HorizontalTextAlignment="Center"/>
                </Grid>

            </Frame>


            <!-- سجل الجولات -->

            <Label
                Text="سجل الجولات"
               FontSize="{OnIdiom Phone=14, Tablet=18}"
                FontAttributes="Bold"
                TextColor="Gold"
                HorizontalOptions="Center"/>
                <Button
    x:Name="ToggleRoundsButton"
    Text="عرض المزيد ▼"
    Clicked="OnToggleRoundsClicked"
    BackgroundColor="#151515"
    BorderColor="Gold"
    BorderWidth="1"
    TextColor="Gold"
    CornerRadius="15"
    IsVisible="False"/>

                <VerticalStackLayout
                x:Name="RoundsContainer"
                Spacing="10"/>

        </VerticalStackLayout>

    </ScrollView>
    <!-- SIDE MENU OVERLAY -->

    <Grid
    x:Name="SideMenuOverlay"
    IsVisible="False"
    BackgroundColor="#80000000"
    ZIndex="999">

        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="CloseMenuClicked"/>
        </Grid.GestureRecognizers>
            <Border
    x:Name="SideMenuPanel"
    WidthRequest="280"
    HorizontalOptions="Start"
    VerticalOptions="Fill"
    TranslationX="-280"
    FlowDirection="LeftToRight"
    BackgroundColor="#151515"
    Stroke="Gold"
    StrokeThickness="2"
    Padding="20">

                <VerticalStackLayout Spacing="20">

                <Label
    Text="⚙ إدارة المباراة"
    FontSize="28"
    FontAttributes="Bold"
    TextColor="Gold"
    HorizontalOptions="Center"/>

                <BoxView HeightRequest="1" Color="#D4AF37"/>

                <Button
    Text="↩ تراجع آخر جولة"
    Clicked="OnUndoClicked"
    BackgroundColor="#111111"
    TextColor="White"
    BorderColor="#D4AF37"
    BorderWidth="1"
    CornerRadius="15"/>

                <Button
    Text="🔄 مباراة جديدة"
    Clicked="OnResetClicked"
    BackgroundColor="#111111"
    TextColor="White"
    BorderColor="#D4AF37"
    BorderWidth="1"
    CornerRadius="15"/>

                <Button
    Text="🏆 إنهاء المباراة"
    Clicked="OnFinishClicked"
    BackgroundColor="#111111"
    TextColor="#76FF03"
    BorderColor="#76FF03"
    BorderWidth="1"
    CornerRadius="15"/>

                <Button
    Text="⬅ العودة"
    Clicked="OnBackClicked"
    BackgroundColor="#111111"
    TextColor="#FF6B6B"
    BorderColor="#FF6B6B"
    BorderWidth="1"
    CornerRadius="15"/>

            </VerticalStackLayout>

        </Border>

    </Grid>
</Grid>
</ContentPage>
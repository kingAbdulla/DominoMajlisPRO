<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:galleryComponents="clr-namespace:DominoMajlisPRO.GalleryEngine.Components"
    x:Class="DominoMajlisPRO.Pages.GamePage"
    BackgroundColor="#050706"
    FlowDirection="RightToLeft"
    Title="المباراة">

    <ContentPage.Resources>
        <Style x:Key="HeaderShell" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#080B0A" />
            <Setter Property="Stroke" Value="#D4A62C" />
            <Setter Property="StrokeThickness" Value="1.2" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        </Style>
        <Style x:Key="KeyButton" TargetType="Button">
            <Setter Property="HeightRequest" Value="42" />
            <Setter Property="MinimumHeightRequest" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BackgroundColor" Value="#0A0D0C" />
            <Setter Property="BorderColor" Value="#A36F16" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="TextColor" Value="#F4DFC2" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="{OnIdiom Phone='5,5,5,4', Tablet='10'}" RowSpacing="7">
        <Grid Grid.Row="0" ColumnDefinitions="42,*,42" ColumnSpacing="4" FlowDirection="LeftToRight" HeightRequest="54">
            <Border WidthRequest="42" HeightRequest="48" BackgroundColor="Transparent" Stroke="Transparent" StrokeThickness="0" Padding="0" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <Image Source="back_gold.png" WidthRequest="28" HeightRequest="28" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Grid Grid.Column="1" ColumnDefinitions="1.12*,0.9*,1.08*" ColumnSpacing="0" HorizontalOptions="Fill" VerticalOptions="Fill" FlowDirection="RightToLeft">
                <Border Grid.Column="0" Style="{StaticResource HeaderShell}" StrokeShape="RoundRectangle 0,22,22,0" Padding="5,4">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="1" HorizontalOptions="Fill" VerticalOptions="Center">
                        <Label Text="حالة المباراة" TextColor="#F5DEB3" FontSize="11" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="NoWrap" />
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="4" HorizontalOptions="Center">
                            <Label x:Name="MatchStatusLabel" Text="جارية" TextColor="#76FF03" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="NoWrap" VerticalTextAlignment="Center" />
                            <BoxView Grid.Column="1" WidthRequest="7" HeightRequest="7" CornerRadius="4" Color="#76FF03" VerticalOptions="Center" />
                        </Grid>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Margin="-3,0" Padding="5,4" BackgroundColor="#10100B" Stroke="#E1B33A" StrokeThickness="1.4" StrokeShape="RoundRectangle 0,0,20,20" ZIndex="2">
                    <VerticalStackLayout Spacing="0" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="الجولة" TextColor="#F5DEB3" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                        <Label x:Name="RoundsCountLabel" Text="0" TextColor="#FFF1D0" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource HeaderShell}" StrokeShape="RoundRectangle 22,0,0,22" Padding="5,4">
                    <Grid ColumnDefinitions="20,*" ColumnSpacing="2" FlowDirection="LeftToRight" VerticalOptions="Center">
                        <Image Source="clock_3d.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Label Text="الوقت" TextColor="#F5DEB3" FontSize="11" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                            <Label x:Name="MatchTimeLabel" Text="00:00" TextColor="#FFD447" FontSize="11" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="NoWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>
            <Button x:Name="MenuButton" Grid.Column="2" Text="☰" Clicked="OnMenuClicked" WidthRequest="42" HeightRequest="48" FontSize="21" Padding="0" BackgroundColor="#080B0A" BorderColor="#D4A62C" BorderWidth="1.2" TextColor="#FFD447" CornerRadius="14" />
        </Grid>

        <Label x:Name="RulesLabel" Grid.Row="0" IsVisible="False" />

        <Grid Grid.Row="1" ColumnDefinitions="*,44,*" ColumnSpacing="0" HeightRequest="{OnIdiom Phone=248, Tablet=360}" FlowDirection="LeftToRight">
            <Border x:Name="Team1Card" Grid.Column="0" Padding="6" BackgroundColor="#100815" Stroke="#C95DFF" StrokeThickness="1.4" StrokeShape="RoundRectangle 16" HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid RowDefinitions="62,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="1">
                    <Image x:Name="Team1BackgroundImage" Grid.RowSpan="7" Aspect="AspectFill" Opacity="0.20" />
                    <BoxView Grid.RowSpan="7" Opacity="0.70">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#18101D" Offset="0" />
                                <GradientStop Color="#050506" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <Image x:Name="Team1Emblem" Grid.Row="0" WidthRequest="{OnIdiom Phone=64, Tablet=116}" HeightRequest="{OnIdiom Phone=64, Tablet=116}" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" ZIndex="1" />
                    <Grid Grid.Row="1" HeightRequest="{OnIdiom Phone=30, Tablet=44}" ZIndex="1">
                        <Label x:Name="Team1Name" FontSize="{OnIdiom Phone=17, Tablet=30}" FontAttributes="Bold" TextColor="#F3E8DD" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                        <galleryComponents:RuntimeNamePlateView x:Name="Team1NamePlate" RenderingContext="GamePage" OwnerKind="Team" IsVisible="False"/>
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="2" HeightRequest="24" ZIndex="1">
                        <Label x:Name="Team1Players" Grid.ColumnSpan="2" IsVisible="False"/>
                        <galleryComponents:RuntimeNamePlateView x:Name="Team1Player1NamePlate" RenderingContext="GamePage" Grid.Column="0" OwnerKind="Player" HeightRequest="24"/>
                        <galleryComponents:RuntimeNamePlateView x:Name="Team1Player2NamePlate" RenderingContext="GamePage" Grid.Column="1" OwnerKind="Player" HeightRequest="24"/>
                    </Grid>
                    <Border Grid.Row="3" Padding="7,1" Margin="0,1" HorizontalOptions="Center" BackgroundColor="#221128" Stroke="#8E36B9" StrokeThickness="1" StrokeShape="RoundRectangle 7" ZIndex="1">
                        <Label x:Name="Team1RankNameLabel" Text="مقدم" TextColor="#F8EAFB" FontSize="9" FontAttributes="Bold" MaxLines="1" LineBreakMode="TailTruncation" />
                    </Border>
                    <Label x:Name="Team1Score" Grid.Row="4" Text="0" FontSize="{OnIdiom Phone=34, Tablet=62}" FontAttributes="Bold" TextColor="#C95DFF" HorizontalTextAlignment="Center" VerticalOptions="Center" MaxLines="1" ZIndex="1" />
                    <Grid Grid.Row="5" RowDefinitions="Auto,Auto" RowSpacing="0" ZIndex="1">
                        <Label x:Name="Team1TargetLabel" Text="الهدف: 151" TextColor="#FFD447" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                        <Label x:Name="Team1XpLabel" Grid.Row="1" Text="0 / 100 XP" TextColor="#FFD447" FontSize="9" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation" />
                    </Grid>
                    <Grid Grid.Row="6" ColumnDefinitions="26,*,26" ColumnSpacing="2" Padding="0,2,0,2" ZIndex="1" VerticalOptions="End">
                        <VerticalStackLayout Spacing="0" WidthRequest="26">
                            <Image x:Name="Team1CurrentRankIcon" Source="unranked.png" WidthRequest="23" HeightRequest="23" />
                            <Label x:Name="Team1CurrentRankLabel" Text="I" FontSize="8" TextColor="#EDE0C2" HorizontalTextAlignment="Center" MaxLines="1" />
                        </VerticalStackLayout>
                        <Grid Grid.Column="1" HeightRequest="18" VerticalOptions="Center">
                            <Border x:Name="Team1RankProgressTrack" HeightRequest="12" BackgroundColor="#211327" Stroke="#6E3A82" StrokeThickness="1" StrokeShape="RoundRectangle 7" VerticalOptions="Center">
                                <Grid>
                                    <BoxView x:Name="Team1RankProgressFill" BackgroundColor="#C95DFF" HorizontalOptions="Fill" VerticalOptions="Fill" ScaleX="0" AnchorX="0" />
                                    <BoxView Opacity="0.28" HeightRequest="3" VerticalOptions="Start" BackgroundColor="#FFFFFFFF" />
                                </Grid>
                            </Border>
                            <Label x:Name="Team1RankPercentLabel" Text="0%" TextColor="White" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" MaxLines="1" />
                        </Grid>
                        <VerticalStackLayout Grid.Column="2" Spacing="0" WidthRequest="26">
                            <Image x:Name="Team1NextRankIcon" Source="unranked.png" WidthRequest="23" HeightRequest="23" />
                            <Label x:Name="Team1NextRankLabel" Text="II" FontSize="8" TextColor="#EDE0C2" HorizontalTextAlignment="Center" MaxLines="1" />
                        </VerticalStackLayout>
                    </Grid>
                    <Label x:Name="Team1FloatingScore" Grid.RowSpan="7" Text="" FontSize="22" FontAttributes="Bold" TextColor="#C95DFF" Opacity="0" HorizontalOptions="Center" VerticalOptions="Center" ZIndex="5" />
                    <Image x:Name="Team1SpecialHonorIcon" IsVisible="False" Opacity="0" />
                </Grid>
            </Border>

            <Grid Grid.Column="1" WidthRequest="44" VerticalOptions="Fill" ZIndex="3">
                <BoxView WidthRequest="2" Color="#D4A62C" Opacity="0.55" HorizontalOptions="Center" VerticalOptions="Fill" />
                <Image Source="vs_gold_icon.png" WidthRequest="50" HeightRequest="50" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <Border x:Name="Team2Card" Grid.Column="2" Padding="6" BackgroundColor="#081708" Stroke="#A4FF45" StrokeThickness="1.4" StrokeShape="RoundRectangle 16" HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid RowDefinitions="62,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="1">
                    <Image x:Name="Team2BackgroundImage" Grid.RowSpan="7" Aspect="AspectFill" Opacity="0.20" />
                    <BoxView Grid.RowSpan="7" Opacity="0.70">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                                <GradientStop Color="#101B10" Offset="0" />
                                <GradientStop Color="#050506" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <Image x:Name="Team2Emblem" Grid.Row="0" WidthRequest="{OnIdiom Phone=64, Tablet=116}" HeightRequest="{OnIdiom Phone=64, Tablet=116}" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" ZIndex="1" />
                    <Grid Grid.Row="1" HeightRequest="{OnIdiom Phone=30, Tablet=44}" ZIndex="1">
                        <Label x:Name="Team2Name" FontSize="{OnIdiom Phone=17, Tablet=30}" FontAttributes="Bold" TextColor="#F3E8DD" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                        <galleryComponents:RuntimeNamePlateView x:Name="Team2NamePlate" RenderingContext="GamePage" OwnerKind="Team" IsVisible="False"/>
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="2" HeightRequest="24" ZIndex="1">
                        <Label x:Name="Team2Players" Grid.ColumnSpan="2" IsVisible="False"/>
                        <galleryComponents:RuntimeNamePlateView x:Name="Team2Player1NamePlate" RenderingContext="GamePage" Grid.Column="0" OwnerKind="Player" HeightRequest="24"/>
                        <galleryComponents:RuntimeNamePlateView x:Name="Team2Player2NamePlate" RenderingContext="GamePage" Grid.Column="1" OwnerKind="Player" HeightRequest="24"/>
                    </Grid>
                    <Border Grid.Row="3" Padding="7,1" Margin="0,1" HorizontalOptions="Center" BackgroundColor="#122510" Stroke="#63AB32" StrokeThickness="1" StrokeShape="RoundRectangle 7" ZIndex="1">
                        <Label x:Name="Team2RankNameLabel" Text="مقدم" TextColor="#F8FFF0" FontSize="9" FontAttributes="Bold" MaxLines="1" LineBreakMode="TailTruncation" />
                    </Border>
                    <Label x:Name="Team2Score" Grid.Row="4" Text="0" FontSize="{OnIdiom Phone=34, Tablet=62}" FontAttributes="Bold" TextColor="#A4FF45" HorizontalTextAlignment="Center" VerticalOptions="Center" MaxLines="1" ZIndex="1" />
                    <Grid Grid.Row="5" RowDefinitions="Auto,Auto" RowSpacing="0" ZIndex="1">
                        <Label x:Name="Team2TargetLabel" Text="الهدف: 151" TextColor="#FFD447" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                        <Label x:Name="Team2XpLabel" Grid.Row="1" Text="0 / 100 XP" TextColor="#FFD447" FontSize="9" HorizontalTextAlignment="Center" MaxLines="1" LineBreakMode="TailTruncation" />
                    </Grid>
                    <Grid Grid.Row="6" ColumnDefinitions="26,*,26" ColumnSpacing="2" Padding="0,2,0,2" ZIndex="1" VerticalOptions="End">
                        <VerticalStackLayout Spacing="0" WidthRequest="26">
                            <Image x:Name="Team2CurrentRankIcon" Source="unranked.png" WidthRequest="23" HeightRequest="23" />
                            <Label x:Name="Team2CurrentRankLabel" Text="I" FontSize="8" TextColor="#EDE0C2" HorizontalTextAlignment="Center" MaxLines="1" />
                        </VerticalStackLayout>
                        <Grid Grid.Column="1" HeightRequest="18" VerticalOptions="Center">
                            <Border x:Name="Team2RankProgressTrack" HeightRequest="12" BackgroundColor="#14210F" Stroke="#5D8D2E" StrokeThickness="1" StrokeShape="RoundRectangle 7" VerticalOptions="Center">
                                <Grid>
                                    <BoxView x:Name="Team2RankProgressFill" BackgroundColor="#A4FF45" HorizontalOptions="Fill" VerticalOptions="Fill" ScaleX="0" AnchorX="0" />
                                    <BoxView Opacity="0.28" HeightRequest="3" VerticalOptions="Start" BackgroundColor="#FFFFFFFF" />
                                </Grid>
                            </Border>
                            <Label x:Name="Team2RankPercentLabel" Text="0%" TextColor="White" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" MaxLines="1" />
                        </Grid>
                        <VerticalStackLayout Grid.Column="2" Spacing="0" WidthRequest="26">
                            <Image x:Name="Team2NextRankIcon" Source="unranked.png" WidthRequest="23" HeightRequest="23" />
                            <Label x:Name="Team2NextRankLabel" Text="II" FontSize="8" TextColor="#EDE0C2" HorizontalTextAlignment="Center" MaxLines="1" />
                        </VerticalStackLayout>
                    </Grid>
                    <Label x:Name="Team2FloatingScore" Grid.RowSpan="7" Text="" FontSize="22" FontAttributes="Bold" TextColor="#A4FF45" Opacity="0" HorizontalOptions="Center" VerticalOptions="Center" ZIndex="5" />
                    <Image x:Name="Team2SpecialHonorIcon" IsVisible="False" Opacity="0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="8,6" BackgroundColor="#090B0A" Stroke="#D4A62C" StrokeThickness="1.2" StrokeShape="RoundRectangle 16">
            <Grid RowDefinitions="Auto,*" RowSpacing="5">
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="6">
                    <BoxView HeightRequest="1" Color="#5D4517" VerticalOptions="Center" />
                    <Border Grid.Column="1" Padding="18,2" MinimumWidthRequest="100" BackgroundColor="#11120E" Stroke="#D4A62C" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <Label x:Name="KeypadDisplay" Text="0" FontSize="21" FontAttributes="Bold" TextColor="#FFF1D0" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" MaxLines="1" LineBreakMode="NoWrap" />
                    </Border>
                    <Label Grid.Column="2" Text="النقاط" TextColor="#FFD447" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="End" VerticalTextAlignment="Center" MaxLines="1" />
                </Grid>
                <Grid Grid.Row="1" FlowDirection="LeftToRight" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="5" RowSpacing="4">
                    <Button Text="1" Grid.Row="0" Grid.Column="0" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="2" Grid.Row="0" Grid.Column="1" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="3" Grid.Row="0" Grid.Column="2" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="4" Grid.Row="1" Grid.Column="0" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="5" Grid.Row="1" Grid.Column="1" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="6" Grid.Row="1" Grid.Column="2" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="7" Grid.Row="2" Grid.Column="0" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="8" Grid.Row="2" Grid.Column="1" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="9" Grid.Row="2" Grid.Column="2" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="✖" Grid.Row="3" Grid.Column="0" Clicked="OnClearKeypadClicked" BackgroundColor="#210E0B" BorderColor="#B84325" BorderWidth="1" CornerRadius="9" TextColor="#FF6B56" HeightRequest="42" MinimumHeightRequest="42" Padding="0" FontSize="23" FontAttributes="Bold" />
                    <Button Text="0" Grid.Row="3" Grid.Column="1" Clicked="OnKeypadClicked" Style="{StaticResource KeyButton}" />
                    <Button Text="مسح" Grid.Row="3" Grid.Column="2" Clicked="OnDeleteDigitClicked" BackgroundColor="#D8A51F" TextColor="#221400" CornerRadius="9" HeightRequest="42" MinimumHeightRequest="42" Padding="0" FontSize="17" FontAttributes="Bold" />
                </Grid>
            </Grid>
        </Border>

        <ScrollView Grid.Row="3" VerticalScrollBarVisibility="Default">
            <VerticalStackLayout Spacing="8" Padding="0,1,0,10">
                <Border BackgroundColor="#080B0A" Stroke="#A36F16" StrokeThickness="1.1" StrokeShape="RoundRectangle 16" Padding="8">
                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="42,*,42" ColumnSpacing="6" FlowDirection="LeftToRight">
                            <Button Text="⌃" WidthRequest="42" HeightRequest="36" Padding="0" BackgroundColor="#111" BorderColor="#A36F16" BorderWidth="1" TextColor="#FFD447" CornerRadius="8" Clicked="OnToggleRoundsClicked" />
                            <Label Grid.Column="1" Text="سجل الجولات" TextColor="#FFD447" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" MaxLines="1" />
                            <Button Grid.Column="2" Text="⌄" WidthRequest="42" HeightRequest="36" Padding="0" BackgroundColor="#111" BorderColor="#A36F16" BorderWidth="1" TextColor="#FFD447" CornerRadius="8" Clicked="OnToggleRoundsClicked" />
                        </Grid>
                        <Grid ColumnDefinitions="1.1*,1.1*,1.7*,1.7*,118" Padding="4,6" BackgroundColor="#101210" ColumnSpacing="4">
                            <Label Text="الجولة" TextColor="#FFD447" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                            <Label Grid.Column="1" Text="الوقت" TextColor="#FFD447" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                            <Label Grid.Column="2" Text="الفائز" TextColor="#FFD447" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                            <Label Grid.Column="3" Text="النقاط" TextColor="#FFD447" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                            <Label Grid.Column="4" Text="الإجراءات" TextColor="#FFD447" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="1" />
                        </Grid>
                        <VerticalStackLayout x:Name="RoundsContainer" Spacing="0" />
                        <Button x:Name="ToggleRoundsButton" Text="إظهار المزيد ⌄" Clicked="OnToggleRoundsClicked" BackgroundColor="#101010" BorderColor="#A36F16" BorderWidth="1" TextColor="#FFD447" CornerRadius="10" HeightRequest="38" IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,0,0,4">
                    <Border Padding="9,6" BackgroundColor="#0A0D0C" Stroke="#8A641F" StrokeThickness="1" StrokeShape="RoundRectangle 15">
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="7" FlowDirection="LeftToRight">
                            <Image Source="coins.png" WidthRequest="36" HeightRequest="36" />
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="العملات" TextColor="#F4DFC2" FontSize="11" MaxLines="1" />
                                <Label x:Name="MatchCoinsLabel" Text="0" TextColor="#FFD447" FontSize="18" FontAttributes="Bold" MaxLines="1" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Padding="9,6" BackgroundColor="#0A0D0C" Stroke="#8A641F" StrokeThickness="1" StrokeShape="RoundRectangle 15">
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="7" FlowDirection="LeftToRight">
                            <Image Source="trust_gold.png" WidthRequest="36" HeightRequest="36" />
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="ثقة الفريق" TextColor="#F4DFC2" FontSize="11" MaxLines="1" />
                                <Label x:Name="TeamTrustLabel" Text="96 %" TextColor="#F4DFC2" FontSize="18" FontAttributes="Bold" MaxLines="1" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </Grid>

                <Grid IsVisible="False">
                    <Label x:Name="WinRateLabel" />
                    <ProgressBar x:Name="WinRateBar" />
                    <Label x:Name="LeaderLabel" />
                    <Label x:Name="LastRoundPointsLabel" />
                    <Label x:Name="LastRoundTeamLabel" />
                    <Label x:Name="LastRoundTimeLabel" />
                    <Frame x:Name="ScoreBoardFrame" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="SideMenuOverlay" Grid.RowSpan="4" IsVisible="False" BackgroundColor="#80000000" ZIndex="999">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="CloseMenuClicked" />
            </Grid.GestureRecognizers>
            <Border x:Name="SideMenuPanel" WidthRequest="280" HorizontalOptions="Start" VerticalOptions="Fill" TranslationX="-280" FlowDirection="LeftToRight" BackgroundColor="#151515" Stroke="Gold" StrokeThickness="2" Padding="20">
                <VerticalStackLayout Spacing="20">
                    <Label Text="إدارة المباراة" FontSize="28" FontAttributes="Bold" TextColor="Gold" HorizontalOptions="Center" MaxLines="1" />
                    <BoxView HeightRequest="1" Color="#D4AF37" />
                    <Button Text="↩ تراجع آخر جولة" Clicked="OnUndoClicked" BackgroundColor="#111111" TextColor="White" BorderColor="#D4AF37" BorderWidth="1" CornerRadius="15" />
                    <Button Text="مباراة جديدة" Clicked="OnResetClicked" BackgroundColor="#111111" TextColor="White" BorderColor="#D4AF37" BorderWidth="1" CornerRadius="15" />
                    <Button Text="إنهاء المباراة" Clicked="OnFinishClicked" BackgroundColor="#111111" TextColor="#76FF03" BorderColor="#76FF03" BorderWidth="1" CornerRadius="15" />
                    <Button Text="العودة" Clicked="OnBackClicked" BackgroundColor="#111111" TextColor="#FF6B6B" BorderColor="#FF6B6B" BorderWidth="1" CornerRadius="15" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="MatchDialogOverlay" Grid.RowSpan="4" IsVisible="False" BackgroundColor="#CC000000" ZIndex="1000" Padding="18">
            <Border x:Name="MatchDialogCard" HorizontalOptions="Center" VerticalOptions="Center" MaximumWidthRequest="420" Padding="18" BackgroundColor="#080B0A" Stroke="#D4A62C" StrokeThickness="1.4" StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="12">
                    <Image x:Name="MatchDialogIcon" Source="trophy_3d.png" WidthRequest="74" HeightRequest="74" HorizontalOptions="Center" />
                    <Label x:Name="MatchDialogTitle" Text="انتهت المباراة" TextColor="#FFD447" FontSize="26" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="WordWrap" />
                    <Label x:Name="MatchDialogMessage" TextColor="#F8EAD0" FontSize="16" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                    <Border x:Name="MatchDialogRewardCard" Padding="12,8" BackgroundColor="#11120E" Stroke="#8A641F" StrokeThickness="1" StrokeShape="RoundRectangle 16">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" FlowDirection="LeftToRight">
                            <Image Source="coins.png" WidthRequest="42" HeightRequest="42" />
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="مكافأة الفوز" TextColor="#F4DFC2" FontSize="12" MaxLines="1" />
                                <Label x:Name="MatchDialogRewardLabel" Text="+0 coins" TextColor="#FFD447" FontSize="22" FontAttributes="Bold" MaxLines="1" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button x:Name="MatchDialogSecondaryButton" Text="الخروج" Clicked="OnDialogSecondaryClicked" BackgroundColor="#111111" BorderColor="#8A641F" BorderWidth="1" TextColor="#F8EAD0" CornerRadius="14" HeightRequest="50" />

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="DominoMajlisPRO.Pages.GamePage"
    BackgroundColor="#080808"
    FlowDirection="RightToLeft"
    Title="المباراة"
    Loaded="OnGamePagePremiumLoaded">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="8" Spacing="10">

                <Grid ColumnDefinitions="Auto,*" HeightRequest="46">
                    <Button
                        x:Name="MenuButton"
                        Text="☰"
                        Clicked="OnMenuClicked"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="20"
                        BackgroundColor="#101010"
                        BorderColor="#D4AF37"
                        BorderWidth="1"
                        TextColor="#D4AF37"
                        CornerRadius="22" />
                </Grid>

                <VerticalStackLayout IsVisible="False" Margin="0,-20" HorizontalOptions="Center">
                    <Label Text="🎲 المباراة" FontSize="18" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                    <Label x:Name="RulesLabel" FontSize="15" TextColor="White" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <Frame
                    Margin="0,-4,0,0"
                    BorderColor="#8A5B27"
                    BackgroundColor="#0B0B0B"
                    CornerRadius="22"
                    Padding="10"
                    HasShadow="False">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                            <Image Source="target_3d.png" HeightRequest="32" WidthRequest="32"/>
                            <Label Text="الجولات" FontSize="11" TextColor="#AFAFAF" HorizontalOptions="Center"/>
                            <Label x:Name="RoundsCountLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="1" HorizontalOptions="Center">
                            <Image Source="trophy_3d.png" HeightRequest="32" WidthRequest="32"/>
                            <Label Text="المتصدر" FontSize="11" TextColor="#AFAFAF" HorizontalOptions="Center"/>
                            <Label x:Name="LeaderLabel" Text="-" FontSize="15" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="1" HorizontalOptions="Center">
                            <Image Source="clock_3d.png" HeightRequest="32" WidthRequest="32"/>
                            <Label Text="الوقت" FontSize="11" TextColor="#AFAFAF" HorizontalOptions="Center"/>
                            <Label x:Name="MatchTimeLabel" Text="00:00:00" FontSize="13" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <Frame IsVisible="False" BorderColor="#D4AF37" BackgroundColor="#080808" CornerRadius="20" Padding="15" HasShadow="False">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📊 نسبة الفوز الحالية" FontSize="{OnIdiom Phone=14, Tablet=18}" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                        <Label x:Name="WinRateLabel" Text="50% - 50%" FontSize="{OnIdiom Phone=14, Tablet=18}" TextColor="White" HorizontalOptions="Center"/>
                        <ProgressBar x:Name="WinRateBar" Progress="0.5" HeightRequest="12"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Margin="0,-2,0,0"
                    x:Name="ScoreBoardFrame"
                    BorderColor="#D4AF37"
                    BackgroundColor="#080808"
                    CornerRadius="28"
                    Padding="8"
                    HasShadow="False">
                    <Grid ColumnDefinitions="*,44,*" HeightRequest="{OnIdiom Phone=286, Tablet=330, Desktop=330}">

                        <VerticalStackLayout x:Name="Team1Card" Grid.Column="0" Spacing="3" VerticalOptions="Center" HorizontalOptions="Fill">
                            <Grid WidthRequest="82" HeightRequest="82" HorizontalOptions="Center">
                                <Image x:Name="Team1Emblem" WidthRequest="76" HeightRequest="76" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Image x:Name="Team1SpecialHonorIcon" Source="developer_gold.png" WidthRequest="0" HeightRequest="0" IsVisible="False"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="5" FlowDirection="LeftToRight" HorizontalOptions="Fill" Margin="0,0,0,1">
                                <Label x:Name="Team1NextRankLabel" Grid.Column="0" Text="◇" FontSize="10" TextColor="#C8B56A" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"/>
                                <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                                    <ProgressBar x:Name="Team1RankProgressBar" Progress="0" HeightRequest="10" ProgressColor="#D4AF37" BackgroundColor="#242424" VerticalOptions="Center"/>
                                    <Label x:Name="Team1RankPercentLabel" Text="0%" FontSize="8" TextColor="Black" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                </Grid>
                                <Label x:Name="Team1CurrentRankLabel" Grid.Column="2" Text="◇" FontSize="10" TextColor="#D4AF37" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"/>
                            </Grid>

                            <Label x:Name="Team1Name" FontSize="{OnIdiom Phone=18, Tablet=22, Desktop=22}" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                            <Label x:Name="Team1Players" FontSize="{OnIdiom Phone=10, Tablet=12, Desktop=12}" TextColor="#D0D0D0" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" MaxLines="2"/>
                            <Label x:Name="Team1FloatingScore" Text="" FontSize="22" FontAttributes="Bold" TextColor="#D4AF37" Opacity="0" HorizontalOptions="Center"/>
                            <Label x:Name="Team1Score" Text="0" FontSize="{OnIdiom Phone=62, Tablet=75, Desktop=75}" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                            <Label Text="الهدف 151" FontSize="11" FontAttributes="Bold" TextColor="#E8E8E8" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <Grid Grid.Column="1" VerticalOptions="FillAndExpand">
                            <BoxView WidthRequest="1.5" Color="#8A5B27" Opacity="0.75" HorizontalOptions="Center" VerticalOptions="FillAndExpand"/>
                            <Frame BorderColor="#D4AF37" BackgroundColor="#080808" CornerRadius="32" WidthRequest="56" HeightRequest="56" Padding="0" HasShadow="False" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image Source="vs_gold_icon.png" WidthRequest="56" HeightRequest="56" VerticalOptions="Center" HorizontalOptions="Center" Aspect="AspectFit"/>
                            </Frame>
                        </Grid>

                        <VerticalStackLayout x:Name="Team2Card" Grid.Column="2" Spacing="3" VerticalOptions="Center" HorizontalOptions="Fill">
                            <Grid WidthRequest="82" HeightRequest="82" HorizontalOptions="Center">
                                <Image x:Name="Team2Emblem" WidthRequest="76" HeightRequest="76" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Image x:Name="Team2SpecialHonorIcon" Source="developer_gold.png" WidthRequest="0" HeightRequest="0" IsVisible="False"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="5" FlowDirection="LeftToRight" HorizontalOptions="Fill" Margin="0,0,0,1">
                                <Label x:Name="Team2NextRankLabel" Grid.Column="0" Text="◇" FontSize="10" TextColor="#C8B56A" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"/>
                                <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                                    <ProgressBar x:Name="Team2RankProgressBar" Progress="0" HeightRequest="10" ProgressColor="#D4AF37" BackgroundColor="#242424" VerticalOptions="Center"/>
                                    <Label x:Name="Team2RankPercentLabel" Text="0%" FontSize="8" TextColor="Black" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                </Grid>
                                <Label x:Name="Team2CurrentRankLabel" Grid.Column="2" Text="◇" FontSize="10" TextColor="#D4AF37" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"/>
                            </Grid>

                            <Label x:Name="Team2Name" FontSize="{OnIdiom Phone=18, Tablet=22, Desktop=22}" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                            <Label x:Name="Team2Players" FontSize="{OnIdiom Phone=10, Tablet=12, Desktop=12}" TextColor="#D0D0D0" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" MaxLines="2"/>
                            <Label x:Name="Team2FloatingScore" Text="" FontSize="22" FontAttributes="Bold" TextColor="#D4AF37" Opacity="0" HorizontalOptions="Center"/>
                            <Label x:Name="Team2Score" Text="0" FontSize="{OnIdiom Phone=62, Tablet=75, Desktop=75}" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                            <Label Text="الهدف 151" FontSize="11" FontAttributes="Bold" TextColor="#E8E8E8" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <Frame BorderColor="#8A5B27" BackgroundColor="#0B0B0B" CornerRadius="18" Padding="8" HasShadow="False">
                    <VerticalStackLayout Spacing="5">
                        <Label x:Name="KeypadDisplay" Text="0" FontSize="{OnIdiom Phone=31, Tablet=36, Desktop=36}" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                        <Grid FlowDirection="LeftToRight" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="5" RowSpacing="5">
                            <Button Text="1" Grid.Row="0" Grid.Column="0" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="2" Grid.Row="0" Grid.Column="1" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="3" Grid.Row="0" Grid.Column="2" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="4" Grid.Row="1" Grid.Column="0" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="5" Grid.Row="1" Grid.Column="1" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="6" Grid.Row="1" Grid.Column="2" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="7" Grid.Row="2" Grid.Column="0" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="8" Grid.Row="2" Grid.Column="1" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="9" Grid.Row="2" Grid.Column="2" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="0" Grid.Row="3" Grid.Column="0" Clicked="OnKeypadClicked" BackgroundColor="#101010" TextColor="White" BorderColor="#2A2A2A" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=24, Tablet=28, Desktop=28}" FontAttributes="Bold"/>
                            <Button Text="حذف" Grid.Row="3" Grid.Column="1" Clicked="OnDeleteDigitClicked" BackgroundColor="#080808" TextColor="#D4AF37" BorderColor="#D4AF37" BorderWidth="1" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=20, Tablet=24, Desktop=24}" FontAttributes="Bold"/>
                            <Button Text="مسح" Grid.Row="3" Grid.Column="2" Clicked="OnClearKeypadClicked" BackgroundColor="#D4AF37" TextColor="Black" CornerRadius="14" HeightRequest="{OnIdiom Phone=46, Tablet=54, Desktop=54}" FontSize="{OnIdiom Phone=20, Tablet=24, Desktop=24}" FontAttributes="Bold"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame IsVisible="False" BackgroundColor="#0B0B0B" BorderColor="#8A5B27" CornerRadius="18" Padding="12" HasShadow="False">
                    <Grid ColumnDefinitions="70,*,105" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.ColumnSpan="3" Text="آخر جولة" FontSize="14" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                        <Label x:Name="LastRoundPointsLabel" Grid.Row="1" Grid.Column="0" FontSize="22" FontAttributes="Bold" TextColor="#D4AF37" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" MaxLines="1"/>
                        <Label x:Name="LastRoundTeamLabel" Grid.Row="1" Grid.Column="1" FontSize="14" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                        <Label x:Name="LastRoundTimeLabel" Grid.Row="1" Grid.Column="2" FontSize="12" TextColor="#888888" HorizontalTextAlignment="Center"/>
                    </Grid>
                </Frame>

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <Label Text="سجل الجولات" FontSize="16" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="End" VerticalOptions="Center"/>
                    <Button x:Name="ToggleRoundsButton" Grid.Column="1" Text="عرض المزيد ▼" Clicked="OnToggleRoundsClicked" BackgroundColor="#151515" BorderColor="#8A5B27" BorderWidth="1" TextColor="#D4AF37" CornerRadius="14" FontSize="12" Padding="12,6" IsVisible="False"/>
                </Grid>
                <VerticalStackLayout x:Name="RoundsContainer" Spacing="8"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="SideMenuOverlay" IsVisible="False" BackgroundColor="#80000000" ZIndex="999">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="CloseMenuClicked"/>
            </Grid.GestureRecognizers>
            <Border x:Name="SideMenuPanel" WidthRequest="280" HorizontalOptions="Start" VerticalOptions="Fill" TranslationX="-280" FlowDirection="LeftToRight" BackgroundColor="#151515" Stroke="#D4AF37" StrokeThickness="1" Padding="20">
                <VerticalStackLayout Spacing="18">
                    <Label Text="إدارة المباراة" FontSize="24" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="1" Color="#8A5B27"/>
                    <Button Text="↩ تراجع آخر جولة" Clicked="OnUndoClicked" BackgroundColor="#111111" TextColor="White" BorderColor="#8A5B27" BorderWidth="1" CornerRadius="14"/>
                    <Button Text="🔄 مباراة جديدة" Clicked="OnResetClicked" BackgroundColor="#111111" TextColor="White" BorderColor="#8A5B27" BorderWidth="1" CornerRadius="14"/>
                    <Button Text="🏆 إنهاء المباراة" Clicked="OnFinishClicked" BackgroundColor="#111111" TextColor="#D4AF37" BorderColor="#D4AF37" BorderWidth="1" CornerRadius="14"/>
                    <Button Text="⬅ العودة" Clicked="OnBackClicked" BackgroundColor="#111111" TextColor="#FF7777" BorderColor="#8A5B27" BorderWidth="1" CornerRadius="14"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="DominoMajlisPRO.Pages.RankingsPage"
    BackgroundColor="#05080B"
    FlowDirection="RightToLeft"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollView x:Name="MainScroll" Grid.Row="0">
            <VerticalStackLayout x:Name="PageContent" Padding="{OnIdiom Phone='14,14,14,104', Tablet='28,20,28,112'}" Spacing="12"/>
        </ScrollView>

        <Border Grid.Row="1" Margin="12,0,12,10" Stroke="#3D2C15" BackgroundColor="#F007090B" StrokeShape="RoundRectangle 18" Padding="0">
            <Grid ColumnDefinitions="*,*,*,*" HeightRequest="76">
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterHomeTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="الرئيسية" TextColor="#D7B66F" FontSize="12"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterCreateTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="players_card.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="إنشاء فريق" TextColor="#D7B66F" FontSize="12"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterRankingsTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="rankings_gold.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="التصنيفات" TextColor="#FFD15F" FontSize="12" FontAttributes="Bold"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFooterStoreTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="shop_gold.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="المتجر" TextColor="#D7B66F" FontSize="12"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid x:Name="DetailsOverlay" Grid.RowSpan="2" IsVisible="False" Opacity="0" BackgroundColor="#B0000000" Padding="16" ZIndex="90">
            <Border x:Name="DetailsSheet" Stroke="#C99539" StrokeThickness="1.4" BackgroundColor="#F00A0B0D" StrokeShape="RoundRectangle 22" Padding="16" HorizontalOptions="Center" VerticalOptions="End" MaximumWidthRequest="560" TranslationY="80">
                <ScrollView MaximumHeightRequest="{OnIdiom Phone=520, Tablet=650}">
                    <VerticalStackLayout x:Name="DetailsContent" Spacing="12"/>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>

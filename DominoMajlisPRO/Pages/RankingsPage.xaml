<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="DominoMajlisPRO.Pages.RankingsPage"
    BackgroundColor="#0B0B0F"
    NavigationPage.HasNavigationBar="False"
    FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- ========================= -->
        <!-- HEADER -->
        <!-- ========================= -->

        <Border
            Grid.Row="0"
            BackgroundColor="#14141A"
            StrokeThickness="0"
            Padding="20,18">

            <Grid ColumnDefinitions="40,*,40">

                <Image
                    Source="back_gold.png"
                    WidthRequest="35"
                    HeightRequest="35"
                    VerticalOptions="Center">

                    <Image.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnBackClicked"/>
                    </Image.GestureRecognizers>

                </Image>

                <Label
                    Grid.Column="1"
                    Text="التصنيفات"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center"
                    VerticalTextAlignment="Center"/>

                <Image
                    Grid.Column="2"
                    Source="rankings_gold.png"
                    WidthRequest="35"
                    HeightRequest="35"
                    HorizontalOptions="End"
                    VerticalOptions="Center"/>

            </Grid>

        </Border>

        <!-- ========================= -->
        <!-- SEGMENTED CONTROL (Teams / Players) -->
        <!-- ========================= -->

        <Border
            Grid.Row="1"
            Margin="20,10,20,4"
            BackgroundColor="#121218"
            Stroke="#262633"
            StrokeThickness="1"
            Padding="4"
            StrokeShape="RoundRectangle 18">

            <Grid ColumnDefinitions="*,*" ColumnSpacing="4">

                <Border
                    Grid.Column="0"
                    BackgroundColor="#2A2008"
                    Stroke="#D4AF37"
                    StrokeThickness="1"
                    Padding="0,10"
                    StrokeShape="RoundRectangle 14">
                    <Label
                        Text="تصنيف الفرق"
                        TextColor="#FFD700"
                        FontSize="15"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"/>
                </Border>

                <Border
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    Padding="0,10"
                    StrokeShape="RoundRectangle 14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlayersRankingClicked"/>
                    </Border.GestureRecognizers>
                    <Label
                        Text="تصنيف اللاعبين"
                        TextColor="#A6A6B5"
                        FontSize="15"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"/>
                </Border>

            </Grid>

        </Border>

        <!-- ========================= -->
        <!-- FILTERS -->
        <!-- ========================= -->

        <ScrollView
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never">

            <HorizontalStackLayout
                Padding="20,10"
                Spacing="10">

                <!-- ALL -->

                <Border
                    x:Name="AllFilter"
                    Padding="14,8"
                    BackgroundColor="#17171F"
                    Stroke="#292938"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnAllFilterClicked"/>
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Spacing="6">

                        <Image
                            Source="all_gold.png"
                            WidthRequest="16"
                            HeightRequest="16"/>

                        <Label
                            Text="الكل"
                            TextColor="White"
                            FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                </Border>

                <!-- XP -->

                <Border
                    x:Name="XPFilter"
                    Padding="14,8"
                    BackgroundColor="#17171F"
                    Stroke="#292938"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnTopXPFilterClicked"/>
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Spacing="6">

                        <Image
                            Source="xp_gold.png"
                            WidthRequest="16"
                            HeightRequest="16"/>

                        <Label
                            Text="XP"
                            TextColor="White"
                            FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                </Border>

                <!-- WINS -->

                <Border
                    x:Name="WinsFilter"
                    Padding="14,8"
                    BackgroundColor="#17171F"
                    Stroke="#292938"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnWinsFilterClicked"/>
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Spacing="6">

                        <Image
                            Source="wins_gold.png"
                            WidthRequest="16"
                            HeightRequest="16"/>

                        <Label
                            Text="الفوز"
                            TextColor="White"
                            FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                </Border>

                <!-- MELES -->

                <Border
                    x:Name="MelesFilter"
                    Padding="14,8"
                    BackgroundColor="#17171F"
                    Stroke="#292938"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnMelesFilterClicked"/>
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Spacing="6">

                        <Image
                            Source="fire_gold.png"
                            WidthRequest="16"
                            HeightRequest="16"/>

                        <Label
                            Text="الملص"
                            TextColor="White"
                            FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                </Border>

            </HorizontalStackLayout>

        </ScrollView>

        <!-- ========================= -->
        <!-- SEARCH -->
        <!-- ========================= -->

        <Border
            Grid.Row="3"
            Margin="20,0,20,10"
            HeightRequest="54"
            Padding="14,0"
            BackgroundColor="#14141A"
            Stroke="#292938"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 18">

            <Grid ColumnDefinitions="30,*">

                <Image
                    Source="search_gold.png"
                    WidthRequest="18"
                    HeightRequest="18"
                    VerticalOptions="Center"/>

                <SearchBar
                    x:Name="SearchBar"
                    Grid.Column="1"
                    Placeholder="البحث عن فريق..."
                    PlaceholderColor="#7B7B89"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    TextChanged="OnSearchTextChanged"/>

            </Grid>

        </Border>

        <!-- ========================= -->
        <!-- CONTENT -->
        <!-- ========================= -->

        <ScrollView Grid.Row="4">

            <VerticalStackLayout
                x:Name="LeaderboardContainer"
                Padding="20"
                Spacing="18">



                <!-- Season Mini Header -->

                <Border
    BackgroundColor="#14141A"
    Stroke="#D9A441"
    StrokeThickness="1"
    Padding="14"
    StrokeShape="RoundRectangle 22">

                    <VerticalStackLayout Spacing="8">

                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <Image
                Source="season_reward_gold.png"
                WidthRequest="34"
                HeightRequest="34"
                VerticalOptions="Center"/>

                            <VerticalStackLayout
                Grid.Column="1"
                Spacing="2"
                Margin="10,0">

                                <Label
                    x:Name="SeasonTitleLabel"
                    Text="الموسم الحالي"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="White"/>

                                <Label
                    x:Name="SeasonCountdownLabel"
                    Text="متبقي 0 يوم"
                    FontSize="12"
                    TextColor="#C9D5FF"/>

                            </VerticalStackLayout>

                            <Label
                x:Name="SeasonProgressPercentLabel"
                Grid.Column="2"
                Text="0%"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#FFD700"
                VerticalTextAlignment="Center"/>

                        </Grid>

                        <ProgressBar
            x:Name="SeasonProgressBar"
            Progress="0"
            HeightRequest="8"
            ProgressColor="#FFD700"
            BackgroundColor="#26324D"/>

                    </VerticalStackLayout>

                </Border>
                
                
                <!-- Champion Card -->

                <VerticalStackLayout
                    x:Name="ChampionContainer"/>

                <!-- Top 3 Podium -->

                <VerticalStackLayout
                    x:Name="PodiumContainer"/>

                <!-- Leaderboard Table -->

                <Border
                    BackgroundColor="#14141A"
                    Stroke="#292938"
                    StrokeThickness="1"
                    Padding="15"
                    StrokeShape="RoundRectangle 24">

                    <VerticalStackLayout
                        x:Name="LeaderboardTableContainer"
                        Spacing="0"/>

                </Border>

                <!-- Quick Actions -->

                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="12">

                    <Border
                        BackgroundColor="#14141A"
                        Stroke="#292938"
                        StrokeThickness="1"
                        Padding="15"
                        StrokeShape="RoundRectangle 20">

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="8">

                            <Image
                                Source="hall_of_fame_gold.png"
                                WidthRequest="28"
                                HeightRequest="28"/>

                            <Label
                                Text="Hall Of Fame"
                                TextColor="White"
                                FontSize="12"/>
                        </VerticalStackLayout>

                    </Border>

                    <Border
                        Grid.Column="1"
                        BackgroundColor="#14141A"
                        Stroke="#292938"
                        StrokeThickness="1"
                        Padding="15"
                        StrokeShape="RoundRectangle 20">

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="8">

                            <Image
                                Source="season_reward_gold.png"
                                WidthRequest="28"
                                HeightRequest="28"/>

                            <Label
                                Text="Season"
                                TextColor="White"
                                FontSize="12"/>
                        </VerticalStackLayout>

                    </Border>

                </Grid>

                <!-- DELETE -->

                <Button
                    x:Name="DeleteAllButton"
                    Text="حذف جميع التصنيفات"
                    BackgroundColor="#B91C1C"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="18"
                    HeightRequest="52"
                    Margin="0,10,0,40"/>

            </VerticalStackLayout>

        </ScrollView>

        <!-- ====================================== -->
        <!-- TEAM DETAILS BOTTOM SHEET -->
        <!-- ====================================== -->

        <Grid
    x:Name="BottomSheetOverlay"
    Grid.RowSpan="5"
    IsVisible="False"
    BackgroundColor="#99000000"
    InputTransparent="False"
    ZIndex="999">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer
            Tapped="OnCloseBottomSheetClicked"/>
            </Grid.GestureRecognizers>

            <Border
        VerticalOptions="End"
        BackgroundColor="#111827"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="20"
        HeightRequest="520"
        StrokeShape="RoundRectangle 28,28,0,0">

                <ScrollView>

                    <VerticalStackLayout Spacing="14">

                        <!-- Handle -->

            <Border
        WidthRequest="60"
        HeightRequest="6"
        HorizontalOptions="Center"
        BackgroundColor="#4B5563"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 10"/>

            <!-- Rank Icon -->

            <Image
        x:Name="SheetRankIcon"
        WidthRequest="90"
        HeightRequest="90"
        HorizontalOptions="Center"/>

            <!-- Team -->

            <Label
        x:Name="SheetTeamName"
        FontSize="24"
        FontAttributes="Bold"
        TextColor="White"
        HorizontalTextAlignment="Center"/>

            <Label
        x:Name="SheetPlayers"
        FontSize="15"
        TextColor="#CBD5E1"
        HorizontalTextAlignment="Center"/>

            <!-- Identity -->

            <Label
        x:Name="SheetTeamIdentity"
        FontSize="11"
        TextColor="#94A3B8"
        HorizontalTextAlignment="Center"/>

            <BoxView
        HeightRequest="1"
        Color="#233A63"
        Opacity="0.5"/>

            <!-- Quick Stats -->

            <Grid ColumnDefinitions="*,*,*">

                <Border
            BackgroundColor="#162033"
            Padding="10"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 14">

                    <VerticalStackLayout>
                        <Label
                    Text="XP"
                    FontSize="11"
                    TextColor="#94A3B8"
                    HorizontalTextAlignment="Center"/>

                        <Label
                    x:Name="SheetXP"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#FFD700"
                    HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                </Border>

                <Border
            Grid.Column="1"
            BackgroundColor="#162033"
            Padding="10"
            Margin="6,0"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 14">

                    <VerticalStackLayout>
                        <Label
                    Text="Trust"
                    FontSize="11"
                    TextColor="#94A3B8"
                    HorizontalTextAlignment="Center"/>

                        <Label
                    x:Name="SheetTrust"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#22C55E"
                    HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                </Border>

                <Border
            Grid.Column="2"
            BackgroundColor="#162033"
            Padding="10"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 14">

                    <VerticalStackLayout>
                        <Label
                    Text="Matches"
                    FontSize="11"
                    TextColor="#94A3B8"
                    HorizontalTextAlignment="Center"/>

                        <Label
                    x:Name="SheetMatches"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                </Border>

            </Grid>

            <BoxView
        HeightRequest="1"
        Color="#233A63"
        Opacity="0.5"/>

                        <!-- Rank Section -->

                        <Grid ColumnDefinitions="*,*">

                            <!-- Current Rank -->

                            <VerticalStackLayout>

                                <Label
            Text="Current Rank"
            FontSize="12"
            TextColor="#94A3B8"
            HorizontalTextAlignment="Center"/>

                                <Image
            x:Name="SheetCurrentRankIcon"
            WidthRequest="42"
            HeightRequest="42"
            HorizontalOptions="Center"/>

                                <Label
            x:Name="SheetCurrentRank"
            FontAttributes="Bold"
            TextColor="#FFD700"
            HorizontalTextAlignment="Center"/>

                            </VerticalStackLayout>

                            <!-- Highest Rank -->

                            <VerticalStackLayout Grid.Column="1">

                                <Label
            Text="Highest Rank"
            FontSize="12"
            TextColor="#94A3B8"
            HorizontalTextAlignment="Center"/>

                                <Image
            x:Name="SheetHighestRankIcon"
            WidthRequest="42"
            HeightRequest="42"
            HorizontalOptions="Center"/>

                                <Label
            x:Name="SheetHighestRank"
            FontAttributes="Bold"
            TextColor="#FFD700"
            HorizontalTextAlignment="Center"/>

                            </VerticalStackLayout>

                        </Grid>

                        <!-- Win Rate -->

            <Grid ColumnDefinitions="*,*">

                <VerticalStackLayout>

                    <Label
                Text="Current WR"
                FontSize="12"
                TextColor="#94A3B8"
                HorizontalTextAlignment="Center"/>

                    <Label
                x:Name="SheetCurrentWR"
                FontAttributes="Bold"
                TextColor="#22C55E"
                HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">

                    <Label
                Text="Peak WR"
                FontSize="12"
                TextColor="#94A3B8"
                HorizontalTextAlignment="Center"/>

                    <Label
                x:Name="SheetPeakWR"
                FontAttributes="Bold"
                TextColor="#22C55E"
                HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>

            </Grid>

            <BoxView
        HeightRequest="1"
        Color="#233A63"
        Opacity="0.5"/>



   

                        <!-- Rank Progress -->

                        <VerticalStackLayout
    Spacing="8">

                            <Label
        x:Name="SheetRankProgressName"
        FontSize="18"
        FontAttributes="Bold"
        TextColor="#FFD700"
        HorizontalTextAlignment="Center"/>

                            <Label
        x:Name="SheetXPProgress"
        FontSize="14"
        TextColor="White"
        HorizontalTextAlignment="Center"/>

                            <ProgressBar
        x:Name="SheetRankProgressBar"
        HeightRequest="10"
        ProgressColor="#FFD700"
        BackgroundColor="#243244"/>

                            <Label
        x:Name="SheetNextRankText"
        FontSize="13"
        TextColor="#63B7FF"
        HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                        <BoxView
    HeightRequest="1"
    Color="#233A63"
    Opacity="0.5"/>
                        <!-- W/L/M -->

                        <!-- Match Statistics Cards -->

                        <Grid
    ColumnDefinitions="*,*,*"
    ColumnSpacing="8">

                            <!-- Wins -->

                            <Border
        BackgroundColor="#13271B"
        Stroke="#1F8A4C"
        StrokeThickness="1"
        Padding="10"
        StrokeShape="RoundRectangle 16">

                                <VerticalStackLayout
            Spacing="4">

                                    <Label
                x:Name="SheetWins"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="#22C55E"
                HorizontalTextAlignment="Center"/>

                                    <Label
                Text="فوز"
                FontSize="12"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Losses -->

                            <Border
        Grid.Column="1"
        BackgroundColor="#2A1616"
        Stroke="#B91C1C"
        StrokeThickness="1"
        Padding="10"
        StrokeShape="RoundRectangle 16">

                                <VerticalStackLayout
            Spacing="4">

                                    <Label
                x:Name="SheetLosses"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="#EF4444"
                HorizontalTextAlignment="Center"/>

                                    <Label
                Text="خسارة"
                FontSize="12"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Meles -->

                            <Border
        Grid.Column="2"
        BackgroundColor="#2B230F"
        Stroke="#D97706"
        StrokeThickness="1"
        Padding="10"
        StrokeShape="RoundRectangle 16">

                                <VerticalStackLayout
            Spacing="4">

                                    <Label
                x:Name="SheetMeles"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="#F59E0B"
                HorizontalTextAlignment="Center"/>

                                    <Label
                Text="ملص"
                FontSize="12"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                        </Grid>

                        <BoxView
        HeightRequest="1"
        Color="#233A63"
        Opacity="0.5"/>



                        <!-- BADGES -->

                        <Grid
    ColumnDefinitions="*,*"
    RowDefinitions="Auto,Auto,Auto,Auto"
    ColumnSpacing="10"
    RowSpacing="10">

                            <!-- Verified -->

                            <Border
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Image
                x:Name="VerifiedIcon"
                Source="verified_team_gold.png"
                WidthRequest="70"
                HeightRequest="70"
                Opacity="0.25"
                HorizontalOptions="Center"/>

                                    <Label
                Text="Verified"
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Rivalry -->

                            <Border
        Grid.Column="1"
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Image
                x:Name="RivalryIcon"
                Source="rivalry_gold.png"
                WidthRequest="70"
                HeightRequest="70"
                Opacity="0.25"
                HorizontalOptions="Center"/>

                                    <Label
                Text="Rivalry"
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Trust -->

                            <Border
        Grid.Row="1"
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Image
                x:Name="TrustIcon"
                Source="trust_gold.png"
                WidthRequest="70"
                HeightRequest="70"
                Opacity="0.25"
                HorizontalOptions="Center"/>

                                    <Label
                Text="Trust"
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Activity -->

                            <Border
        Grid.Row="1"
        Grid.Column="1"
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Image
                x:Name="ActivityIcon"
                Source="activity_gold.png"
                WidthRequest="70"
                HeightRequest="70"
                Opacity="0.25"
                HorizontalOptions="Center"/>

                                    <Label
                Text="Activity"
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Season -->

                            <Border
        Grid.Row="2"
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Image
                x:Name="SeasonIcon"
                Source="season_reward_gold.png"
                WidthRequest="70"
                HeightRequest="70"
                Opacity="0.25"
                HorizontalOptions="Center"/>

                                    <Label
                Text="Season"
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- MVP -->

                            <Border
        Grid.Row="2"
        Grid.Column="1"
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Image
                x:Name="MVPIcon"
                Source="mvp_gold.png"
                WidthRequest="70"
                HeightRequest="70"
                Opacity="0.25"
                HorizontalOptions="Center"/>

                                    <Label
                Text="MVP"
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Hall Of Fame -->

                            <Border
        Grid.Row="3"
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Image
                x:Name="HallOfFameIcon"
                Source="hall_of_fame_gold.png"
                WidthRequest="70"
                HeightRequest="70"
                Opacity="0.25"
                HorizontalOptions="Center"/>

                                    <Label
                Text="Hall Of Fame"
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Reserved -->

                            <Border
        Grid.Row="3"
        Grid.Column="1"
        BackgroundColor="#162033"
        Stroke="#2D3748"
        StrokeThickness="1"
        Padding="1"
        HeightRequest="95"
        StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="4">

                                    <Label
                Text="Coming Soon"
                FontSize="11"
                TextColor="#64748B"
                HorizontalTextAlignment="Center"
                VerticalOptions="Center"/>

                                </VerticalStackLayout>

                            </Border>

                        </Grid>

                        <BoxView
        HeightRequest="1"
        Color="#233A63"
        Opacity="0.5"/>

            <Button
        Text="إغلاق"
        Clicked="OnCloseBottomSheetClicked"
        BackgroundColor="#1E293B"
        TextColor="White"
        CornerRadius="16"/>

                    </VerticalStackLayout>

                </ScrollView>

            </Border>

        </Grid>

    </Grid>

</ContentPage>
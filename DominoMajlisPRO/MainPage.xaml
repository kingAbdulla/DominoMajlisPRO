<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    xmlns:galleryComponents="clr-namespace:DominoMajlisPRO.GalleryEngine.Components"
    x:Class="DominoMajlisPRO.MainPage"
    BackgroundColor="#050505"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <ScrollView>

            <VerticalStackLayout
            Padding="18"
            Spacing="24">



                <!-- ========================= -->
                <!-- HERO SECTION -->
                <!-- ========================= -->

                <Border
                    Stroke="#D4AF37"
                    StrokeThickness="2"
                    BackgroundColor="#080808">
                    <Border.Padding>
                        <OnIdiom x:TypeArguments="Thickness"
                                 Phone="14"
                                 Tablet="24"/>
                    </Border.Padding>
                    <Border.Shadow>
                        <Shadow
                            Brush="#D4AF37"
                            Radius="8"
                            Opacity="0.28"/>
                    </Border.Shadow>

                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="38"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="{OnIdiom Phone=16, Tablet=22}">

                        <!-- RESPONSIVE THREE-ZONE HEADER -->
                        <Grid
                            x:Name="MainPlayerHeaderSurface"
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="{OnIdiom Phone=10, Tablet=22}"
                            Padding="{OnIdiom Phone=2, Tablet=8}">

                            <Grid
                                Grid.Column="0"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="{OnIdiom Phone=8, Tablet=12}"
                                HorizontalOptions="Fill"
                                VerticalOptions="Center">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnProfileTapped"/>
                                </Grid.GestureRecognizers>

                                <Image
                                    x:Name="HeaderProfileBackgroundImage"
                                    Grid.ColumnSpan="2"
                                    Aspect="AspectFill"
                                    Opacity="0.34"
                                    InputTransparent="True"
                                    IsVisible="False"/>

                                <Grid
                                    Grid.Column="0"
                                    WidthRequest="{OnIdiom Phone=40, Tablet=48}"
                                    HeightRequest="{OnIdiom Phone=40, Tablet=48}"
                                    VerticalOptions="Center">
                                        <Image
                                            x:Name="HeaderPlayerAvatar"
                                            Source="normal_avatar_1.png"
                                            Aspect="AspectFill"/>

                                    <Image
                                        x:Name="HeaderAvatarFrameOverlay"
                                        Aspect="AspectFit"
                                        InputTransparent="True"
                                        IsVisible="False"/>
                                    <Image
                                        x:Name="HeaderAvatarEffectOverlay"
                                        Aspect="AspectFit"
                                        InputTransparent="True"
                                        IsVisible="False"/>

                                    <Border
                                        x:Name="ProfileStatusBadge"
                                        WidthRequest="{OnIdiom Phone=10, Tablet=12}"
                                        HeightRequest="{OnIdiom Phone=10, Tablet=12}"
                                        BackgroundColor="Red"
                                        Stroke="#111111"
                                        StrokeThickness="1"
                                        HorizontalOptions="End"
                                        VerticalOptions="End">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999"/>
                                        </Border.StrokeShape>
                                    </Border>
                                </Grid>

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="1"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center">
                                    <Label
                                        x:Name="HeaderPlayerNameLabel"
                                        Text="اللاعب"
                                        FontSize="{OnIdiom Phone=11, Tablet=14}"
                                        FontAttributes="Bold"
                                        TextColor="#F5F5F5"
                                        HorizontalTextAlignment="Start"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"/>

                                    <galleryComponents:IdentityPlateView
                                        x:Name="HeaderPlayerNamePlate"
                                        HeightRequest="{OnIdiom Phone=28, Tablet=32}"
                                        MaximumWidthRequest="190"
                                        HorizontalOptions="Fill"
                                        IsVisible="False"/>

                                    <Label
                                        x:Name="MemberLevelLabel"
                                        Text="Guest"
                                        FontSize="{OnIdiom Phone=9, Tablet=11}"
                                        TextColor="#C8B56A"
                                        HorizontalTextAlignment="Start"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"/>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="2"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                                <Grid
                                    WidthRequest="{OnIdiom Phone=36, Tablet=42}"
                                    HeightRequest="{OnIdiom Phone=36, Tablet=42}">
                                    <Image
                                        Source="settings_gold.png"
                                        WidthRequest="{OnIdiom Phone=28, Tablet=32}"
                                        HeightRequest="{OnIdiom Phone=28, Tablet=32}"
                                        Aspect="AspectFit">
                                    </Image>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSettingsImageTapped"/>
                                    </Grid.GestureRecognizers>
                                </Grid>
                                <Label
                                    Text="الإعدادات"
                                    FontSize="{OnIdiom Phone=9, Tablet=11}"
                                    TextColor="#C8B56A"
                                    HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>

                        </Grid>

                        <!-- CENTERED LOGO -->
                        <Border
                            HorizontalOptions="Center"
                            Stroke="Gold"
                            StrokeThickness="2"
                            BackgroundColor="#080808"
                            Padding="{OnIdiom Phone=22, Tablet=28}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="40"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Gold" Radius="12" Opacity="0.42"/>
                            </Border.Shadow>
                            <Image
                                Source="domino_gold_icon.png"
                                HeightRequest="{OnIdiom Phone=150, Tablet=185}"
                                WidthRequest="{OnIdiom Phone=150, Tablet=185}"
                                Aspect="AspectFit">
                                <Image.GestureRecognizers>
                                    <PointerGestureRecognizer
                                        PointerPressed="OnLogoPressed"
                                        PointerReleased="OnLogoReleased"/>
                                </Image.GestureRecognizers>
                            </Image>
                        </Border>

                        <Label
                            Text="DOMINO MAJLIS PRO"
                            FontFamily="CinzelDecorative-Bold"
                            FontSize="{OnIdiom Phone=22, Tablet=28}"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            TextColor="Gold"/>

                        <Label
                            Text="منصة احترافية لإدارة بطولات الدومينو"
                            FontFamily="DG-Nemr-V.0"
                            FontSize="{OnIdiom Phone=14, Tablet=18}"
                            HorizontalOptions="Fill"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            MaxLines="2"
                            TextColor="#BBBBBB"/>

                    </VerticalStackLayout>
                </Border>

                <!-- ========================= -->
                <!-- SEASON PREMIUM CARD -->
                <!-- ========================= -->

                <Border
    x:Name="SeasonCard"
    Margin="0,-10,0,-8"
    Stroke="#D4AF37"
    StrokeThickness="2"
    BackgroundColor="#080808"
    Padding="14">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow
            Brush="#D4AF37"
            Radius="10"
            Opacity="0.45"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <Image
                Source="season_reward_gold.png"
                WidthRequest="44"
                HeightRequest="44"
                VerticalOptions="Center"/>

                            <VerticalStackLayout
                Grid.Column="1"
                Margin="12,0"
                Spacing="2"
                VerticalOptions="Center">

                                <Label
                    x:Name="MainSeasonTitleLabel"
                    Text="الموسم الحالي"
                    FontSize="{OnIdiom Phone=17, Tablet=22}"
                    FontAttributes="Bold"
                    TextColor="#FFD700"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"/>

                                <Label
                    x:Name="MainSeasonCountdownLabel"
                    Text="متبقي 0 يوم"
                    FontSize="{OnIdiom Phone=13, Tablet=17}"
                    TextColor="#DDDDDD"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"/>

                            </VerticalStackLayout>

                            <Label
                x:Name="MainSeasonProgressPercentLabel"
                Grid.Column="2"
                Text="0%"
                FontSize="{OnIdiom Phone=18, Tablet=24}"
                FontAttributes="Bold"
                TextColor="#FFD700"
                VerticalTextAlignment="Center"/>

                        </Grid>

                        <ProgressBar
            x:Name="MainSeasonProgressBar"
            Progress="0"
            HeightRequest="9"
            ProgressColor="#FFD700"
            BackgroundColor="#2A2A2A"/>

                    </VerticalStackLayout>

                </Border>


                <!-- ========================= -->
                <!-- TEAM SELECTION -->
                <!-- ========================= -->

                <Grid
                Margin="0,-15"
    ColumnDefinitions="*">




                    <!-- القوانين -->

                    <Border
                    HorizontalOptions="Fill"
 
      Stroke="#D4AF37"
  StrokeThickness="2"
  BackgroundColor="#080808"
  Padding="12">


                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>

                        </Border.StrokeShape>


                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="0"
                            FlowDirection="RightToLeft">

                            <Grid
                                Grid.Column="0"
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="8"
                                Padding="8,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRulesCardTapped"/>
                                </Grid.GestureRecognizers>

                                <Image
                                    Source="rules_gold.png"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    VerticalOptions="Center"/>

                                <Label
                                    Grid.Column="1"
                                    x:Name="PreviewRulesLabel"
                                    Text="عالمي"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#D4AF37"
                                    VerticalOptions="Center"
                                    HorizontalTextAlignment="Center"/>

                                <Label
                                    Grid.Column="2"
                                    Text="▼"
                                    FontSize="12"
                                    TextColor="#D4AF37"
                                    VerticalOptions="Center"/>
                            </Grid>

                            <Grid
                                Grid.Column="1"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="8"
                                Padding="12,0"
                                BackgroundColor="#080808">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStoreTapped"/>
                                </Grid.GestureRecognizers>

                                <Image
                                    Source="shop_gold.png"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Aspect="AspectFit"
                                    VerticalOptions="Center"/>

                                <Label
                                    Grid.Column="1"
                                    Text="المتجر"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#D4AF37"
                                    VerticalOptions="Center"
                                    HorizontalTextAlignment="Center"/>
                            </Grid>
                        </Grid>

                    </Border>

                </Grid>

                <!--Rulls -->
                <Border
x:Name="RulesDropdownBorder"
IsVisible="False"
Stroke="#D4AF37"
StrokeThickness="2"
BackgroundColor="#080808"
Padding="10"
Margin="0,5,0,0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">

                        <Label
        Text="محلي"
        FontSize="20"
        TextColor="#D4AF37">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                Tapped="OnLocalRuleTapped"/>
                            </Label.GestureRecognizers>

                        </Label>

                        <BoxView
        HeightRequest="1"
        Color="#333333"/>

                        <Label
        Text="عالمي"
        FontSize="20"
        TextColor="#D4AF37">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                Tapped="OnInternationalRuleTapped"/>
                            </Label.GestureRecognizers>

                        </Label>

                    </VerticalStackLayout>

                </Border>




                <!---Creat New Team-->
                <Border
    Stroke="#D4AF37"
    StrokeThickness="2"
    BackgroundColor="#080808"
    Padding="12">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow
            Brush="#D4AF37"
            Radius="10"
            Opacity="0.45"/>
                    </Border.Shadow>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
            Tapped="OnCreateTeamClicked"/>
                    </Border.GestureRecognizers>

                    <Grid
        ColumnDefinitions="100,*,0"
        FlowDirection="RightToLeft">

                        <Image
            Source="addteam_logo.png"
            WidthRequest="60"
            HeightRequest="60"
            VerticalOptions="Center"/>

                        <VerticalStackLayout
    Grid.Column="1"
    Spacing="2"
    VerticalOptions="Center">

                            <Label
        Text=" + إنشاء فريق جديد"
        FontSize="20"
        FontAttributes="Bold"
        TextColor="#D4AF37"/>

                            <Label
        Text="إضافة فريق جديد للمجلس"
        FontSize="14"
        TextColor="#AAAAAA"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>

                <!-- ========================= -->
                <!-- MATCH PREVIEW NEW -->
                <!-- ========================= -->

                <Border
    Margin="0,-15"
    x:Name="MatchPreviewBorder"
    Stroke="#D4AF37"
    StrokeThickness="2"
    BackgroundColor="#080808"
    Padding="15">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">

                        <HorizontalStackLayout
    HorizontalOptions="Center"
    Spacing="3">

                            <Image
        Source="vs_match.png"
        WidthRequest="75"
        HeightRequest="75"/>

                            <Label
        Text="مواجهة اليوم"
                                FontFamily="DG-Nemr-V.0"
        FontSize="18"
        FontAttributes="Bold"
                             VerticalTextAlignment="Center"
        TextColor="#FFD700"/>

                        </HorizontalStackLayout>

                        <Label
            x:Name="PreviewTeamsLabel"
            Text="اختر فريقين"
            FontSize="18"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="White"/>

                        <!-- TEAM 1 -->

                        <Border
    x:Name="PreviewTeam1Border"
    MinimumHeightRequest="170"
    Margin="0,0,0,-20"
    Stroke="#D4AF37"
    StrokeThickness="2"
    BackgroundColor="#080808"
    Padding="12">
                            <Border.Shadow>
                                <Shadow
                                Brush="#D4AF37"
                                Radius="12"
                                Opacity="0.55"/>

                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
            Tapped="OnTeam1CardTapped"/>
                            </Border.GestureRecognizers>

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>



                            <Grid
                FlowDirection="RightToLeft"
                ColumnDefinitions="120,*"
                ColumnSpacing="12">

                                <Image
                    x:Name="PreviewTeam1Logo"
                    WidthRequest="130"
                    HeightRequest="130"
                    Aspect="AspectFit"/>

                                <VerticalStackLayout
    Grid.Column="1"
    VerticalOptions="Center"
    Spacing="2">

                                    <Grid
        ColumnDefinitions="*,25">

                                        <Label
    Grid.Column="0"
    x:Name="PreviewTeam1NameLabel"
    Text="الفريق الأول"
    FontSize="24"
    FontAttributes="Bold"
    TextColor="#FFD700"
    LineBreakMode="TailTruncation"
    MaxLines="1"
    HorizontalTextAlignment="Start"/>

                                        <galleryComponents:IdentityPlateView
    Grid.Column="0"
    x:Name="PreviewTeam1NamePlate"
    HeightRequest="42"
    MaximumWidthRequest="280"
    HorizontalOptions="Fill"
    IsVisible="False"/>

                                        <Label
            Grid.Column="1"
            Text="▼"
            FontSize="14"
            TextColor="#D4AF37"
            VerticalOptions="Center"/>

                                    </Grid>

                                    <Label
        x:Name="PreviewTeam1PlayersLabel"
        Text="اختر فريق"
        FontSize="15"
        TextColor="#DDDDDD"/>

                                </VerticalStackLayout>

                            </Grid>

                        </Border>

                        <!--VS-->

                        <!-- VS LINE -->

                        <Grid
    Margin="0,-15,0,-15"
    ZIndex="10">

                            <!-- LINE -->

                            <Grid
    HeightRequest="120">

                                <!-- الخط الخلفي -->

                                <BoxView
        HeightRequest="2"
        Color="#D4AF37"
        VerticalOptions="Center"
        Margin="20,0"/>

                                <!-- دائرة VS فوق الخط -->

                                <Border
        HorizontalOptions="Center"
        VerticalOptions="Center"
        ZIndex="10"
        BackgroundColor="#080808"
        Stroke="#D4AF37"
        StrokeThickness="3"
        Padding="20">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="999"/>
                                    </Border.StrokeShape>

                                    <Border.Shadow>
                                        <Shadow
                Brush="#D4AF37"
                Radius="30"
                Opacity="0.95"/>
                                    </Border.Shadow>


                                </Border>

                            </Grid>

                            <!-- VS CIRCLE -->

                            <Border
        HorizontalOptions="Center"
        VerticalOptions="Center"
        BackgroundColor="#080808"
        Stroke="#D4AF37"
        StrokeThickness="3"
        Padding="10">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="999"/>
                                </Border.StrokeShape>

                                <Border.Shadow>
                                    <Shadow
                Brush="#D4AF37"
                Radius="25"
                Opacity="0.9"/>
                                </Border.Shadow>

                                <Image
Grid.Column="1"
Source="vs_gold_icon.png"
WidthRequest="75"
HeightRequest="75"
VerticalOptions="Center"
HorizontalOptions="Center"
Aspect="AspectFit"/>

                            </Border>

                        </Grid>


                        <!-- TEAM 2 -->


                        <Border
            x:Name="PreviewTeam2Border"
            MinimumHeightRequest="170"
             Margin="0,-20,0,0"
            Stroke="#D4AF37"
            StrokeThickness="2"
            BackgroundColor="#080808"
            Padding="12">
                            <Border.Shadow>
                                <Shadow
        Brush="#D4AF37"
        Radius="12"
        Opacity="0.55"/>

                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
            Tapped="OnTeam2CardTapped"/>
                            </Border.GestureRecognizers>

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>

                            <Grid
                FlowDirection="RightToLeft"
                ColumnDefinitions="120,*"
                ColumnSpacing="12">

                                <Image
                    x:Name="PreviewTeam2Logo"
                    WidthRequest="130"
                    HeightRequest="130"
                    Aspect="AspectFit"/>

                                <VerticalStackLayout
    Grid.Column="1"
    VerticalOptions="Center"
    Spacing="2">

                                    <Grid
        ColumnDefinitions="*,25">

                                        <Label
    Grid.Column="0"
    x:Name="PreviewTeam2NameLabel"
    Text="الفريق الثاني"
    FontSize="24"
    FontAttributes="Bold"
    TextColor="#FFD700"
    LineBreakMode="TailTruncation"
    MaxLines="1"
    HorizontalTextAlignment="Start"/>

                                        <galleryComponents:IdentityPlateView
    Grid.Column="0"
    x:Name="PreviewTeam2NamePlate"
    HeightRequest="42"
    MaximumWidthRequest="280"
    HorizontalOptions="Fill"
    IsVisible="False"/>

                                        <Label
            Grid.Column="1"
            Text="▼"
            FontSize="14"
            TextColor="#D4AF37"
            VerticalOptions="Center"/>

                                    </Grid>

                                    <Label
        x:Name="PreviewTeam2PlayersLabel"
        Text="اختر فريق"
        FontSize="15"
        TextColor="#DDDDDD"/>

                                </VerticalStackLayout>
                            </Grid>

                        </Border>


                    </VerticalStackLayout>

                </Border>




                <!-- ========================= -->
                <!-- START BUTTON -->
                <!-- ========================= -->


                <Border
    Margin="0,0,0,20"
    BackgroundColor="Transparent"
    StrokeThickness="0"
                HorizontalOptions="Fill">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
            Tapped="OnStartGame"/>
                    </Border.GestureRecognizers>

                    <Image
        Source="startmatch_gold.png"
        Aspect="AspectFit"
        HorizontalOptions="Fill"
        VerticalOptions="Center"
        />

                </Border>
                <!-- ========================= -->
                <!-- PREMIUM ACTION BUTTONS -->
                <!-- ========================= -->

                <Grid
    ColumnDefinitions="*,*,*"
    ColumnSpacing="10"
    Margin="0,-35,0,0">

                    <!-- السجل -->

                    <Border
        Grid.Column="0"
        BackgroundColor="#080808"
        Stroke="#D4AF37"
        StrokeThickness="2.5">
                        <Border.Shadow>
                            <Shadow
        Brush="#D4AF37"
        Radius="10"
        Opacity="0.50"/>
                        </Border.Shadow>

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                Tapped="OnHistoryClicked"/>
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
            Padding="14"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="6">

                            <Image
                Source="history_gold.png"
                HeightRequest="70"
                WidthRequest="70"/>

                            <Label
                Text="السجل"
                FontSize="18"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="#FFD700"/>

                        </VerticalStackLayout>

                    </Border>

                    <!-- التصنيفات -->

                    <Border
        Grid.Column="1"
          BackgroundColor="#080808"
   Stroke="#D4AF37"
   StrokeThickness="2.5">
                        <Border.Shadow>
                            <Shadow
   Brush="#D4AF37"
   Radius="10"
   Opacity="0.50"/>
                        </Border.Shadow>

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                Tapped="OnRankingsClicked"/>
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
            Padding="14"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="6">

                            <Image
                Source="rankings_gold.png"
                HeightRequest="70"
                WidthRequest="70"/>

                            <Label
                Text="التصنيفات"
                FontSize="16"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="#FFD700"/>

                        </VerticalStackLayout>

                    </Border>

                    <!-- Hall Of Fame -->

                    <Border
        Grid.Column="2"
          BackgroundColor="#080808"
   Stroke="#D4AF37"
   StrokeThickness="2.5">
                        <Border.Shadow>
                            <Shadow
   Brush="#D4AF37"
   Radius="10"
   Opacity="0.50"/>
                        </Border.Shadow>

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                Tapped="OnHallOfFameClicked"/>
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
            Padding="14"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="6">

                            <Image
                Source="halloffame_gold.png"
                HeightRequest="70"
                WidthRequest="70"/>

                            <Label
                Text="Hall Of Fame"
                FontSize="14"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="#FFD700"/>

                        </VerticalStackLayout>

                    </Border>

                </Grid>

            </VerticalStackLayout>

        </ScrollView>


        <!-- TEAM PICKER OVERLAY -->

        <Grid
    x:Name="TeamPickerOverlay"
    IsVisible="False"
    BackgroundColor="#AA000000"
    ZIndex="999">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer
            Tapped="OnCloseTeamPicker"/>
            </Grid.GestureRecognizers>

            <Border
        VerticalOptions="End"
        HeightRequest="550"
        BackgroundColor="#080808"
        Stroke="#D4AF37"
        StrokeThickness="2">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30,30,0,0"/>
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <!-- Handle -->

                    <BoxView
                HeightRequest="5"
                WidthRequest="70"
                CornerRadius="3"
                Color="#666666"
                HorizontalOptions="Center"
                Margin="0,10"/>

                    <!-- Title -->

                    <Label
                Grid.Row="1"
                x:Name="PickerTitle"
                Text="اختر الفريق"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="Gold"
                HorizontalOptions="Center"
                Margin="0,10"/>

                    <!-- Search -->

                    <Border
                Grid.Row="2"
                Margin="20,10"
                Stroke="#444444"
                BackgroundColor="#111111"
                StrokeShape="RoundRectangle 18">

                        <Entry
                    x:Name="TeamPickerSearchEntry"
                    Placeholder="ابحث عن فريق..."
                    PlaceholderColor="#777777"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    TextChanged="OnTeamPickerSearchChanged"/>

                    </Border>

                    <!-- Teams -->

                    <CollectionView
                x:Name="TeamPickerCollection"
                Grid.Row="3"
                Margin="20,10"

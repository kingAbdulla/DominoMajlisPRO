                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="999"/>
                            </Border.StrokeShape>
                       
                            <Image
                                Source="vs_gold_icon.png"
                                WidthRequest="{OnIdiom Phone=72, Tablet=98}"
                                HeightRequest="{OnIdiom Phone=72, Tablet=98}"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                Aspect="AspectFit"/>
                        </Border>

                        <Border

<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    x:Class="DominoMajlisPRO.MainPage"
    BackgroundColor="#050505"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <ScrollView>

            <VerticalStackLayout
            Padding="18"
            Spacing="24">



                <!-- ========================= -->
                <!-- HERO SECTION -->
                <!-- ========================= -->

                <Border
                    Stroke="#D4AF37"
                    StrokeThickness="2"
                    BackgroundColor="#080808">
                    <Border.Padding>
                        <OnIdiom x:TypeArguments="Thickness"
                                 Phone="14"
                                 Tablet="24"/>
                    </Border.Padding>
                    <Border.Shadow>
                        <Shadow
                            Brush="#D4AF37"
                            Radius="8"
                            Opacity="0.28"/>
                    </Border.Shadow>

                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="38"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="{OnIdiom Phone=16, Tablet=22}">

                        <!-- RESPONSIVE THREE-ZONE HEADER -->
                        <Grid
                            x:Name="MainPlayerHeaderSurface"
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="{OnIdiom Phone=10, Tablet=22}"
                            Padding="{OnIdiom Phone=2, Tablet=8}">

                            <Grid
                                Grid.Column="0"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="{OnIdiom Phone=8, Tablet=12}"
                                HorizontalOptions="Fill"
                                VerticalOptions="Center">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnProfileTapped"/>
                                </Grid.GestureRecognizers>

                                <Image
                                    x:Name="HeaderProfileBackgroundImage"
                                    Grid.ColumnSpan="2"
                                    Aspect="AspectFill"
                                    Opacity="0.34"
                                    InputTransparent="True"
                                    IsVisible="False"/>
                                <Border
                                    Grid.Column="0"
                                    WidthRequest="{OnIdiom Phone=76, Tablet=96}"
                                    HeightRequest="{OnIdiom Phone=76, Tablet=96}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    BackgroundColor="#151515"
                                    Stroke="#D4AF37"
                                    StrokeThickness="2.4"
                                    StrokeShape="RoundRectangle 999">

                                    <Grid>
                                        <Image
                                            x:Name="HeaderPlayerAvatar"
                                            Source="normal_avatar_1.png"
                                            Aspect="AspectFill"/>

                                        <Image
                                            x:Name="HeaderAvatarFrameOverlay"
                                            Aspect="AspectFit"
                                            InputTransparent="True"
                                            IsVisible="False"/>

                                        <Image
                                            x:Name="HeaderAvatarEffectOverlay"
                                            Aspect="AspectFit"
                                            InputTransparent="True"
                                            IsVisible="False"/>

                                        <Border
                                            x:Name="ProfileStatusBadge"
                                            WidthRequest="{OnIdiom Phone=10, Tablet=12}"
                                            HeightRequest="{OnIdiom Phone=10, Tablet=12}"
                                            BackgroundColor="Red"
                                            Stroke="#111111"
                                            StrokeThickness="1"
                                            HorizontalOptions="End"
                                            VerticalOptions="End">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="999"/>
                                            </Border.StrokeShape>
                                        </Border>
                                    </Grid>
                                </Border><VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="1"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center">
                                    <Label
                                        x:Name="HeaderPlayerNameLabel"
                                        Text="اللاعب"
                                        FontSize="{OnIdiom Phone=11, Tablet=14}"
                                        FontAttributes="Bold"
                                        TextColor="#F5F5F5"
                                        HorizontalTextAlignment="Start"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"/>

                                    <Label
                                        x:Name="MemberLevelLabel"
                                        Text="Guest"
                                        FontSize="{OnIdiom Phone=9, Tablet=11}"
                                        TextColor="#C8B56A"
                                        HorizontalTextAlignment="Start"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"/>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="2"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                                <Grid
                                    WidthRequest="{OnIdiom Phone=36, Tablet=42}"
                                    HeightRequest="{OnIdiom Phone=36, Tablet=42}">
                                    <Image
                                        Source="settings_gold.png"
                                        WidthRequest="{OnIdiom Phone=28, Tablet=32}"
                                        HeightRequest="{OnIdiom Phone=28, Tablet=32}"
                                        Aspect="AspectFit">
                                    </Image>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSettingsImageTapped"/>
                                    </Grid.GestureRecognizers>
                                </Grid>
                                <Label
                                    Text="الإعدادات"
                                    FontSize="{OnIdiom Phone=9, Tablet=11}"
                                    TextColor="#C8B56A"
                                    HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>

                        </Grid>

                        <!-- CENTERED LOGO -->
                        <Border
                            HorizontalOptions="Center"
                            Stroke="Gold"
                            StrokeThickness="2"
                            BackgroundColor="#080808"
                            Padding="{OnIdiom Phone=22, Tablet=28}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="40"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Gold" Radius="12" Opacity="0.42"/>
                            </Border.Shadow>
                            <Image
                                Source="domino_gold_icon.png"
                                HeightRequest="{OnIdiom Phone=150, Tablet=185}"
                                WidthRequest="{OnIdiom Phone=150, Tablet=185}"
                                Aspect="AspectFit">
                                <Image.GestureRecognizers>
                                    <PointerGestureRecognizer
                                        PointerPressed="OnLogoPressed"
                                        PointerReleased="OnLogoReleased"/>
                                </Image.GestureRecognizers>
                            </Image>
                        </Border>

                        <Label
                            Text="DOMINO MAJLIS PRO"
                            FontFamily="CinzelDecorative-Bold"
                            FontSize="{OnIdiom Phone=22, Tablet=28}"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            TextColor="Gold"/>

                        <Label
                            Text="منصة احترافية لإدارة بطولات الدومينو"
                            FontFamily="DG-Nemr-V.0"
                            FontSize="{OnIdiom Phone=14, Tablet=18}"
                            HorizontalOptions="Fill"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            MaxLines="2"
                            TextColor="#BBBBBB"/>

                    </VerticalStackLayout>
                </Border>

                <!-- ========================= -->
                <!-- SEASON PREMIUM CARD -->
                <!-- ========================= -->

                <Border
                    Stroke="#D4AF37"
                    StrokeThickness="1.8"
                    BackgroundColor="#0A0A0A"
                    Padding="14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                        <Image Source="season_badge.png" WidthRequest="46" HeightRequest="46" Aspect="AspectFit"/>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="الموسم 1" FontSize="18" FontAttributes="Bold" TextColor="Gold"/>
                            <Label x:Name="SeasonRemainingLabel" Text="متبقي 30 يوم على نهاية الموسم" FontSize="12" TextColor="#CFCFCF"/>
                        </VerticalStackLayout>

                        <Label x:Name="SeasonProgressLabel" Grid.Column="2" Text="5%" FontSize="20" FontAttributes="Bold" TextColor="Gold" VerticalOptions="Center"/>

                        <ProgressBar
                            x:Name="MainSeasonProgressBar"
                            Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="0,8,0,0"
                            HeightRequest="12"
                            Progress="0.05"
                            ProgressColor="Gold"
                            BackgroundColor="#2A2A2A"/>
                    </Grid>
                </Border>

                <!-- ========================= -->
                <!-- QUICK ACTIONS -->
                <!-- ========================= -->

                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="10">

                    <Border Grid.Column="0" Stroke="#D4AF37" StrokeThickness="1.4" BackgroundColor="#0B0B0B" Padding="12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="المتجر" TextColor="Gold" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Image Grid.Column="1" Source="store_icon.png" WidthRequest="36" HeightRequest="36"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStoreTapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Column="1" Stroke="#D4AF37" StrokeThickness="1.4" BackgroundColor="#0B0B0B" Padding="12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="RankBadgeLabel" Text="عالمي" TextColor="Gold" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Image x:Name="RankBadgeImage" Grid.Column="1" Source="rank_legend_badge.png" WidthRequest="36" HeightRequest="36"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRankBadgeTapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Column="2" Stroke="#D4AF37" StrokeThickness="1.4" BackgroundColor="#0B0B0B" Padding="8" WidthRequest="54">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Image Source="history_icon.png" WidthRequest="34" HeightRequest="34"/>
                    </Border>
                </Grid>

                <!-- CREATE TEAM -->

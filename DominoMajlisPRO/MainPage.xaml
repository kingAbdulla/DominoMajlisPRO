<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    xmlns:galleryComponents="clr-namespace:DominoMajlisPRO.GalleryEngine.Components"
    x:Class="DominoMajlisPRO.MainPage"
    BackgroundColor="#050505"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <ScrollView x:Name="MainPageScroll">

            <VerticalStackLayout
            Padding="18"
            Spacing="20">

                <!-- ========================= -->
                <!-- AAA COMPACT TOP BAR -->
                <!-- ========================= -->

                <Grid
                    ColumnDefinitions="*,*,Auto,Auto"
                    ColumnSpacing="{OnIdiom Phone=6, Tablet=10}"
                    FlowDirection="LeftToRight"
                    VerticalOptions="Center">

              

                    <Border
                        Grid.Column="0"
                        Stroke="#8D6824"
                        StrokeThickness="1.2"
                        BackgroundColor="#080808"
                        Padding="2"
                        MinimumWidthRequest="{OnIdiom Phone=106, Tablet=150}"
                        HeightRequest="{OnIdiom Phone=50, Tablet=55}"
                        StrokeShape="RoundRectangle 18">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4">
                            <Image Source="coins.png" WidthRequest="25" HeightRequest="25"/>
                            <Label
                                x:Name="HeaderCoinsLabel"
                                Grid.Column="1"
                                Text="0"
                                FontSize="{OnIdiom Phone=10, Tablet=15}"
                                TextColor="White"
                                FontAttributes="Bold"
                                VerticalTextAlignment="Center"
                                LineBreakMode="TailTruncation"/>
                            <Label
    x:Name="getcoins"
    Grid.Column="2"
    Text="+"
    FontSize="{OnIdiom Phone=18, Tablet=25}"
    TextColor="#8D6824"
    FontAttributes="Bold"
    VerticalTextAlignment="Center"
    LineBreakMode="TailTruncation">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="GetCoins_Tapped"/>
                                </Label.GestureRecognizers>

                            </Label>


                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Stroke="#8D6824"
                        StrokeThickness="1.2"
                        BackgroundColor="#080808"
                        MinimumWidthRequest="{OnIdiom Phone=106, Tablet=150}"
                        HeightRequest="{OnIdiom Phone=50, Tablet=55}"
                        Padding="2"
                        StrokeShape="RoundRectangle 18">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                            <Image Source="gems.png" WidthRequest="25" HeightRequest="25"/>
                            <Label
                                x:Name="HeaderGemsLabel"
                                Grid.Column="1"
                                Text="0"
                                FontSize="{OnIdiom Phone=10, Tablet=15}"
                                TextColor="White"
                                FontAttributes="Bold"
                                VerticalTextAlignment="Center"
                                LineBreakMode="TailTruncation"/>
                            <Label
x:Name="getGems"
Grid.Column="2"
Text="+"
FontSize="{OnIdiom Phone=18, Tablet=25}"
TextColor="#8D6824"
FontAttributes="Bold"
VerticalTextAlignment="Center"
LineBreakMode="TailTruncation">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="GetGems_Tapped"/>
                                </Label.GestureRecognizers>

                            </Label>

                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="2"
                        WidthRequest="{OnIdiom Phone=76, Tablet=98}"
                        HeightRequest="{OnIdiom Phone=76, Tablet=98}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 0">

                        <Grid
    Grid.Column="2"
    WidthRequest="{OnIdiom Phone=64, Tablet=84}"
    HeightRequest="{OnIdiom Phone=64, Tablet=84}"
    HorizontalOptions="Center"
    VerticalOptions="Center">

                            <Border
        WidthRequest="{OnIdiom Phone=50, Tablet=70}"
        HeightRequest="{OnIdiom Phone=50, Tablet=70}"
        HorizontalOptions="Center"
        VerticalOptions="Center"
        BackgroundColor="#080808"
        Stroke="#D4AF37"
        StrokeThickness="1.2"
        StrokeShape="RoundRectangle 999">

                              

                                <Grid>
                                    <Image
                x:Name="HeaderPlayerAvatar"
                Source="normal_avatar_1.png"
                Aspect="AspectFill"/>

                                    <Image
                x:Name="HeaderAvatarFrameOverlay"
                Aspect="AspectFit"
                InputTransparent="True"
                IsVisible="False"/>

                                    <Image
                x:Name="HeaderAvatarEffectOverlay"
                Aspect="AspectFit"
                InputTransparent="True"
                IsVisible="False"/>


                                </Grid>
                            </Border>

                            <!-- Level Badge -->
                            <Border
        x:Name="HeaderPlayerLevelBadge"
        WidthRequest="{OnIdiom Phone=24, Tablet=30}"
        HeightRequest="{OnIdiom Phone=24, Tablet=30}"
        HorizontalOptions="Start"
        VerticalOptions="End"
        Margin="{OnIdiom Phone='3,0,0,3', Tablet='3,0,0,3'}"
        BackgroundColor="#080808"
        Stroke="#D4AF37"
        StrokeThickness="2"
        StrokeShape="RoundRectangle 999"
        ZIndex="99"
        InputTransparent="True">

                                <Label
            x:Name="HeaderPlayerLevelLabel"
            Text="1"
            FontSize="{OnIdiom Phone=11, Tablet=14}"
            FontAttributes="Bold"
            TextColor="#FFD700"
            HorizontalTextAlignment="Center"
            VerticalTextAlignment="Center"/>
                            </Border>

                            <!-- Status Dot -->
                            <Border
        x:Name="ProfileStatusBadge"
        WidthRequest="{OnIdiom Phone=9, Tablet=12}"
        HeightRequest="{OnIdiom Phone=9, Tablet=12}"
        BackgroundColor="Red"
        Stroke="#080808"
        StrokeThickness="1"
        HorizontalOptions="End"
        VerticalOptions="Start"
        StrokeShape="RoundRectangle 999"/>
                        </Grid>
                        
                        
                    </Border>

                    <Border
                        Grid.Column="3"
                        WidthRequest="{OnIdiom Phone=50, Tablet=50}"
                        HeightRequest="{OnIdiom Phone=50, Tablet=50}"
                        Stroke="#080808"
                        StrokeThickness="1.4"
                        BackgroundColor="#080808"
                        StrokeShape="RoundRectangle 18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsImageTapped"/>
                        </Border.GestureRecognizers>
                        <Grid>
                            <Image Source="settings_gold.png" WidthRequest="32" HeightRequest="32"/>
                         
                        </Grid>
                    </Border>
                </Grid>



                <!-- ========================= -->
                <!-- HERO SECTION -->
                <!-- ========================= -->

                <Border
                    Stroke="#D4AF37"
                    StrokeThickness="2"
                    BackgroundColor="#080808"
                    HeightRequest="{OnIdiom Phone=250, Tablet=300}"
                    VerticalOptions="Start">
                    <Border.Padding>
                        <OnIdiom x:TypeArguments="Thickness"
                                 Phone="14"
                                 Tablet="24"/>
                    </Border.Padding>
                    <Border.Shadow>
                        <Shadow
                            Brush="#D4AF37"
                            Radius="8"
                            Opacity="0.28"/>
                    </Border.Shadow>

                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="38"/>
                    </Border.StrokeShape>

                    <Grid RowDefinitions="*" ColumnDefinitions="0.36*,0.64*" FlowDirection="LeftToRight">
                        <Image
                            x:Name="MainSeasonHeroBackgroundImage"
                            Grid.ColumnSpan="2"
                            Aspect="AspectFill"
                            Opacity="0.58"
                            InputTransparent="True"/>

                        <BoxView
                            Grid.ColumnSpan="2"
                            InputTransparent="True">
                            <BoxView.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F2000000" Offset="0"/>
                                    <GradientStop Color="#A8000000" Offset="0.42"/>
                                    <GradientStop Color="#E8000000" Offset="1"/>
                                </LinearGradientBrush>
                            </BoxView.Background>
                        </BoxView>

                        <Grid
                            Grid.Column="0"
                            Padding="{OnIdiom Phone=0, Tablet=6}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <Image
                                Source="domino_gold_icon.png"
                                WidthRequest="{OnIdiom Phone=128, Tablet=170}"
                                HeightRequest="{OnIdiom Phone=128, Tablet=170}"
                                Aspect="AspectFit">
                                <Image.GestureRecognizers>
                                    <PointerGestureRecognizer
                                        PointerPressed="OnLogoPressed"
                                        PointerReleased="OnLogoReleased"/>
                                </Image.GestureRecognizers>
                            </Image>
                        </Grid>

                        <Grid
                            Grid.Column="1"
                            RowDefinitions="Auto,*"
                            Padding="{OnIdiom Phone='8,4,6,4', Tablet='16,10,10,10'}"
                            RowSpacing="{OnIdiom Phone=6, Tablet=10}"
                            VerticalOptions="Center">

                            <Grid
                                x:Name="MainPlayerHeaderSurface"
                                ColumnDefinitions="*"
                                ColumnSpacing="{OnIdiom Phone=9, Tablet=14}">

                                <Image
                                    x:Name="HeaderProfileBackgroundImage"
                                    Aspect="AspectFill"
                                    Opacity="0.12"
                                    InputTransparent="True"
                                    IsVisible="False"/>

                                <VerticalStackLayout
                                    Spacing="0"
                                    VerticalOptions="Center">
                                    <Label
                                        Text="مرحباً بك"
                                        FontFamily="DG-Nemr-V.0"
                                        FontSize="{OnIdiom Phone=20, Tablet=40}"
                                        FontAttributes="Bold"
                                        TextColor="#F3F3F3"
                                        MaxLines="1"/>
                                    <Label
                                        x:Name="HeaderPlayerNameLabel"
                                        Text="اللاعب"
                                        FontSize="{OnIdiom Phone=20, Tablet=30}"
                                        FontAttributes="Bold"
                                        TextColor="#FFD700"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"/>
                                    <Label
                                        x:Name="MemberLevelLabel"
                                        Text="Guest"
                                        FontSize="{OnIdiom Phone=12, Tablet=17}"
                                        TextColor="#DDDDDD"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"/>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout
                                Grid.Row="1"
                                Spacing="{OnIdiom Phone=8, Tablet=12}"
                                VerticalOptions="Center">
                                <Border
                                    HorizontalOptions="Start"
                                    Stroke="#6C5522"
                                    StrokeThickness="1"
                                    BackgroundColor="#64000000"
                                    Padding="{OnIdiom Phone='12,5', Tablet='16,7'}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="999"/>
                                    </Border.StrokeShape>
                                    <HorizontalStackLayout Spacing="8">
                                        <Image
                                            Source="crown_3d.png"
                                            WidthRequest="{OnIdiom Phone=20, Tablet=26}"
                                            HeightRequest="{OnIdiom Phone=20, Tablet=26}"
                                            Aspect="AspectFit"/>
                                        <Label
                                            x:Name="HeroRankLabel"
                                            Text="Majlis Legend"
                                            FontSize="{OnIdiom Phone=13, Tablet=17}"
                                            TextColor="#F6F0DE"
                                            VerticalTextAlignment="Center"
                                            MaxLines="1"/>
                                    </HorizontalStackLayout>
                                </Border>

                                <VerticalStackLayout Spacing="4" WidthRequest="{OnIdiom Phone=175, Tablet=330}" HorizontalOptions="Start">
                                    <HorizontalStackLayout Spacing="7">
                                        <Label
                                            Text="XP"
                                            FontSize="{OnIdiom Phone=19, Tablet=25}"
                                            FontAttributes="Bold"
                                            TextColor="#D5A131"/>
                                        <Label
                                            x:Name="HeroXpLabel"
                                            Text="0 / 100"
                                            FontSize="{OnIdiom Phone=17, Tablet=23}"
                                            TextColor="#F2F2F2"
                                            MaxLines="1"/>
                                        <Label
                                            x:Name="HeroXpPercentLabel"
                                            Text="0%"
                                            FontSize="{OnIdiom Phone=14, Tablet=18}"
                                            TextColor="#8F8F8F"
                                            MaxLines="1"/>
                                    </HorizontalStackLayout>
                                    <ProgressBar
                                        x:Name="HeroXpProgressBar"
                                        Progress="0"
                                        HeightRequest="7"
                                        ProgressColor="#FFD700"
                                        BackgroundColor="#2A2A2A"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ========================= -->
                <!-- SEASON PREMIUM CARD -->
                <!-- ========================= -->

                <Border
    x:Name="SeasonCard"
    IsVisible="False"
    Margin="0,-10,0,-8"
    Stroke="#D4AF37"
    StrokeThickness="2"
    BackgroundColor="#080808"
    Padding="14">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow
            Brush="#D4AF37"
            Radius="10"
            Opacity="0.45"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <Image
                Source="xp_gold.png"
                WidthRequest="44"
                HeightRequest="44"
                VerticalOptions="Center"/>

                            <VerticalStackLayout
                Grid.Column="1"
                Margin="12,0"
                Spacing="2"
                VerticalOptions="Center">

                                <Label
                    x:Name="MainSeasonTitleLabel"
                    Text="XP اللاعب"
                    FontSize="{OnIdiom Phone=17, Tablet=22}"
                    FontAttributes="Bold"
                    TextColor="#FFD700"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"/>

                                <Label
                    x:Name="MainSeasonCountdownLabel"
                    Text="0 / 0"
                    FontSize="{OnIdiom Phone=13, Tablet=17}"
                    TextColor="#DDDDDD"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"/>

                            </VerticalStackLayout>

                            <Label
                x:Name="MainSeasonProgressPercentLabel"
                Grid.Column="2"
                Text="0%"
                FontSize="{OnIdiom Phone=18, Tablet=24}"
                FontAttributes="Bold"
                TextColor="#FFD700"
                VerticalTextAlignment="Center"/>

                        </Grid>

                        <ProgressBar
            x:Name="MainSeasonProgressBar"
            Progress="0"
            HeightRequest="9"
            ProgressColor="#FFD700"
            BackgroundColor="#2A2A2A"/>

                    </VerticalStackLayout>

                </Border>


                <!-- ========================= -->
                <!-- TEAM SELECTION -->
                <!-- ========================= -->

                <Grid
                Margin="0,-15"
                IsVisible="False"
    ColumnDefinitions="*">




                    <!-- القوانين -->

                    <Border
                    HorizontalOptions="Fill"
 
      Stroke="#D4AF37"
  StrokeThickness="2"
  BackgroundColor="#080808"
  Padding="12">


                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>

                        </Border.StrokeShape>


                        <Grid
                            ColumnDefinitions="*"
                            ColumnSpacing="0"
                            FlowDirection="RightToLeft">

                            <Grid
                                Grid.Column="0"
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="8"
                                Padding="8,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRulesCardTapped"/>
                                </Grid.GestureRecognizers>

                                <Image
                                    Source="rules_gold.png"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    VerticalOptions="Center"/>

                                <Label
                                    Grid.Column="1"
                                    x:Name="PreviewRulesLabel"
                                    Text="عالمي"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#D4AF37"
                                    VerticalOptions="Center"
                                    HorizontalTextAlignment="Center"/>

                                <Label
                                    Grid.Column="2"
                                    Text="▼"
                                    FontSize="12"
                                    TextColor="#D4AF37"
                                    VerticalOptions="Center"/>
                            </Grid>

                            <Grid
                                Grid.Column="1"
                                IsVisible="False"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="8"
                                Padding="12,0"
                                BackgroundColor="#080808">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStoreTapped"/>
                                </Grid.GestureRecognizers>

                                <Image
                                    Source="shop_gold.png"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Aspect="AspectFit"
                                    VerticalOptions="Center"/>

                                <Label
                                    Grid.Column="1"
                                    Text="المتجر"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#D4AF37"
                                    VerticalOptions="Center"
                                    HorizontalTextAlignment="Center"/>
                            </Grid>
                        </Grid>

                    </Border>

                </Grid>

                <!--Rulls -->
                <Border
x:Name="RulesDropdownBorder"
IsVisible="False"
Stroke="#D4AF37"
StrokeThickness="2"
BackgroundColor="#080808"
Padding="10"
Margin="0,5,0,0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">

                        <Label
        Text="محلي"
        FontSize="20"
        TextColor="#D4AF37">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                Tapped="OnLocalRuleTapped"/>
                            </Label.GestureRecognizers>

                        </Label>

                        <BoxView
        HeightRequest="1"
        Color="#333333"/>

                        <Label
        Text="عالمي"
        FontSize="20"
        TextColor="#D4AF37">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                Tapped="OnInternationalRuleTapped"/>
                            </Label.GestureRecognizers>

                        </Label>

                    </VerticalStackLayout>

                </Border>




                <!---Creat New Team-->
                <Border
    IsVisible="False"
    Stroke="#D4AF37"
    StrokeThickness="2"
    BackgroundColor="#080808"
    Padding="12">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow
            Brush="#D4AF37"
            Radius="10"
            Opacity="0.45"/>
                    </Border.Shadow>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
            Tapped="OnCreateTeamClicked"/>
                    </Border.GestureRecognizers>

                    <Grid
        ColumnDefinitions="100,*,0"
        FlowDirection="RightToLeft">

                        <Image
            Source="addteam_logo.png"
            WidthRequest="60"
            HeightRequest="60"
            VerticalOptions="Center"/>

                        <VerticalStackLayout
    Grid.Column="1"
    Spacing="2"
    VerticalOptions="Center">

                            <Label
        Text=" + إنشاء فريق جديد"
        FontSize="20"
        FontAttributes="Bold"
        TextColor="#D4AF37"/>

                            <Label
        Text="إضافة فريق جديد للمجلس"
        FontSize="14"
        TextColor="#AAAAAA"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>

                <!-- ========================= -->
                <!-- REFERENCE MATCH PREVIEW -->
                <!-- ========================= -->

                <VerticalStackLayout Spacing="{OnIdiom Phone=8, Tablet=12}" Margin="0,-8,0,0">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <BoxView
                            WidthRequest="{OnIdiom Phone=76, Tablet=130}"
                            HeightRequest="1"
                            Color="#6A4B17"
                            VerticalOptions="Center"/>
                        <Label
                            Text="مواجهة اليوم"
                            FontFamily="DG-Nemr-V.0"
                            FontSize="{OnIdiom Phone=22, Tablet=30}"
                            FontAttributes="Bold"
                            VerticalTextAlignment="Center"
                            TextColor="#D8A342"/>
                        <BoxView
                            WidthRequest="{OnIdiom Phone=76, Tablet=130}"
                            HeightRequest="1"
                            Color="#6A4B17"
                            VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    
                    
                    <Grid
                        ColumnDefinitions="*,Auto,*"
                        ColumnSpacing="{OnIdiom Phone=-12, Tablet=-6}"
                        HorizontalOptions="Fill">

                        <Border
                            Grid.Column="0"
                            x:Name="RefTeam1CardBorder"
                            HeightRequest="{OnIdiom Phone=305, Tablet=390}"
                            Stroke="#FFD700"
                            StrokeThickness="1.8"
                            BackgroundColor="#080808"
                            Padding="{OnIdiom Phone=10, Tablet=16}">
                            <Border.Shadow>
                                <Shadow Brush="#D4AF37" Radius="10" Opacity="0.40"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTeam1CardTapped"/>
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24"/>
                            </Border.StrokeShape>
                            <Grid RowDefinitions="*,Auto,Auto,Auto,Auto" RowSpacing="{OnIdiom Phone=5, Tablet=8}">
                                <Grid
                                    WidthRequest="{OnIdiom Phone=145, Tablet=210}"
                                    HeightRequest="{OnIdiom Phone=145, Tablet=210}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                    <Border
                                        x:Name="RefTeam1EmblemBackgroundLayer"
                                        BackgroundColor="Transparent"
                                        StrokeThickness="0"
                                        Opacity="0.95">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="28"/>
                                        </Border.StrokeShape>
                                    </Border>
                                    <Image
                                        x:Name="RefTeam1EmblemBackgroundImage"
                                        Aspect="AspectFill"
                                        Opacity="0.55"
                                        IsVisible="False"
                                        InputTransparent="True"/>
                                    <Image
                                        x:Name="RefPreviewTeam1Logo"
                                        WidthRequest="{OnIdiom Phone=140, Tablet=200}"
                                        HeightRequest="{OnIdiom Phone=140, Tablet=200}"
                                        Aspect="AspectFit"/>
                                </Grid>
                                <Label
                                    Grid.Row="1"
                                    x:Name="RefPreviewTeam1NameLabel"
                                    Text="الفريق الأول"
                                    FontSize="{OnIdiom Phone=25, Tablet=34}"
                                    FontAttributes="Bold"
                                    TextColor="#FFD700"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    HorizontalTextAlignment="Center"/>
                                <Label
                                    Grid.Row="2"
                                    x:Name="RefPreviewTeam1PlayersLabel"
                                    Text="اختر فريق"
                                    FontSize="{OnIdiom Phone=15, Tablet=20}"
                                    TextColor="#DDDDDD"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    HorizontalTextAlignment="Center"/>
                                <HorizontalStackLayout
                                    Grid.Row="3"
                                    x:Name="RefTeam1PlayerAvatarsHost"
                                    Spacing="-6"
                                    HorizontalOptions="Center">
                                    <Border
                                        x:Name="RefTeam1Player1AvatarFrame"
                                        IsVisible="False"
                                        WidthRequest="{OnIdiom Phone=30, Tablet=40}"
                                        HeightRequest="{OnIdiom Phone=30, Tablet=40}"
                                        Stroke="#D4AF37"
                                        StrokeThickness="1.2"
                                        BackgroundColor="#111111"
                                        StrokeShape="RoundRectangle 999">
                                        <Image
                                            x:Name="RefTeam1Player1AvatarImage"
                                            Source="normal_avatar_1.png"
                                            Aspect="AspectFill"/>
                                    </Border>
                                    <Border
                                        x:Name="RefTeam1Player2AvatarFrame"
                                        IsVisible="False"
                                        WidthRequest="{OnIdiom Phone=30, Tablet=40}"
                                        HeightRequest="{OnIdiom Phone=30, Tablet=40}"
                                        Stroke="#D4AF37"
                                        StrokeThickness="1.2"
                                        BackgroundColor="#111111"
                                        StrokeShape="RoundRectangle 999">
                                        <Image
                                            x:Name="RefTeam1Player2AvatarImage"
                                            Source="normal_avatar_1.png"
                                            Aspect="AspectFill"/>
                                    </Border>
                                </HorizontalStackLayout>
                                <Grid
                                    Grid.Row="4"
                                    ColumnDefinitions="*,Auto"
                                    Padding="{OnIdiom Phone='8,8,8,0', Tablet='12,12,12,0'}">
                                    <Label
                                        Text="اختيار الفريق"
                                        FontFamily="DG-Nemr-V.0"
                                        FontSize="{OnIdiom Phone=17, Tablet=22}"

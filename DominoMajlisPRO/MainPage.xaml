                            x:Name="RefTeam2CardBorder"
                            HeightRequest="{OnIdiom Phone=305, Tablet=390}"
                            Stroke="#A953FF"
                            StrokeThickness="1.8"
                            BackgroundColor="#080808"
                            Padding="{OnIdiom Phone=10, Tablet=16}">
                            <Border.Shadow>
                                <Shadow Brush="#A953FF" Radius="10" Opacity="0.40"/>
                            </Border.Shadow>

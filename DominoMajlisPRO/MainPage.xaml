        BackgroundColor="#111111"
        Stroke="#D4AF37"
        StrokeThickness="2"
        Padding="18"
        StrokeShape="RoundRectangle 28,28,0,0">

                <ScrollView>
                    <VerticalStackLayout Spacing="14">

                        <Label
                    Text="قفل المطور"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="Gold"
                    HorizontalTextAlignment="Center"/>

                        <Label
                    x:Name="DeveloperLockStatusLabel"
                    Text="الحالة: غير مفعّل"
                    TextColor="White"
                    FontSize="15"
                    HorizontalTextAlignment="Center"/>

                        <Label
                    x:Name="DeveloperLockLastChangeLabel"
                    Text="آخر تغيير: —"
                    TextColor="#AAAAAA"
                    FontSize="13"
                    HorizontalTextAlignment="Center"/>

                        <Entry
                    x:Name="DeveloperPasswordEntry"
                    Placeholder="كلمة مرور المطور"
                    PlaceholderColor="#777777"
                    TextColor="White"
                    IsPassword="True"
                    BackgroundColor="Transparent"/>

                        <Entry
                    x:Name="DeveloperConfirmPasswordEntry"
                    Placeholder="تأكيد كلمة المرور"
                    PlaceholderColor="#777777"
                    TextColor="White"
                    IsPassword="True"
                    BackgroundColor="Transparent"/>

                        <Button
                    Text="حفظ كلمة مرور المطور"
                    BackgroundColor="#D4AF37"
                    TextColor="Black"
                    FontAttributes="Bold"
                    Clicked="OnSaveDeveloperPasswordClicked"/>

                        <Button
                    Text="اختبار كلمة المرور"
                    BackgroundColor="#1A1A1A"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="OnTestDeveloperPasswordClicked"/>

                    </VerticalStackLayout>
                </ScrollView>

            </Border>
        </Grid>
        <!-- HONOR ACTIVATION OVERLAY -->

        <Grid
    x:Name="HonorActivationOverlay"
    IsVisible="False"
    BackgroundColor="#80000000"
    ZIndex="1007">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer
            Tapped="OnCloseHonorActivation"/>
            </Grid.GestureRecognizers>

            <Border
        x:Name="HonorActivationSheet"
        VerticalOptions="End"
        HorizontalOptions="Fill"
        Margin="14,0,14,0"
        BackgroundColor="#111111"
        Stroke="#D4AF37"
        StrokeThickness="2"
        Padding="18"
        StrokeShape="RoundRectangle 28,28,0,0">

                <VerticalStackLayout Spacing="14">

                    <Label
                Text="تفعيل قاعة الشرف"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="Gold"
                HorizontalTextAlignment="Center"/>

                    <Label
                Text="أدخل الاسم أو ID، ثم مفتاح التفعيل. سيحدد التطبيق نوع الصلاحية تلقائياً."
                FontSize="14"
                TextColor="White"
                HorizontalTextAlignment="End"/>
                    <Label
    x:Name="CurrentHonorRoleLabel"
    Text="الحالة الحالية: مستخدم عادي"
    FontSize="14"
    TextColor="#CCCCCC"
    HorizontalTextAlignment="Center"/>

                    <Entry
                x:Name="HonorDisplayNameEntry"
                Placeholder="الاسم أو ID"
                PlaceholderColor="#777777"
                TextColor="White"
                BackgroundColor="Transparent"/>

                    <Entry
                x:Name="HonorActivationKeyEntry"
                Placeholder="مفتاح التفعيل"
                PlaceholderColor="#777777"
                TextColor="White"
                BackgroundColor="Transparent"/>

                    <Button
                Text="تفعيل"
                BackgroundColor="#D4AF37"
                TextColor="Black"
                FontAttributes="Bold"
                Clicked="OnActivateHonorClicked"/>
                    <Button
    x:Name="DebugClearHonorIdentityButton"
    Text="تصفير هوية الشرف فقط"
    BackgroundColor="#7A1F1F"
    TextColor="White"
    FontAttributes="Bold"
    Clicked="OnDebugClearHonorIdentityClicked"/>

                </VerticalStackLayout>

            </Border>
        </Grid>
    </Grid>
</ContentPage>

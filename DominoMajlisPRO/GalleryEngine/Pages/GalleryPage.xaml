<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DominoMajlisPRO.GalleryEngine.Pages.GalleryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sections="clr-namespace:DominoMajlisPRO.GalleryEngine.Components.StoreSections"
    BackgroundColor="#030303"
    NavigationPage.HasNavigationBar="False"
    FlowDirection="RightToLeft">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0"
                    VerticalScrollBarVisibility="Never">

            <VerticalStackLayout
                Padding="12,12,12,108"
                Spacing="12">

                <Button
                    x:Name="StoreBackButton"
                    Text="‹"
                    Clicked="OnBackClicked"
                    FontFamily="Tajawal-Regular"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="#FFD76A"
                    BackgroundColor="#15120D"
                    BorderColor="#B98A3A"
                    BorderWidth="1"
                    CornerRadius="16"
                    WidthRequest="48"
                    HeightRequest="44"
                    HorizontalOptions="Start" />

                <sections:PremiumStoreHeaderView
                    x:Name="StoreHeader"
                    SeasonSwitchRequested="OnSeasonSwitchRequested"
                    CoinsRequested="OnCoinsRequested"
                    GemsRequested="OnGemsRequested"
                    IdentityRequested="OnIdentityRequested" />

                <VerticalStackLayout
                    x:Name="HomeTopContent"
                    Spacing="12">
                    <sections:HeroSliderView
                        x:Name="HeroSlider" />

                    <Border
                        x:Name="SeasonEmptyCard"
                        IsVisible="False"
                        Padding="20"
                        Background="#15120D"
                        Stroke="#B98A3A"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Label
                            x:Name="SeasonEmptyLabel"
                            Text="لم يتم نشر موسم حالياً"
                            FontFamily="Tajawal-Regular"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#E7C979"
                            HorizontalTextAlignment="Center" />
                    </Border>

                    <sections:QuickActionsView
                        x:Name="QuickActions"
                        ActionRequested="OnQuickActionRequested" />
                </VerticalStackLayout>

                <sections:CategoriesSectionView
                    x:Name="CategoriesSection"
                    CategorySelected="OnCategorySelected"
                    ShowAllRequested="OnBrowseCategoriesShowAllRequested" />

                <VerticalStackLayout
                    x:Name="HomeContent"
                    Spacing="12">
                    <sections:NewArrivalsSectionView
                        x:Name="NewArrivalsSection"
                        ShowAllRequested="OnNewArrivalsShowAllRequested" />

                    <sections:LimitedOffersSectionView
                        x:Name="LimitedOffersSection"
                        ShowAllRequested="OnLimitedOffersShowAllRequested" />

                    <sections:BrowseCategoriesSectionView
                        x:Name="BrowseCategoriesSection"
                        ShowAllRequested="OnBrowseCategoriesShowAllRequested"
                        CategorySelected="OnBrowseCategorySelected" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    x:Name="SectionContentRoot"
                    IsVisible="False"
                    Opacity="0"
                    Spacing="12">

                    <ContentView x:Name="SelectedSectionHost" />

                    <Border
                        x:Name="SectionMessageCard"
                        IsVisible="False"
                        Padding="20"
                        Background="#15120D"
                        Stroke="#B98A3A"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Label
                            x:Name="SectionMessageLabel"
                            FontFamily="Tajawal-Regular"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#E7C979"
                            HorizontalTextAlignment="Center" />
                    </Border>

                    <Button
                        x:Name="ShowMoreButton"
                        IsVisible="False"
                        Text="عرض المزيد"
                        Clicked="OnShowMoreClicked"
                        FontFamily="Tajawal-Regular"
                        FontAttributes="Bold"
                        TextColor="#E7C979"
                        BackgroundColor="#15120D"
                        BorderColor="#B98A3A"
                        BorderWidth="1"
                        CornerRadius="16"
                        HeightRequest="44" />
                </VerticalStackLayout>

                <sections:StoreFooterView />

            </VerticalStackLayout>

        </ScrollView>

        <sections:StoreBottomNavigationView
            x:Name="BottomNavigation"
            TabRequested="OnBottomTabRequested"
            Grid.Row="1" />

    </Grid>

</ContentPage>

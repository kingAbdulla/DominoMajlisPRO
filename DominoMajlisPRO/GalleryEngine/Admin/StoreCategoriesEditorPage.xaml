<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="DominoMajlisPRO.GalleryEngine.Admin.StoreCategoriesEditorPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#030303" NavigationPage.HasNavigationBar="False" FlowDirection="RightToLeft">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="16,18,16,28" Spacing="14">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Button Text="‹" Clicked="OnCancelClicked" />
                    <VerticalStackLayout Grid.Column="1">
                        <Label x:Name="TitleLabel" Text="إدارة تصنيفات المتجر" FontSize="25" FontAttributes="Bold" HorizontalTextAlignment="End" />
                        <Label x:Name="SubtitleLabel" Text="Category • Collection • Season" FontSize="12" HorizontalTextAlignment="End" />
                    </VerticalStackLayout>
                </Grid>
                <Border x:Name="ModeCard" Padding="12" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <BoxView x:Name="ModeDot" WidthRequest="12" HeightRequest="12" CornerRadius="6" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1"><Label x:Name="ModeTitleLabel" FontAttributes="Bold" HorizontalTextAlignment="End" /><Label x:Name="ModeSubtitleLabel" FontSize="11" HorizontalTextAlignment="End" /></VerticalStackLayout>
                    </Grid>
                </Border>
                <Border x:Name="FormPanel" Padding="12" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Entry x:Name="NameArEntry" Placeholder="الاسم بالعربية" />
                        <Entry x:Name="NameEnEntry" Placeholder="English name" />
                        <Editor x:Name="DescriptionEditor" Placeholder="الوصف" HeightRequest="76" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"><Entry x:Name="IconPathEntry" Placeholder="الأيقونة" IsReadOnly="True" /><Button Grid.Column="1" Text="اختيار أيقونة" Clicked="OnPickIconClicked" /></Grid>
                        <Image x:Name="IconPreview" HeightRequest="80" Aspect="AspectFit" IsVisible="False" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"><Entry x:Name="BannerPathEntry" Placeholder="صورة الغلاف" IsReadOnly="True" /><Button Grid.Column="1" Text="اختيار غلاف" Clicked="OnPickBannerClicked" /></Grid>
                        <Image x:Name="BannerPreview" HeightRequest="120" Aspect="AspectFill" IsVisible="False" />
                        <Picker x:Name="AccentColorPicker" Title="لون التمييز" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Picker x:Name="CategoryPicker" Title="Asset Type / Category" />
                            <Picker x:Name="CollectionPicker" Grid.Column="1" Title="Collection" />
                        </Grid>
                        <Picker x:Name="SeasonPicker" Title="Season (اختياري)" />
                        <Entry x:Name="DisplayOrderEntry" Placeholder="ترتيب العرض" Keyboard="Numeric" />
                        <Grid ColumnDefinitions="*,*"><HorizontalStackLayout Spacing="8"><Label x:Name="VisibleLabel" Text="ظاهر" /><Switch x:Name="VisibleSwitch" /></HorizontalStackLayout><HorizontalStackLayout Grid.Column="1" Spacing="8"><Label x:Name="FeaturedLabel" Text="مميز" /><Switch x:Name="FeaturedSwitch" /></HorizontalStackLayout></Grid>
                        <Picker x:Name="StatusPicker" Title="الحالة" IsEnabled="False" />
                        <Label x:Name="ValidationLabel" IsVisible="False" TextColor="#D84A4A" HorizontalTextAlignment="End" />
                    </VerticalStackLayout>
                </Border>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                    <Button x:Name="SaveDraftButton" Text="حفظ كمسودة" Clicked="OnSaveDraftClicked" /><Button x:Name="PublishButton" Grid.Column="1" Text="نشر" Clicked="OnPublishClicked" />
                    <Button Grid.Row="1" Text="إلغاء" Clicked="OnCancelClicked" /><Button Grid.Row="1" Grid.Column="1" Text="المسودات" Clicked="OnDraftsClicked" />
                    <Button Grid.Row="2" Grid.ColumnSpan="2" Text="التصنيفات المنشورة" Clicked="OnPublishedClicked" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
        <Grid x:Name="SheetOverlay" IsVisible="False" BackgroundColor="#99000000">
            <Border x:Name="SheetPanel" Padding="14" StrokeThickness="1" VerticalOptions="End">
                <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="10"><Grid ColumnDefinitions="*,Auto"><Label x:Name="SheetTitleLabel" FontSize="20" FontAttributes="Bold" /><Button Grid.Column="1" Text="إغلاق" Clicked="OnCloseSheetClicked" /></Grid><ScrollView MaximumHeightRequest="460"><VerticalStackLayout x:Name="SheetList" Spacing="10" /></ScrollView></VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
